{
  "name": "@gravity-platform/design-system-dev",
  "version": "0.1.0",
  "private": true,
  "description": "Design System development - Storybook and node generation",
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-index": "node -e \"require('fs').mkdirSync('.storybook-index',{recursive:true})\" && storybook index --output-file .storybook-index/index.json",
    "gen:nodes": "npm run generate-index && ts-node scripts/generate-nodes.ts"
  },
  "devDependencies": {
    "@storybook/react-vite": "9.1.10",
    "autoprefixer": "^10.4.21",
    "identity-obj-proxy": "^3.0.0",
    "postcss": "^8.5.6",
    "storybook": "9.1.10",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@gravity-platform/gravity-client": "github:gravity-platform/gravity-client",
    "chalk": "^5.6.2",
    "clsx": "^2.0.0",
    "lucide-react": "^0.546.0",
    "markdown-to-jsx": "^7.7.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
