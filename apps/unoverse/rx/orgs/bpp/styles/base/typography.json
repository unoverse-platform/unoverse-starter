{
  "$description": "BPP type — Poppins display/headings + Open Sans body over the standard scale/weights/line-heights.",
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": [
          "Open Sans",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Roboto",
          "Helvetica",
          "Arial",
          "sans-serif"
        ]
      },
      "mono": {
        "$value": [
          "ui-monospace",
          "SFMono-Regular",
          "Menlo",
          "Consolas",
          "monospace"
        ]
      },
      "display": {
        "$value": [
          "Poppins",
          "Open Sans",
          "system-ui",
          "sans-serif"
        ]
      }
    },
    "size": {
      "$type": "dimension",
      "xs": {
        "$value": "0.75rem"
      },
      "sm": {
        "$value": "0.875rem"
      },
      "base": {
        "$value": "1rem"
      },
      "lg": {
        "$value": "1.125rem"
      },
      "xl": {
        "$value": "1.25rem"
      },
      "2xl": {
        "$value": "1.5rem"
      },
      "3xl": {
        "$value": "1.875rem"
      },
      "4xl": {
        "$value": "2.25rem"
      },
      "5xl": {
        "$value": "3rem"
      },
      "display": {
        "lg": {
          "$value": "clamp(2.25rem, 2rem + 1vw, 3rem)"
        },
        "md": {
          "$value": "clamp(1.875rem, 1.625rem + 0.75vw, 2.5rem)"
        },
        "sm": {
          "$value": "clamp(1.5rem, 1.375rem + 0.5vw, 2rem)"
        }
      },
      "headline": {
        "lg": {
          "$value": "clamp(1.375rem, 1.25rem + 0.5vw, 1.75rem)"
        },
        "md": {
          "$value": "clamp(1.25rem, 1.125rem + 0.375vw, 1.5rem)"
        },
        "sm": {
          "$value": "clamp(1.125rem, 1.0625rem + 0.25vw, 1.25rem)"
        }
      },
      "title": {
        "lg": {
          "$value": "clamp(1rem, 0.9375rem + 0.25vw, 1.125rem)"
        },
        "md": {
          "$value": "clamp(0.9375rem, 0.875rem + 0.25vw, 1rem)"
        },
        "sm": {
          "$value": "clamp(0.875rem, 0.8125rem + 0.125vw, 0.9375rem)"
        }
      },
      "bodyLg": {
        "$value": "clamp(0.9375rem, 0.875rem + 0.25vw, 1rem)"
      },
      "bodyMd": {
        "$value": "0.9375rem"
      },
      "bodySm": {
        "$value": "0.8125rem"
      },
      "labelLg": {
        "$value": "0.875rem"
      },
      "labelMd": {
        "$value": "0.75rem"
      },
      "labelSm": {
        "$value": "0.6875rem"
      },
      "caption": {
        "$value": "0.625rem"
      }
    },
    "weight": {
      "$type": "fontWeight",
      "light": {
        "$value": 300
      },
      "normal": {
        "$value": 400
      },
      "medium": {
        "$value": 500
      },
      "semibold": {
        "$value": 600
      },
      "bold": {
        "$value": 700
      },
      "extrabold": {
        "$value": 800
      },
      "black": {
        "$value": 900
      }
    },
    "lineHeight": {
      "$type": "number",
      "display": {
        "$value": 1.15
      },
      "headline": {
        "$value": 1.25
      },
      "title": {
        "$value": 1.35
      },
      "label": {
        "$value": 1.4
      },
      "body": {
        "$value": 1.5
      },
      "none": {
        "$value": 1
      },
      "tight": {
        "$value": 1.25
      },
      "snug": {
        "$value": 1.375
      },
      "normal": {
        "$value": 1.5
      },
      "relaxed": {
        "$value": 1.625
      }
    },
    "tracking": {
      "$type": "dimension",
      "display": {
        "$value": "-0.025em"
      },
      "headline": {
        "$value": "-0.0125em"
      },
      "title": {
        "$value": "0"
      },
      "body": {
        "$value": "0.01em"
      },
      "label": {
        "$value": "0.025em"
      },
      "button": {
        "$value": "0.05em"
      },
      "tighter": {
        "$value": "-0.02em"
      },
      "tight": {
        "$value": "-0.0125em"
      },
      "normal": {
        "$value": "0"
      },
      "wide": {
        "$value": "0.05em"
      }
    }
  }
}