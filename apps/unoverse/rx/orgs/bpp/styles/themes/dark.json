{
  "$description": "BPP dark theme — identical to light: the BPP brand IS dark-first (bpp.com). Served at unoverse://theme/bpp/dark.",
  "color": {
    "$type": "color",
    "text": {
      "primary": {
        "$value": "{color.brand.bpp.mist}"
      },
      "secondary": {
        "$value": "{color.brand.bpp.mist-dim}"
      },
      "tertiary": {
        "$value": "{color.brand.bpp.mist-faint}"
      },
      "inverse": {
        "$value": "{color.brand.bpp.night}"
      }
    },
    "surface": {
      "base": {
        "$value": "{color.brand.bpp.night}"
      },
      "raised": {
        "$value": "{color.brand.bpp.coal}"
      },
      "sunken": {
        "$value": "{color.brand.bpp.coal}"
      },
      "inverse": {
        "$value": "{color.brand.bpp.paper-warm}"
      }
    },
    "border": {
      "subtle": {
        "$value": "{color.brand.bpp.coal-soft}"
      },
      "strong": {
        "$value": "{color.brand.bpp.coal-strong}"
      }
    },
    "action": {
      "primary": {
        "$value": "{color.brand.bpp.yellow}"
      },
      "primary-hover": {
        "$value": "{color.brand.bpp.yellow-bright}"
      },
      "primary-active": {
        "$value": "{color.brand.bpp.yellow-bright}"
      },
      "primary-text": {
        "$value": "{color.brand.bpp.night}"
      },
      "subtle": {
        "$value": "{color.brand.bpp.yellow-deep}"
      }
    },
    "status": {
      "success": {
        "$value": "{color.brand.bpp.green-bright}"
      },
      "success-subtle": {
        "$value": "{color.brand.bpp.green-deep}"
      },
      "success-border": {
        "$value": "{color.brand.bpp.green}"
      },
      "success-text": {
        "$value": "{color.brand.bpp.green-subtle}"
      },
      "error": {
        "$value": "{color.brand.bpp.red-bright}"
      },
      "warning": {
        "$value": "{color.brand.bpp.yellow}"
      },
      "info": {
        "$value": "{color.brand.bpp.cobalt-bright}"
      }
    },
    "overlay": {
      "scrim": {
        "$value": "linear-gradient(to top, rgba(0,0,0,0.55), rgba(0,0,0,0.1), transparent)"
      }
    }
  }
}