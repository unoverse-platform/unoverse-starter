{
  "$description": "BPP studio theme — warm white, ink Poppins, highlighter yellow (the restrained alternate). Served at unoverse://theme/bpp/studio.",
  "color": {
    "$type": "color",
    "text": {
      "primary": {
        "$value": "{color.brand.bpp.ink-emphasis}"
      },
      "secondary": {
        "$value": "{color.brand.bpp.ink-subtle}"
      },
      "tertiary": {
        "$value": "{color.brand.bpp.ink-faint}"
      },
      "inverse": {
        "$value": "{color.white}"
      }
    },
    "surface": {
      "base": {
        "$value": "{color.brand.bpp.paper}"
      },
      "raised": {
        "$value": "{color.brand.bpp.paper-warm}"
      },
      "sunken": {
        "$value": "{color.brand.bpp.paper-warm}"
      },
      "inverse": {
        "$value": "{color.brand.bpp.night}"
      }
    },
    "border": {
      "subtle": {
        "$value": "{color.brand.bpp.line-faint}"
      },
      "strong": {
        "$value": "{color.brand.bpp.line}"
      }
    },
    "action": {
      "primary": {
        "$value": "{color.brand.bpp.yellow}"
      },
      "primary-hover": {
        "$value": "{color.brand.bpp.yellow-bright}"
      },
      "primary-active": {
        "$value": "{color.brand.bpp.yellow-bright}"
      },
      "primary-text": {
        "$value": "{color.brand.bpp.ink-emphasis}"
      },
      "subtle": {
        "$value": "{color.brand.bpp.paper-tint}"
      }
    },
    "status": {
      "success": {
        "$value": "{color.brand.bpp.green}"
      },
      "success-subtle": {
        "$value": "{color.brand.bpp.green-subtle}"
      },
      "success-border": {
        "$value": "{color.brand.bpp.green-border}"
      },
      "success-text": {
        "$value": "{color.brand.bpp.green-text}"
      },
      "error": {
        "$value": "{color.brand.bpp.red}"
      },
      "warning": {
        "$value": "{color.brand.bpp.yellow}"
      },
      "info": {
        "$value": "{color.brand.bpp.cobalt}"
      }
    },
    "overlay": {
      "scrim": {
        "$value": "linear-gradient(to top, rgba(0,0,0,0.45), rgba(0,0,0,0.05), transparent)"
      }
    }
  }
}