{
  "$description": "BPP light theme — THE DEFAULT: paper-and-ink content surfaces with cobalt actions (the bpp.com content language). The brand gradient + frosted glass live at brand.bpp.* and are referenced DIRECTLY by shell templates (chat canvas/chrome) — never mapped onto the content semantics, so components render as clean panels. Served at unoverse://theme/bpp/light.",
  "color": {
    "$type": "color",
    "text": {
      "primary": {
        "$value": "{color.brand.bpp.ink}"
      },
      "secondary": {
        "$value": "{color.brand.bpp.ink-subtle}"
      },
      "tertiary": {
        "$value": "{color.brand.bpp.ink-faint}"
      },
      "inverse": {
        "$value": "{color.white}"
      }
    },
    "surface": {
      "base": {
        "$value": "{color.brand.bpp.paper}"
      },
      "raised": {
        "$value": "{color.brand.bpp.paper-warm}"
      },
      "sunken": {
        "$value": "{color.brand.bpp.paper-tint}"
      },
      "inverse": {
        "$value": "{color.brand.bpp.navy}"
      }
    },
    "border": {
      "subtle": {
        "$value": "{color.brand.bpp.line}"
      },
      "strong": {
        "$value": "{color.brand.bpp.line-strong}"
      }
    },
    "action": {
      "primary": {
        "$value": "{color.brand.bpp.cobalt}"
      },
      "primary-hover": {
        "$value": "{color.brand.bpp.cobalt-hover}"
      },
      "primary-active": {
        "$value": "{color.brand.bpp.cobalt-active}"
      },
      "primary-text": {
        "$value": "{color.white}"
      },
      "subtle": {
        "$value": "{color.brand.bpp.cobalt-subtle}"
      }
    },
    "status": {
      "success": {
        "$value": "{color.brand.bpp.green}"
      },
      "success-subtle": {
        "$value": "{color.brand.bpp.green-subtle}"
      },
      "success-border": {
        "$value": "{color.brand.bpp.green-border}"
      },
      "success-text": {
        "$value": "{color.brand.bpp.green-text}"
      },
      "error": {
        "$value": "{color.brand.bpp.red}"
      },
      "warning": {
        "$value": "{color.brand.bpp.yellow}"
      },
      "info": {
        "$value": "{color.brand.bpp.cobalt}"
      }
    },
    "overlay": {
      "scrim": {
        "$value": "linear-gradient(to top, rgba(0,0,0,0.45), rgba(0,0,0,0.05), transparent)"
      }
    }
  }
}
