{
  "$description": "Markdown primitive element styling — DATA, served at theme.prose. The Markdown SDK primitive READS this and applies it; it authors nothing. Grounded in the legacy prose.css. Values reference tokens.",
  "prose": {
    "paragraph": {
      "$value": {
        "margin": "0 0 0.75em 0",
        "lineHeight": "1.5"
      }
    },
    "link": {
      "$value": {
        "color": "{color.brand.bpp.cobalt-bright}",
        "fontWeight": "{font.weight.bold}",
        "textDecoration": "none"
      }
    },
    "linkIcon": {
      "$value": {
        "width": "0.85em",
        "height": "0.85em",
        "display": "inline-block",
        "verticalAlign": "middle",
        "marginLeft": "0.1em",
        "marginBottom": "0.1em"
      }
    },
    "list": {
      "$value": {
        "margin": "{space.3} 0",
        "paddingLeft": "1.5rem"
      }
    },
    "listItem": {
      "$value": {
        "margin": "{space.1} 0"
      }
    },
    "bulletStyle": {
      "$value": "disc"
    },
    "orderedStyle": {
      "$value": "decimal"
    },
    "tableWrap": {
      "$value": {
        "width": "100%",
        "overflowX": "auto",
        "border": "{border.width.thin} solid {color.border.subtle}",
        "borderRadius": "{radius.lg}",
        "margin": "{space.3} 0"
      }
    },
    "table": {
      "$value": {
        "width": "100%",
        "borderCollapse": "collapse"
      }
    },
    "cell": {
      "$value": {
        "padding": "{space.1} {space.2}",
        "textAlign": "left",
        "verticalAlign": "top",
        "borderBottom": "{border.width.thin} solid {color.border.subtle}"
      }
    },
    "headerCell": {
      "$value": {
        "fontWeight": "{font.weight.semibold}",
        "background": "{color.surface.sunken}",
        "color": "{color.text.primary}"
      }
    },
    "image": {
      "$value": {
        "maxWidth": "100%",
        "height": "auto",
        "display": "block",
        "margin": "{space.3} 0",
        "borderRadius": "{radius.lg}",
        "border": "{border.width.thin} solid {color.border.subtle}"
      }
    },
    "imageFallback": {
      "$value": {
        "color": "{color.text.tertiary}"
      }
    },
    "heading": {
      "$value": {
        "h1": "headline.lg",
        "h2": "headline.md",
        "h3": "headline.sm",
        "h4": "title",
        "h5": "title",
        "h6": "title"
      }
    }
  }
}