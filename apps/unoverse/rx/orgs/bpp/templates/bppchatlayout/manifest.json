{
  "name": "BPP Assistant",
  "description": "The BPP learning-support chat for questions about studying with BPP.",
  "whenToUse": "Ask BPP a question or get general guidance about studying \u2014 the conversational home and fallback for learners. Choosing the right course or journey has its own focused finder; everything else starts here.",
  "category": "Assistant",
  "version": "1.0.0",
  "defaultState": "template",
  "inputSchema": {
    "type": "object",
    "properties": {
      "message": {
        "type": "string",
        "description": "The user's request"
      }
    }
  },
  "stateOrder": [
    "welcome",
    "conversation",
    "focus",
    "courses",
    "course",
    "apply"
  ],
  "preview": {
    "conversation": [
      "markdownrenderer"
    ],
    "courses": [
      "coursecard",
      "coursecard",
      "coursecard"
    ],
    "course": [
      "coursecard"
    ],
    "apply": [
      "coursecard"
    ],
    "focus": [
      "journeyfinder"
    ]
  },
  "autoTrigger": false,
  "expose": {
    "openaiApps": false
  },
  "binding": {
    "workflow": "wf-8koixv",
    "trigger": "inputtrigger1"
  },
  "layout": "standard"
}