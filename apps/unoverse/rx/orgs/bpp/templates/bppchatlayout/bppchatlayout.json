{
  "unoverse": "1.0",
  "kind": "template",
  "name": "BPPChatLayout",
  "category": "Layout",
  "description": "BPP-branded chat surface: a brand-gradient welcome (editorial Poppins headline with highlighted word + full-bleed photo journey cards) that gives way to a white conversation sheet — slate assistant cards, cobalt user bubbles — with a pill composer.",
  "whenToUse": "The default BPP branded chat surface.",
  "props": {
    "logoUrl": {
      "type": "string",
      "default": "https://www.datocms-assets.com/106045/1768981856-bpp_endorsed-logo_reversed_rgb.svg"
    },
    "brandName": {
      "type": "string",
      "default": "BPP Assistant"
    },
    "headline": {
      "type": "string",
      "default": "Built to transform"
    },
    "headlineAccent": {
      "type": "string",
      "default": "careers."
    },
    "brandSubtitle": {
      "type": "string",
      "default": "Courses, qualifications and apprenticeships — ask me anything."
    },
    "suggestions": {
      "type": "array",
      "default": [
        {
          "image": "https://www.datocms-assets.com/106045/1727947826-woman-on-computer-edited.png?auto=format&fit=crop&w=520&h=760",
          "tag": "Courses",
          "title": "Find a course",
          "subtitle": "Share your career goals — I'll match you to the right course.",
          "cta": "Find my course",
          "text": "Help me find the right course or learning journey for my career goals"
        },
        {
          "image": "https://www.datocms-assets.com/106045/1727865777-mock-trial-edited.png?auto=format&fit=crop&w=520&h=760",
          "tag": "Professional",
          "title": "Qualifications",
          "subtitle": "ACCA, ACA, SQE — compare routes and find your right fit.",
          "cta": "Compare options",
          "text": "Which professional qualification should I take?"
        },
        {
          "image": "https://www.datocms-assets.com/106045/1720167177-data_and_tech.jpg?auto=format&fit=crop&w=520&h=760",
          "tag": "Earn & learn",
          "title": "Apprenticeships",
          "subtitle": "Routes that pay you a salary while you train for a career.",
          "cta": "Explore routes",
          "text": "What apprenticeship routes are available?"
        }
      ]
    },
    "faqLabel": {
      "type": "string",
      "default": "FAQ"
    },
    "faqs": {
      "type": "array",
      "description": "Quick FAQ pills (the strip above the composer); each sends its text as a message.",
      "default": [
        {
          "text": "How much does ACCA cost?"
        },
        {
          "text": "Can I study online?"
        },
        {
          "text": "What are the entry requirements?"
        },
        {
          "text": "When do courses start?"
        }
      ]
    }
  },
  "root": {
    "type": "Box",
    "style": {
      "direction": "column",
      "width": "full",
      "height": "full",
      "background": "brand.bpp.gradient"
    },
    "children": [
      {
        "type": "Box",
        "style": {
          "direction": "column",
          "flex": 1,
          "minHeight": "0",
          "position": "relative"
        },
        "children": [
          {
            "$include": "blocks/header"
          },
          {
            "type": "Box",
            "style": {
              "direction": "column",
              "flex": 1,
              "minHeight": "0",
              "position": "relative",
              "when": [
                {
                  "field": "hasMessages",
                  "eq": true,
                  "apply": {
                    "background": "brand.bpp.paper",
                    "radiusTopLeft": "2xl",
                    "radiusTopRight": "2xl",
                    "overflow": "hidden"
                  }
                }
              ]
            },
            "children": [
              {
                "$include": "states/welcome"
              },
              {
                "$include": "states/conversation"
              }
            ]
          },
          {
            "type": "Box",
            "visibleWhen": {
              "field": "mode",
              "ne": "focus"
            },
            "style": {
              "position": "absolute",
              "bottom": "0",
              "left": "0",
              "right": "0",
              "direction": "column"
            },
            "children": [
              {
                "$include": "blocks/suggestions"
              }
            ]
          },
          {
            "$include": "states/focus"
          }
        ]
      },
      {
        "$include": "blocks/composer-bar"
      }
    ]
  }
}