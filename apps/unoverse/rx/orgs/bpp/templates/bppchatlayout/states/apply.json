{
  "type": "ComponentSlot",
  "select": {
    "from": "all",
    "where": {
      "field": "defaultState",
      "eq": "apply"
    },
    "limit": 1
  },
  "frame": {
    "type": "Box",
    "style": {
      "flex": 1.6,
      "minWidth": 0,
      "direction": "column",
      "overflow": "auto",
      "borderLeft": "subtle",
      "background": "surface.base"
    },
    "children": [
      {
        "type": "ComponentSlot"
      }
    ]
  }
}
