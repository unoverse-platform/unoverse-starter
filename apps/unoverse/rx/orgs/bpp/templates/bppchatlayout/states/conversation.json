{
  "type": "Box",
  "visibleWhen": "hasMessages",
  "autoScroll": true,
  "style": {
    "flex": 1,
    "minHeight": "0",
    "direction": "column",
    "overflow": "auto",
    "padding": [
      "6",
      "8"
    ]
  },
  "children": [
    {
      "type": "Timeline",
      "style": {
        "direction": "column",
        "gap": "md",
        "margin": ["auto", "0", "0", "0"]
      },
      "assistantData": {
        "avatarUrl": "https://www.datocms-assets.com/106045/1726474870-lion-head-cobal.jpg?auto=format&fit=max&w=200",
        "thinkingText": "Thinking…"
      },
      "user": {
        "$include": "blocks/user-turn"
      },
      "assistant": {
        "$include": "blocks/assistant-turn"
      }
    }
  ]
}