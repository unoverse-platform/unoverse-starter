{
  "type": "Box",
  "visibleWhen": "isEmpty",
  "style": {
    "direction": "column",
    "flex": 1,
    "minHeight": "0",
    "overflow": "hidden",
    "justify": "end",
    "gap": "lg",
    "padding": [
      "xl",
      "xl",
      "md",
      "xl"
    ]
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "align": "start",
        "gap": "sm",
        "maxWidth": 620,
        "padding": [
          "0",
          "xl",
          "0",
          "0"
        ]
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "wrap": "wrap",
            "justify": "start",
            "gap": "3"
          },
          "children": [
            {
              "type": "Text",
              "bind": {
                "value": "headline"
              },
              "style": {
                "font": "display",
                "color": "white",
                "align": "start"
              }
            },
            {
              "type": "Text",
              "bind": {
                "value": "headlineAccent"
              },
              "style": {
                "font": "display",
                "color": "action.primary-text",
                "background": "action.primary",
                "padding": [
                  "0",
                  "2"
                ],
                "radius": "sm",
                "align": "start"
              }
            }
          ]
        },
        {
          "type": "Text",
          "bind": {
            "value": "brandSubtitle"
          },
          "style": {
            "font": "body.lg",
            "color": "brand.bpp.white-dim",
            "align": "start"
          }
        }
      ]
    },
    {
      "type": "Each",
      "bind": {
        "items": "suggestions"
      },
      "style": {
        "direction": "row",
        "gap": "md",
        "width": "full",
        "padding": [
          "2",
          "0",
          "2",
          "0"
        ]
      },
      "template": {
        "type": "Button",
        "action": "sendMessage",
        "style": {
          "position": "relative",
          "flex": "1 1 0",
          "minWidth": 0,
          "height": 350,
          "padding": "0",
          "radius": "2xl",
          "border": "none",
          "overflow": "hidden",
          "cursor": "pointer",
          "transition": "all 200ms ease",
          "shadow": "lg",
          "hover": {
            "shadow": "xl",
            "transform": "scale(1.02)"
          }
        },
        "children": [
          {
            "type": "Image",
            "bind": {
              "src": "image",
              "alt": "title"
            },
            "style": {
              "position": "absolute",
              "inset": "0",
              "width": "full",
              "height": "full",
              "fit": "cover"
            }
          },
          {
            "type": "Box",
            "style": {
              "position": "absolute",
              "inset": "0",
              "direction": "column",
              "align": "start",
              "justify": "end",
              "gap": "sm",
              "padding": "md",
              "background": "brand.bpp.card-scrim",
              "textAlign": "start"
            },
            "children": [
              {
                "type": "Box",
                "style": {
                  "direction": "row",
                  "align": "center",
                  "gap": "xs",
                  "padding": [
                    "xs",
                    "3"
                  ],
                  "radius": "full",
                  "background": "brand.bpp.glass"
                },
                "children": [
                  {
                    "type": "Icon",
                    "icon": "journey",
                    "style": {
                      "width": "3.5",
                      "height": "3.5",
                      "color": "white"
                    }
                  },
                  {
                    "type": "Text",
                    "bind": {
                      "value": "tag"
                    },
                    "style": {
                      "font": "caption",
                      "color": "white",
                      "lineHeight": "tight"
                    }
                  }
                ]
              },
              {
                "type": "Text",
                "bind": {
                  "value": "title"
                },
                "style": {
                  "font": "title",
                  "color": "white",
                  "lineHeight": "tight",
                  "align": "start"
                }
              },
              {
                "type": "Text",
                "bind": {
                  "value": "subtitle"
                },
                "style": {
                  "font": "body.sm",
                  "color": "brand.bpp.white-dim",
                  "lineHeight": "snug",
                  "align": "start"
                }
              },
              {
                "type": "Box",
                "style": {
                  "width": "full",
                  "align": "center",
                  "justify": "center",
                  "padding": "sm",
                  "radius": "full",
                  "background": "white",
                  "margin": [
                    "xs",
                    "0",
                    "0",
                    "0"
                  ],
                  "textAlign": "center"
                },
                "children": [
                  {
                    "type": "Text",
                    "bind": {
                      "value": "cta"
                    },
                    "style": {
                      "font": "button",
                      "color": "brand.bpp.night",
                      "lineHeight": "tight"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}