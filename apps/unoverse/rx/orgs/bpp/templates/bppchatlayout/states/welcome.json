{
  "type": "Box",
  "visibleWhen": "isEmpty",
  "style": {
    "direction": "column",
    "flex": 1,
    "minHeight": "0",
    "overflow": "hidden",
    "justify": "end",
    "gap": "lg",
    "padding": [
      "xl",
      "xl",
      "md",
      "xl"
    ]
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "align": "start",
        "gap": "sm",
        "maxWidth": 620,
        "padding": [
          "0",
          "xl",
          "0",
          "0"
        ]
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "wrap": "wrap",
            "justify": "start",
            "gap": "3"
          },
          "children": [
            {
              "type": "Text",
              "style": {
                "font": "display",
                "color": "white",
                "align": "start"
              },
              "value": "Built to transform"
            },
            {
              "type": "Text",
              "style": {
                "font": "display",
                "color": "action.primary-text",
                "background": "action.primary",
                "padding": [
                  "0",
                  "2"
                ],
                "radius": "sm",
                "align": "start"
              },
              "value": "careers."
            }
          ]
        },
        {
          "type": "Text",
          "style": {
            "font": "body.lg",
            "color": "brand.bpp.white-dim",
            "align": "start"
          },
          "value": "Courses, qualifications and apprenticeships — ask me anything."
        }
      ]
    },
    {
      "type": "Each",
      "style": {
        "direction": "row",
        "gap": "md",
        "width": "full",
        "padding": [
          "2",
          "0",
          "2",
          "0"
        ]
      },
      "template": {
        "type": "Button",
        "action": "sendMessage",
        "style": {
          "position": "relative",
          "flex": "1 1 0",
          "minWidth": 0,
          "height": 350,
          "padding": "0",
          "radius": "2xl",
          "border": "none",
          "overflow": "hidden",
          "cursor": "pointer",
          "transition": "all 200ms ease",
          "shadow": "lg",
          "hover": {
            "shadow": "xl",
            "transform": "scale(1.02)"
          }
        },
        "children": [
          {
            "type": "Image",
            "bind": {
              "src": "image",
              "alt": "title"
            },
            "style": {
              "position": "absolute",
              "inset": "0",
              "width": "full",
              "height": "full",
              "fit": "cover"
            }
          },
          {
            "type": "Box",
            "style": {
              "position": "absolute",
              "inset": "0",
              "direction": "column",
              "align": "start",
              "justify": "end",
              "gap": "sm",
              "padding": "md",
              "background": "brand.bpp.card-scrim",
              "textAlign": "start"
            },
            "children": [
              {
                "type": "Box",
                "style": {
                  "direction": "row",
                  "align": "center",
                  "gap": "xs",
                  "padding": [
                    "xs",
                    "3"
                  ],
                  "radius": "full",
                  "background": "brand.bpp.glass"
                },
                "children": [
                  {
                    "type": "Icon",
                    "icon": "journey",
                    "style": {
                      "width": "4",
                      "height": "4",
                      "color": "white"
                    }
                  },
                  {
                    "type": "Text",
                    "bind": {
                      "value": "tag"
                    },
                    "style": {
                      "font": "caption",
                      "color": "white",
                      "lineHeight": "tight"
                    }
                  }
                ]
              },
              {
                "type": "Text",
                "bind": {
                  "value": "title"
                },
                "style": {
                  "font": "title",
                  "color": "white",
                  "lineHeight": "tight",
                  "align": "start"
                }
              },
              {
                "type": "Text",
                "bind": {
                  "value": "subtitle"
                },
                "style": {
                  "font": "body.sm",
                  "color": "brand.bpp.white-dim",
                  "lineHeight": "snug",
                  "align": "start"
                }
              },
              {
                "type": "Box",
                "style": {
                  "width": "full",
                  "align": "center",
                  "justify": "center",
                  "padding": "sm",
                  "radius": "full",
                  "background": "white",
                  "margin": [
                    "xs",
                    "0",
                    "0",
                    "0"
                  ],
                  "textAlign": "center"
                },
                "children": [
                  {
                    "type": "Text",
                    "bind": {
                      "value": "cta"
                    },
                    "style": {
                      "font": "button",
                      "color": "brand.bpp.night",
                      "lineHeight": "tight"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "items": [
        {
          "image": "https://www.datocms-assets.com/106045/1727947826-woman-on-computer-edited.png?auto=format&fit=crop&w=520&h=760",
          "tag": "Courses",
          "title": "Find a course",
          "subtitle": "Share your career goals — I'll match you to the right course.",
          "cta": "Find my course",
          "text": "Help me find the right course or learning journey for my career goals"
        },
        {
          "image": "https://www.datocms-assets.com/106045/1727865777-mock-trial-edited.png?auto=format&fit=crop&w=520&h=760",
          "tag": "Professional",
          "title": "Qualifications",
          "subtitle": "ACCA, ACA, SQE — compare routes and find your right fit.",
          "cta": "Compare options",
          "text": "Which professional qualification should I take?"
        },
        {
          "image": "https://www.datocms-assets.com/106045/1720167177-data_and_tech.jpg?auto=format&fit=crop&w=520&h=760",
          "tag": "Earn & learn",
          "title": "Apprenticeships",
          "subtitle": "Routes that pay you a salary while you train for a career.",
          "cta": "Explore routes",
          "text": "What apprenticeship routes are available?"
        }
      ]
    }
  ]
}
