{
  "type": "Box",
  "style": {
    "direction": "row",
    "width": "full",
    "height": "full",
    "overflow": "hidden",
    "background": "brand.bpp.gradient"
  },
  "children": [
    {
      "$include": "components/core"
    },
    {
      "type": "ComponentSlot",
      "appWidth": "panel",
      "select": {
        "from": "all",
        "where": {
          "field": "defaultState",
          "eq": "apply"
        },
        "limit": 1
      },
      "frame": {
        "type": "Box",
        "style": {
          "minWidth": 0,
          "height": "full",
          "direction": "column",
          "overflow": "auto",
          "borderLeft": "subtle",
          "background": "surface.base"
        },
        "children": [
          {
            "type": "ComponentSlot"
          }
        ]
      }
    }
  ]
}