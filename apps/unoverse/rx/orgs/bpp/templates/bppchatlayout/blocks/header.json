{
  "type": "Box",
  "style": {
    "direction": "row",
    "align": "center",
    "justify": "space-between",
    "padding": "md",
    "background": "transparent"
  },
  "children": [
    {
      "type": "Image",
      "visibleWhen": "logoUrl",
      "bind": {
        "src": "logoUrl",
        "alt": "brandName"
      },
      "style": {
        "height": "8",
        "fit": "contain"
      }
    },
    { "type": "Ref", "ref": "close-button", "action": "close" }
  ]
}