{
  "type": "Box",
  "style": {
    "direction": "row",
    "align": "center",
    "justify": "space-between",
    "padding": "md",
    "background": "transparent"
  },
  "children": [
    {
      "type": "Image",
      "style": {
        "height": "8",
        "fit": "contain"
      },
      "src": "https://www.datocms-assets.com/106045/1768981856-bpp_endorsed-logo_reversed_rgb.svg",
      "alt": "BPP Assistant"
    },
    {
      "type": "Button",
      "action": "close",
      "style": {
        "flex": "0 0 auto",
        "cursor": "pointer",
        "width": "8",
        "height": "8",
        "radius": "full",
        "background": "surface.base",
        "border": "subtle",
        "shadow": "sm",
        "direction": "row",
        "align": "center",
        "justify": "center",
        "transition": "all 150ms ease",
        "hover": {
          "background": "surface.sunken"
        }
      },
      "children": [
        {
          "type": "Icon",
          "icon": "close",
          "style": {
            "width": "4",
            "height": "4",
            "color": "text.secondary"
          }
        }
      ],
      "visibleWhen": {
        "field": "surfacedView",
        "in": [
          "",
          "courses"
        ]
      }
    }
  ]
}
