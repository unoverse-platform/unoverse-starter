{
  "type": "Box",
  "style": {
    "position": "relative",
    "direction": "column",
    "width": "full",
    "minHeight": "full",
    "background": "surface.base",
    "textAlign": "start"
  },
  "children": [
    {
      "type": "Button",
      "action": {
        "type": "setValue",
        "values": [
          {
            "key": "defaultState",
            "value": "courses"
          }
        ]
      },
      "style": {
        "flex": "0 0 auto",
        "cursor": "pointer",
        "width": "8",
        "height": "8",
        "radius": "full",
        "background": "surface.base",
        "border": "subtle",
        "shadow": "sm",
        "direction": "row",
        "align": "center",
        "justify": "center",
        "transition": "all 150ms ease",
        "hover": {
          "background": "surface.sunken"
        },
        "position": "absolute",
        "inset": "0 0 auto auto",
        "zIndex": 2,
        "margin": "4"
      },
      "children": [
        {
          "type": "Icon",
          "icon": "close",
          "style": {
            "width": "4",
            "height": "4",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "flex": "0 0 auto",
        "height": "50",
        "width": "full",
        "overflow": "hidden"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "src": "primaryImage",
            "alt": "title"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "5",
        "padding": [
          "xl",
          "8"
        ],
        "width": "full",
        "maxWidth": "160",
        "margin": [
          "0",
          "auto"
        ]
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "align": "center",
            "justify": "space-between",
            "gap": "md",
            "width": "full"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "gap": "2",
                "flex": 1,
                "minWidth": 0
              },
              "children": [
                {
                  "type": "Text",
                  "visibleWhen": "tagline",
                  "bind": {
                    "value": "tagline"
                  },
                  "style": {
                    "font": "label",
                    "weight": "semibold",
                    "color": "action.primary"
                  }
                },
                {
                  "type": "Text",
                  "bind": {
                    "value": "title"
                  },
                  "style": {
                    "font": "headline.md",
                    "weight": "bold",
                    "color": "text.primary",
                    "lineHeight": "tight"
                  }
                }
              ]
            },
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "align": "end",
                "gap": "3",
                "flex": "0 0 auto",
                "maxWidth": "75"
              },
              "children": [
                {
                  "type": "Button",
                  "action": {
                    "type": "setValue",
                    "values": [
                      {
                        "key": "defaultState",
                        "value": "apply"
                      }
                    ]
                  },
                  "style": {
                    "direction": "row",
                    "align": "center",
                    "gap": "sm",
                    "flex": "0 0 auto",
                    "background": "transparent",
                    "border": "heavy accent",
                    "radius": "full",
                    "padding": [
                      "3",
                      "5"
                    ],
                    "cursor": "pointer",
                    "transition": "all 150ms ease",
                    "hover": {
                      "background": "action.subtle"
                    }
                  },
                  "children": [
                    {
                      "type": "Icon",
                      "icon": "phone",
                      "style": {
                        "width": "4",
                        "height": "4",
                        "color": "action.primary"
                      }
                    },
                    {
                      "type": "Text",
                      "value": "Request callback",
                      "style": {
                        "font": "button",
                        "weight": "bold",
                        "color": "action.primary"
                      }
                    }
                  ]
                },
                {
                  "type": "Text",
                  "value": "Transform your business, or your career, with industry-leading training from BPP.",
                  "style": {
                    "font": "body.sm",
                    "color": "text.secondary",
                    "textAlign": "end"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Text",
          "visibleWhen": "description",
          "bind": {
            "value": "description"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        },
        {
          "type": "Markdown",
          "visibleWhen": "bodyCopy",
          "bind": {
            "value": "bodyCopy"
          },
          "style": {
            "font": "body.md"
          }
        },
        {
          "type": "Markdown",
          "visibleWhen": "link",
          "bind": {
            "value": "link"
          },
          "style": {
            "font": "body.md"
          }
        }
      ]
    }
  ]
}
