{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "align": "center",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "commitmentTitle"
          },
          "style": {
            "font": "headline.md",
            "weight": "semibold",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "commitmentSubtitle",
          "bind": {
            "value": "commitmentSubtitle"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Button",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "commitment",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "searching"
            },
            {
              "key": "phase",
              "value": "results"
            },
            {
              "key": "progressPct",
              "value": "100%"
            },
            {
              "key": "questionLabel",
              "value": ""
            },
            {
              "key": "headerTitle",
              "value": "Your learning journey"
            },
            {
              "key": "inlinePrimary",
              "value": "Finding your courses…"
            },
            {
              "key": "defaultState",
              "value": "inline"
            }
          ],
          "then": {
            "type": "submit"
          }
        },
        "style": {
          "width": "full",
          "direction": "row",
          "align": "center",
          "gap": "3",
          "padding": "3",
          "textAlign": "start",
          "background": "surface.base",
          "border": "subtle",
          "radius": "lg",
          "cursor": "pointer",
          "transition": "all 150ms ease",
          "hover": {
            "background": "surface.sunken"
          }
        },
        "children": [
          {
            "type": "Icon",
            "visibleWhen": "icon",
            "bind": {
              "name": "icon"
            },
            "style": {
              "width": "6",
              "height": "6",
              "color": "text.secondary"
            }
          },
          {
            "type": "Box",
            "style": {
              "direction": "column",
              "flex": "1",
              "minWidth": "0",
              "gap": "1",
              "align": "start"
            },
            "children": [
              {
                "type": "Text",
                "bind": {
                  "value": "label"
                },
                "style": {
                  "font": "body.md",
                  "weight": "semibold",
                  "color": "text.primary"
                }
              },
              {
                "type": "Text",
                "visibleWhen": "description",
                "bind": {
                  "value": "description"
                },
                "style": {
                  "font": "body.sm",
                  "color": "text.secondary"
                }
              }
            ]
          }
        ]
      },
      "items": [
        {
          "value": "full-time",
          "label": "Full-time",
          "description": "Study will be my main focus",
          "icon": "calendar"
        },
        {
          "value": "part-time",
          "label": "Part-time",
          "description": "Alongside work and other commitments",
          "icon": "clock"
        },
        {
          "value": "flexible",
          "label": "Flexible",
          "description": "My own pace, when it suits me",
          "icon": "sliders"
        }
      ]
    }
  ]
}
