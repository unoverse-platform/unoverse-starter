{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "align": "center",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "subjectTitle"
          },
          "style": {
            "font": "headline.md",
            "weight": "semibold",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "subjectSubtitle",
          "bind": {
            "value": "subjectSubtitle"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Each",
      "style": {
        "direction": "row",
        "wrap": "wrap",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Button",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "subject",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "route"
            },
            {
              "key": "phase",
              "value": "direction"
            },
            {
              "key": "progressPct",
              "value": "66%"
            },
            {
              "key": "questionLabel",
              "value": "Question 4 of 6"
            }
          ]
        },
        "style": {
          "flex": "1 1 40%",
          "minWidth": "40",
          "height": "20",
          "direction": "row",
          "align": "center",
          "gap": "3",
          "padding": [
            "3",
            "4"
          ],
          "textAlign": "start",
          "background": "surface.base",
          "border": "subtle",
          "radius": "lg",
          "cursor": "pointer",
          "transition": "all 150ms ease",
          "hover": {
            "background": "surface.sunken",
            "border": "strong"
          }
        },
        "children": [
          {
            "type": "Icon",
            "visibleWhen": "icon",
            "bind": {
              "name": "icon"
            },
            "style": {
              "width": "6",
              "height": "6",
              "color": "text.secondary"
            }
          },
          {
            "type": "Box",
            "style": {
              "direction": "column",
              "flex": "1",
              "minWidth": "0",
              "gap": "1",
              "align": "start"
            },
            "children": [
              {
                "type": "Text",
                "bind": {
                  "value": "label"
                },
                "style": {
                  "font": "title",
                  "color": "text.primary"
                }
              },
              {
                "type": "Text",
                "visibleWhen": "description",
                "bind": {
                  "value": "description"
                },
                "style": {
                  "font": "body.sm",
                  "color": "text.secondary"
                }
              }
            ]
          }
        ]
      },
      "items": [
        {
          "value": "accountancy-tax",
          "label": "Accountancy & Tax",
          "description": "ACCA, AAT, CIMA, ACA"
        },
        {
          "value": "law",
          "label": "Law",
          "description": "SQE, Bar and conversion"
        },
        {
          "value": "technology",
          "label": "Technology",
          "description": "Software, cyber and IT"
        },
        {
          "value": "hr",
          "label": "HR",
          "description": "CIPD qualifications"
        },
        {
          "value": "management",
          "label": "Management",
          "description": "Teams, projects, change"
        },
        {
          "value": "finance",
          "label": "Finance",
          "description": "CFA and investment"
        },
        {
          "value": "healthcare",
          "label": "Nursing and Healthcare",
          "description": "Degrees and leadership"
        },
        {
          "value": "ai",
          "label": "AI",
          "description": "Skills and apprenticeships"
        }
      ]
    }
  ]
}
