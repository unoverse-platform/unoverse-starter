{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "5",
    "width": "full",
    "animation": {
      "name": "focusFadeIn",
      "duration": "400ms",
      "easing": "ease-out",
      "iteration": "1"
    }
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "row",
        "align": "start",
        "gap": "4",
        "width": "full"
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "flex": "1",
            "minWidth": "0",
            "direction": "column",
            "gap": "1",
            "align": "start"
          },
          "children": [
            {
              "type": "Text",
              "style": {
                "font": "headline.md",
                "weight": "semibold",
                "color": "text.primary"
              },
              "value": "Your learning journey"
            },
            {
              "type": "Text",
              "style": {
                "font": "body.md",
                "color": "text.secondary"
              },
              "value": "Courses matched to your goals"
            }
          ]
        },
        {
          "type": "Button",
          "action": {
            "type": "setValue",
            "values": [
              {
                "key": "step",
                "value": "careerstage"
              },
              {
                "key": "phase",
                "value": "about"
              },
              {
                "key": "progressPct",
                "value": "16%"
              },
              {
                "key": "questionLabel",
                "value": "Question 1 of 6"
              },
              {
                "key": "headerTitle",
                "value": "Find your learning journey"
              },
              {
                "key": "inlinePrimary",
                "value": "Find your ideal course"
              },
              {
                "key": "careerStage",
                "value": null
              },
              {
                "key": "situation",
                "value": null
              },
              {
                "key": "subject",
                "value": null
              },
              {
                "key": "route",
                "value": null
              },
              {
                "key": "studyMode",
                "value": null
              },
              {
                "key": "commitment",
                "value": null
              }
            ]
          },
          "style": {
            "flex": "0 0 auto",
            "cursor": "pointer",
            "font": "label",
            "weight": "medium",
            "background": "transparent",
            "color": "text.tertiary",
            "border": "none",
            "padding": [
              "2",
              "3"
            ]
          },
          "label": "Start again"
        }
      ]
    },
    {
      "type": "Each",
      "bind": {
        "items": "courses"
      },
      "style": {
        "direction": "column",
        "gap": "3",
        "width": "full"
      },
      "template": {
        "type": "Button",
        "action": "selectCourse",
        "style": {
          "width": "full",
          "direction": "row",
          "align": "center",
          "gap": "4",
          "padding": "4",
          "background": "surface.base",
          "border": "subtle",
          "radius": "xl",
          "shadow": "sm",
          "cursor": "pointer",
          "transition": "all 150ms ease",
          "hover": {
            "shadow": "md",
            "background": "surface.sunken"
          }
        },
        "children": [
          {
            "type": "Box",
            "style": {
              "flex": "1",
              "minWidth": "0",
              "direction": "column",
              "gap": "1.5",
              "align": "start"
            },
            "children": [
              {
                "type": "Box",
                "visibleWhen": "badge",
                "style": {
                  "flex": "0 0 auto",
                  "background": "surface.inverse",
                  "radius": "md",
                  "padding": [
                    "1",
                    "3"
                  ]
                },
                "children": [
                  {
                    "type": "Text",
                    "bind": {
                      "value": "badge"
                    },
                    "style": {
                      "font": "caption",
                      "weight": "bold",
                      "lineHeight": "none",
                      "color": "text.inverse"
                    }
                  }
                ]
              },
              {
                "type": "Text",
                "bind": {
                  "value": "name"
                },
                "style": {
                  "font": "headline.sm",
                  "weight": "bold",
                  "lineHeight": "tight",
                  "color": "text.primary"
                }
              },
              {
                "type": "Text",
                "visibleWhen": "description",
                "bind": {
                  "value": "description"
                },
                "style": {
                  "font": "body.md",
                  "color": "text.secondary"
                }
              },
              {
                "type": "Text",
                "visibleWhen": "meta",
                "bind": {
                  "value": "meta"
                },
                "style": {
                  "font": "body.sm",
                  "color": "text.tertiary"
                }
              },
              {
                "type": "Box",
                "visibleWhen": "fitReason",
                "style": {
                  "direction": "row",
                  "align": "center",
                  "gap": "2",
                  "margin": [
                    "1",
                    "0",
                    "0",
                    "0"
                  ]
                },
                "children": [
                  {
                    "type": "Box",
                    "style": {
                      "flex": "0 0 auto",
                      "width": "5",
                      "height": "5",
                      "radius": "full",
                      "background": "status.success-subtle",
                      "direction": "row",
                      "align": "center",
                      "justify": "center"
                    },
                    "children": [
                      {
                        "type": "Icon",
                        "icon": "check",
                        "style": {
                          "width": "4",
                          "height": "4",
                          "color": "status.success"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "bind": {
                      "value": "fitReason"
                    },
                    "style": {
                      "font": "body.sm",
                      "weight": "medium",
                      "color": "text.primary"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "style": {
              "flex": "0 0 auto",
              "width": "10",
              "height": "10",
              "radius": "full",
              "background": "action.primary",
              "direction": "row",
              "align": "center",
              "justify": "center"
            },
            "children": [
              {
                "type": "Icon",
                "icon": "arrowRight",
                "style": {
                  "width": "5",
                  "height": "5",
                  "color": "action.primary-text"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
