{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "align": "center",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "studyModeTitle"
          },
          "style": {
            "font": "headline.md",
            "weight": "semibold",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "studyModeSubtitle",
          "bind": {
            "value": "studyModeSubtitle"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Button",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "studyMode",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "commitment"
            },
            {
              "key": "phase",
              "value": "study"
            },
            {
              "key": "progressPct",
              "value": "100%"
            },
            {
              "key": "questionLabel",
              "value": "Question 6 of 6"
            }
          ]
        },
        "style": {
          "width": "full",
          "direction": "row",
          "align": "center",
          "gap": "3",
          "padding": "3",
          "textAlign": "start",
          "background": "surface.base",
          "border": "subtle",
          "radius": "lg",
          "cursor": "pointer",
          "transition": "all 150ms ease",
          "hover": {
            "background": "surface.sunken"
          }
        },
        "children": [
          {
            "type": "Icon",
            "visibleWhen": "icon",
            "bind": {
              "name": "icon"
            },
            "style": {
              "width": "6",
              "height": "6",
              "color": "text.secondary"
            }
          },
          {
            "type": "Box",
            "style": {
              "direction": "column",
              "flex": "1",
              "minWidth": "0",
              "gap": "1",
              "align": "start"
            },
            "children": [
              {
                "type": "Text",
                "bind": {
                  "value": "label"
                },
                "style": {
                  "font": "body.md",
                  "weight": "semibold",
                  "color": "text.primary"
                }
              },
              {
                "type": "Text",
                "visibleWhen": "description",
                "bind": {
                  "value": "description"
                },
                "style": {
                  "font": "body.sm",
                  "color": "text.secondary"
                }
              }
            ]
          }
        ]
      },
      "items": [
        {
          "value": "online-live",
          "label": "Online Classroom Live",
          "description": "Live online classes with expert tutors",
          "icon": "online"
        },
        {
          "value": "online-ondemand",
          "label": "Online Classroom",
          "description": "On demand, at your own pace",
          "icon": "play"
        },
        {
          "value": "in-centre",
          "label": "In centre",
          "description": "Face-to-face teaching at a study centre",
          "icon": "location"
        },
        {
          "value": "no-preference",
          "label": "No preference",
          "description": "Show me everything that fits",
          "icon": "journey"
        }
      ]
    }
  ]
}
