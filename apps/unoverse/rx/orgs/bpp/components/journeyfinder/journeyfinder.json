{
  "unoverse": "1.0",
  "kind": "component",
  "name": "JourneyFinder",
  "category": "Input",
  "nodeSize": {
    "width": 1040,
    "height": 760
  },
  "outputs": {
    "careerStage": {
      "type": "string",
      "description": "The user's career goal",
      "enum": [
        "start",
        "qualify",
        "build",
        "change"
      ]
    },
    "situation": {
      "type": "string",
      "description": "Current situation",
      "enum": [
        "school-leaver",
        "working",
        "graduate",
        "returning"
      ]
    },
    "subject": {
      "type": "string",
      "description": "Chosen subject area",
      "enum": [
        "accountancy-tax",
        "law",
        "technology",
        "hr",
        "management",
        "finance",
        "healthcare",
        "ai"
      ]
    },
    "route": {
      "type": "string",
      "description": "Preferred learning route",
      "enum": [
        "professional-qualification",
        "apprenticeship",
        "degree",
        "short-courses",
        "unsure"
      ]
    },
    "studyMode": {
      "type": "string",
      "description": "Preferred study mode",
      "enum": [
        "online-live",
        "online-ondemand",
        "in-centre",
        "no-preference"
      ]
    },
    "commitment": {
      "type": "string",
      "description": "Time commitment",
      "enum": [
        "full-time",
        "part-time",
        "flexible"
      ]
    }
  },
  "state": {
    "inlinePrimary": "Find your ideal course",
    "step": "careerstage",
    "phase": "about",
    "progressPct": "16%",
    "questionLabel": "Question 1 of 6",
    "headerTitle": "Find your learning journey",
    "searchStatus": "Matching courses to your goals…"
  },
  "stateOrder": [
    "careerstage",
    "situation",
    "subject",
    "route",
    "studymode",
    "commitment",
    "searching",
    "results"
  ],
  "root": {
    "type": "Box",
    "style": {
      "width": "full",
      "height": "full",
      "container": "inline-size"
    },
    "children": [
      {
        "type": "Switch",
        "on": "defaultState",
        "cases": {
          "focused": {
            "$include": "layouts/focused"
          },
          "inline": {
            "$include": "layouts/inline"
          },
          "default": {
            "$include": "layouts/inline"
          }
        }
      }
    ]
  },
  "props": {
    "courses": {
      "type": "array",
      "input": true,
      "description": "The matched courses the workflow streams back after the questions.",
      "default": [
        {
          "badge": "Professional Qualification",
          "name": "ACCA Qualification",
          "description": "Become a chartered certified accountant with industry-leading pass rates and expert tutors.",
          "meta": "Online Classroom Live · Part-time · 24–36 months",
          "fitReason": "A recognised qualification you can earn while working"
        },
        {
          "badge": "Apprenticeship",
          "name": "Level 7 Accountancy & Taxation Professional",
          "description": "A fully funded route to chartered status with structured employer support.",
          "meta": "Blended · Part-time · 36 months",
          "fitReason": "Employer-funded, so you can qualify without stepping back from work"
        },
        {
          "badge": "Professional Qualification",
          "name": "AAT Level 4 Diploma in Professional Accounting",
          "description": "Deepen your finance skills with a practical, flexible diploma.",
          "meta": "Online Classroom · Flexible · 12–18 months",
          "fitReason": "A flexible stepping stone toward full chartered status"
        }
      ]
    }
  }
}
