{
  "$description": "Yas Island dark theme — identical to light: the Yas Island brand IS dark-first (yasisland.com). Served at unoverse://theme/yasisland/dark.",
  "color": {
    "$type": "color",
    "text": {
      "primary": {
        "$value": "{color.brand.yasisland.paper-tint}"
      },
      "secondary": {
        "$value": "{color.brand.yasisland.line}"
      },
      "tertiary": {
        "$value": "{color.brand.yasisland.mist-faint}"
      },
      "inverse": {
        "$value": "{color.brand.yasisland.ink-emphasis}"
      }
    },
    "surface": {
      "base": {
        "$value": "{color.brand.yasisland.ink-emphasis}"
      },
      "raised": {
        "$value": "{color.brand.yasisland.ink}"
      },
      "sunken": {
        "$value": "{color.brand.yasisland.ink}"
      },
      "inverse": {
        "$value": "{color.brand.yasisland.paper-warm}"
      }
    },
    "border": {
      "subtle": {
        "$value": "{color.brand.yasisland.coal-soft}"
      },
      "strong": {
        "$value": "{color.brand.yasisland.ink-subtle}"
      },
      "accent": {
        "$value": "{color.brand.yasisland.yellow-bright}"
      }
    },
    "action": {
      "primary": {
        "$value": "{color.brand.yasisland.yellow}"
      },
      "primary-hover": {
        "$value": "{color.brand.yasisland.yellow-bright}"
      },
      "primary-active": {
        "$value": "{color.brand.yasisland.yellow-bright}"
      },
      "primary-text": {
        "$value": "{color.brand.yasisland.ink-emphasis}"
      },
      "subtle": {
        "$value": "{color.brand.yasisland.yellow-deep}"
      },
      "cta": {
        "$value": "{color.brand.yasisland.yellow-bright}"
      },
      "cta-text": {
        "$value": "{color.brand.yasisland.ink-emphasis}"
      },
      "cta-hover": {
        "$value": "{color.brand.yasisland.yellow}"
      }
    },
    "status": {
      "success": {
        "$value": "{color.brand.yasisland.green-bright}"
      },
      "success-subtle": {
        "$value": "{color.brand.yasisland.green-deep}"
      },
      "success-border": {
        "$value": "{color.brand.yasisland.green}"
      },
      "success-text": {
        "$value": "{color.brand.yasisland.green-subtle}"
      },
      "error": {
        "$value": "{color.brand.yasisland.red-bright}"
      },
      "warning": {
        "$value": "{color.brand.yasisland.yellow}"
      },
      "info": {
        "$value": "{color.brand.yasisland.cobalt-bright}"
      }
    },
    "overlay": {
      "scrim": {
        "$value": "linear-gradient(to top, rgba(0,0,0,0.72), rgba(0,0,0,0.40) 45%, rgba(0,0,0,0.10) 75%, rgba(0,0,0,0))"
      }
    }
  }
}