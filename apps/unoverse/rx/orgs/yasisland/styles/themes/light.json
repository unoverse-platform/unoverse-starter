{
  "$description": "Yas Island light theme — THE DEFAULT: paper-and-ink content surfaces with cobalt actions (the yasisland.com content language). The brand gradient + frosted glass live at brand.yasisland.* and are referenced DIRECTLY by shell templates (chat canvas/chrome) — never mapped onto the content semantics, so components render as clean panels. Served at unoverse://theme/yasisland/light.",
  "color": {
    "$type": "color",
    "text": {
      "primary": {
        "$value": "{color.brand.yasisland.ink}"
      },
      "secondary": {
        "$value": "{color.brand.yasisland.ink-subtle}"
      },
      "tertiary": {
        "$value": "{color.brand.yasisland.ink-faint}"
      },
      "inverse": {
        "$value": "{color.white}"
      }
    },
    "surface": {
      "base": {
        "$value": "{color.brand.yasisland.paper}"
      },
      "raised": {
        "$value": "{color.brand.yasisland.paper-warm}"
      },
      "sunken": {
        "$value": "{color.brand.yasisland.paper-tint}"
      },
      "inverse": {
        "$value": "{color.brand.yasisland.navy}"
      }
    },
    "border": {
      "subtle": {
        "$value": "{color.brand.yasisland.line}"
      },
      "strong": {
        "$value": "{color.brand.yasisland.line-strong}"
      },
      "accent": {
        "$value": "{color.brand.yasisland.yellow-bright}"
      }
    },
    "action": {
      "primary": {
        "$value": "{color.brand.yasisland.cobalt}"
      },
      "primary-hover": {
        "$value": "{color.brand.yasisland.cobalt-hover}"
      },
      "primary-active": {
        "$value": "{color.brand.yasisland.cobalt-active}"
      },
      "primary-text": {
        "$value": "{color.white}"
      },
      "subtle": {
        "$value": "{color.brand.yasisland.cobalt-subtle}"
      },
      "cta": {
        "$value": "{color.brand.yasisland.yellow-bright}"
      },
      "cta-text": {
        "$value": "{color.brand.yasisland.ink-emphasis}"
      },
      "cta-hover": {
        "$value": "{color.brand.yasisland.yellow}"
      }
    },
    "status": {
      "success": {
        "$value": "{color.brand.yasisland.green}"
      },
      "success-subtle": {
        "$value": "{color.brand.yasisland.green-subtle}"
      },
      "success-border": {
        "$value": "{color.brand.yasisland.green-border}"
      },
      "success-text": {
        "$value": "{color.brand.yasisland.green-text}"
      },
      "error": {
        "$value": "{color.brand.yasisland.red}"
      },
      "warning": {
        "$value": "{color.brand.yasisland.yellow}"
      },
      "info": {
        "$value": "{color.brand.yasisland.cobalt}"
      }
    },
    "overlay": {
      "scrim": {
        "$value": "linear-gradient(to top, rgba(0,0,0,0.72), rgba(0,0,0,0.40) 45%, rgba(0,0,0,0.10) 75%, rgba(0,0,0,0))"
      }
    }
  }
}