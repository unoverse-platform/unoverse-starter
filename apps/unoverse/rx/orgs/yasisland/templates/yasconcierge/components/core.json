{
  "type": "Box",
  "appWidth": "chat",
  "style": {
    "direction": "column",
    "minHeight": "0"
  },
  "children": [
    {
      "$include": "components/header"
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "flex": 1,
        "minHeight": "0",
        "position": "relative",
        "when": [
          {
            "field": "hasMessages",
            "eq": true,
            "apply": {
              "background": "brand.yasisland.paper",
              "radiusTopLeft": "2xl",
              "overflow": "hidden"
            }
          }
        ]
      },
      "children": [
        {
          "$include": "states/welcome"
        },
        {
          "$include": "states/conversation"
        }
      ]
    },
    {
      "$include": "components/composer-bar"
    }
  ]
}
