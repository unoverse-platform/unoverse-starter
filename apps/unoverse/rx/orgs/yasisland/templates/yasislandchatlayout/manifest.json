{
  "name": "Yas Island Assistant",
  "description": "The Yas Island guest chat for planning parks, stays, dining and events.",
  "whenToUse": "Ask Yas Island anything about your visit \u2014 theme parks, hotels, dining, events, tickets and getting around. The conversational home and fallback for guests; anything without its own focused app starts here.",
  "category": "Assistant",
  "version": "1.0.0",
  "defaultState": "template",
  "inputSchema": {
    "type": "object",
    "properties": {
      "message": {
        "type": "string",
        "description": "The user's request"
      }
    }
  },
  "stateOrder": [
    "welcome",
    "conversation",
    "list",
    "focus",
    "page",
    "planned"
  ],
  "preview": {
    "focus": [
      "restaurantcard"
    ],
    "page": [
      "perfectday"
    ],
    "list": [
      "activitycard",
      "activitycard",
      "activitycard"
    ],
    "planned": [
      "restaurantcard",
      "activitycard"
    ]
  },
  "autoTrigger": false,
  "expose": {
    "openaiApps": false
  },
  "binding": {
    "workflow": "wf-8zdhms",
    "trigger": "inputtrigger2"
  },
  "layout": "standard"
}
