{
  "type": "ComponentSlot",
  "select": {
    "from": "all",
    "where": {
      "field": "defaultState",
      "eq": "focused"
    },
    "limit": 1
  },
  "frame": {
    "type": "Box",
    "style": {
      "position": "absolute",
      "inset": "0",
      "width": "full",
      "height": "full",
      "background": "surface.base",
      "overflow": "hidden",
      "direction": "column",
      "align": "stretch"
    },
    "children": [
      {
        "type": "ComponentSlot"
      }
    ]
  }
}
