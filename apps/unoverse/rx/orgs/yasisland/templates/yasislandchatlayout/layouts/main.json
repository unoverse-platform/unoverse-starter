{
  "type": "Box",
  "style": {
    "direction": "column",
    "width": "full",
    "height": "full",
    "background": "brand.yasisland.gradient"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "flex": 1,
        "minHeight": "0",
        "position": "relative"
      },
      "children": [
        {
          "$include": "components/header"
        },
        {
          "type": "Box",
          "style": {
            "direction": "column",
            "flex": 1,
            "minHeight": "0",
            "position": "relative",
            "when": [
              {
                "field": "hasMessages",
                "eq": true,
                "apply": {
                  "background": "brand.yasisland.paper",
                  "radiusTopLeft": "2xl",
                  "radiusTopRight": "2xl",
                  "overflow": "hidden"
                }
              }
            ]
          },
          "children": [
            {
              "$include": "states/welcome"
            },
            {
              "$include": "states/conversation"
            }
          ]
        },
        {
          "type": "Box",
          "style": {
            "position": "absolute",
            "bottom": "0",
            "left": "0",
            "right": "0",
            "direction": "column"
          },
          "children": [
            {
              "$include": "components/suggestions"
            }
          ]
        },
        {
          "$include": "states/focus"
        }
      ]
    },
    {
      "$include": "components/composer-bar"
    }
  ]
}
