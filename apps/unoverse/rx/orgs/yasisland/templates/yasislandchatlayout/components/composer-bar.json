{
  "type": "Box",
  "style": {
    "direction": "row",
    "gap": "sm",
    "padding": [
      "4",
      "8",
      "6",
      "8"
    ],
    "background": "transparent",
    "when": [
      {
        "field": "hasMessages",
        "eq": true,
        "apply": {
          "background": "brand.yasisland.paper"
        }
      }
    ]
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "flex": 1,
        "direction": "row",
        "align": "center",
        "gap": "sm",
        "background": "white",
        "border": "none",
        "radius": "full",
        "shadow": "md",
        "padding": [
          "3",
          "4"
        ]
      },
      "children": [
        {
          "type": "Icon",
          "icon": "chat",
          "style": {
            "width": "5",
            "height": "5",
            "color": "brand.yasisland.ink-faint"
          }
        },
        {
          "type": "Input",
          "placeholder": "Ask me anything…",
          "action": "sendMessage",
          "bind": {
            "value": "draft"
          },
          "style": {
            "flex": 1,
            "font": "body.md",
            "color": "brand.yasisland.ink",
            "background": "transparent",
            "border": "none",
            "outline": "none"
          }
        },
        {
          "type": "Icon",
          "icon": "mic",
          "style": {
            "width": "5",
            "height": "5",
            "color": "brand.yasisland.ink-faint"
          }
        },
        {
          "type": "Button",
          "action": "sendMessage",
          "style": {
            "width": "10",
            "height": "10",
            "align": "center",
            "justify": "center",
            "radius": "full",
            "background": "brand.yasisland.cobalt",
            "border": "none",
            "cursor": "pointer",
            "padding": "0",
            "flex": "0 0 auto",
            "transition": "all 150ms ease",
            "hover": {
              "background": "brand.yasisland.cobalt-hover"
            },
            "direction": "row"
          },
          "children": [
            {
              "type": "Icon",
              "icon": "send",
              "style": {
                "width": "5",
                "height": "5",
                "color": "white"
              }
            }
          ]
        }
      ]
    }
  ]
}