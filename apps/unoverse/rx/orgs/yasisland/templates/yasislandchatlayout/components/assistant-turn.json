{
  "type": "Box",
  "visibleWhen": "active",
  "style": {
    "direction": "row",
    "gap": "sm",
    "align": "start"
  },
  "children": [
    {
      "type": "Image",
      "bind": {
        "src": "avatarUrl",
        "alt": "assistantName"
      },
      "style": {
        "width": "8",
        "height": "8",
        "radius": "full",
        "shadow": "md",
        "fit": "cover"
      }
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "flex": 1,
        "gap": "sm",
        "minWidth": 0
      },
      "children": [
        {
          "type": "ComponentSlot",
          "select": {}
        },
        {
          "type": "Box",
          "visibleWhen": "streaming",
          "children": [
            {
              "type": "Box",
              "visibleWhen": "empty",
              "style": {
                "direction": "row",
                "gap": "sm",
                "align": "center"
              },
              "children": [
                {
                  "$include": "components/thinking-dots"
                },
                {
                  "type": "Text",
                  "bind": {
                    "value": "thinkingText"
                  },
                  "style": {
                    "font": "body.sm",
                    "color": "brand.yasisland.ink-faint"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Text",
          "visibleWhen": "time",
          "bind": {
            "value": "time"
          },
          "style": {
            "font": "body.sm",
            "color": "brand.yasisland.ink-faint"
          }
        }
      ]
    }
  ]
}