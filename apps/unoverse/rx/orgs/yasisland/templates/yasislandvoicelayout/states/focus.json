{
  "type": "Box",
  "visibleWhen": {
    "field": "defaultState",
    "eq": "focus"
  },
  "style": {
    "flex": 1.7,
    "direction": "column",
    "overflow": "auto",
    "padding": "lg",
    "borderLeft": "subtle",
    "background": "surface.base",
    "animation": {
      "name": "slideInRight",
      "duration": "0.3s",
      "easing": "ease-out",
      "iteration": "1"
    }
  },
  "children": [
    {
      "type": "ComponentSlot",
      "select": {
        "from": "all"
      },
      "fallback": {
        "type": "Skeleton",
        "variant": "card"
      }
    }
  ]
}
