{
  "type": "Box",
  "visibleWhen": "isEmpty",
  "style": {
    "direction": "column",
    "align": "center",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "minHeight": "12"
      }
    },
    {
      "type": "Box",
      "style": {
        "minHeight": "20",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "children": [
        {
          "type": "Button",
          "action": "startCall",
          "style": {
            "direction": "row",
            "align": "center",
            "justify": "center",
            "gap": "sm",
            "minHeight": "12",
            "padding": [
              "3",
              "8"
            ],
            "radius": "full",
            "background": "action.cta",
            "color": "action.cta-text",
            "shadow": "md",
            "cursor": "pointer",
            "outline": "none",
            "transition": "all 150ms ease",
            "hover": {
              "background": "action.cta-hover"
            }
          },
          "children": [
            {
              "type": "Icon",
              "style": {
                "width": "6",
                "height": "6"
              },
              "icon": "phone"
            },
            {
              "type": "Text",
              "style": {
                "font": "button"
              },
              "value": "Start Call"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "minHeight": "16",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "children": [
        {
          "type": "Text",
          "style": {
            "font": "body.sm",
            "color": "text.tertiary",
            "align": "center",
            "maxWidth": "90"
          },
          "value": "Tap the button above to start a voice conversation."
        }
      ]
    }
  ]
}
