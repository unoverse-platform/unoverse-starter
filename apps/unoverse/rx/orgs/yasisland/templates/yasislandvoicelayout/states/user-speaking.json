{
  "type": "Box",
  "visibleWhen": {
    "field": "callState",
    "eq": "userSpeaking"
  },
  "style": {
    "direction": "column",
    "align": "center",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "minHeight": "12",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "align": "center",
            "gap": "md",
            "padding": [
              "3",
              "5"
            ],
            "radius": "full",
            "background": "surface.base",
            "border": "subtle",
            "shadow": "sm"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "width": "2",
                "height": "2",
                "radius": "full",
                "background": "action.primary",
                "animation": {
                  "name": "dotPulse",
                  "duration": "1.4s",
                  "easing": "ease-in-out"
                }
              }
            },
            {
              "type": "Text",
              "style": {
                "font": "body.sm",
                "weight": "medium",
                "color": "action.primary"
              },
              "value": "You are speaking…"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "minHeight": "20",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "children": [
        {
          "$include": "components/call-controls"
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "minHeight": "16"
      }
    }
  ]
}
