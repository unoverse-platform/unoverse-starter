{
  "type": "Box",
  "service": "voice",
  "style": {
    "direction": "row",
    "width": "full",
    "height": "full",
    "overflow": "hidden",
    "background": "surface.sunken"
  },
  "children": [
    {
      "$include": "components/core-slim"
    },
    {
      "type": "ComponentSlot",
      "appWidth": "rail",
      "select": {
        "from": "all",
        "where": {
          "field": "defaultState",
          "eq": "planned"
        }
      },
      "frame": {
        "type": "Box",
        "style": {
          "minWidth": 0,
          "height": "full",
          "direction": "column",
          "overflow": "auto",
          "borderLeft": "subtle",
          "background": "surface.base",
          "gap": "md",
          "padding": "md"
        },
        "children": [
          {
            "type": "Text",
            "value": "Your plan",
            "style": {
              "font": "label",
              "weight": "semibold",
              "color": "text.tertiary"
            }
          },
          {
            "type": "ComponentSlot"
          }
        ]
      }
    }
  ]
}