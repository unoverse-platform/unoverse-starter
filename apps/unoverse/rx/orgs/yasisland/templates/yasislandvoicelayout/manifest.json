{
  "name": "Yas Island Voice Assistant",
  "description": "Hands-free voice conversation with the Yas Island assistant.",
  "whenToUse": "Talk to Yas Island by voice \u2014 a live, hands-free audio call instead of typing. Use voice, talk hands-free, have a phone-style conversation about planning your visit. Wanting a human or live agent is a different job, not this.",
  "category": "Assistant",
  "version": "1.0.0",
  "defaultState": "template",
  "inputSchema": {
    "type": "object",
    "properties": {
      "message": {
        "type": "string",
        "description": "The user's request"
      }
    }
  },
  "autoTrigger": false,
  "binding": {
    "workflow": "wf-8zdhms",
    "trigger": "inputtrigger1"
  },
  "preview": {
    "focus": [
      "restaurantcard"
    ],
    "planned": [
      "restaurantcard",
      "activitycard"
    ],
    "page": [
      "perfectday"
    ],
    "list": [
      "activitycard",
      "activitycard",
      "activitycard"
    ]
  },
  "expose": {
    "openaiApps": false
  },
  "service": "voice",
  "layout": "standard",
  "stateOrder": [
    "idle",
    "active",
    "agent-speaking",
    "user-speaking",
    "list",
    "focus",
    "page",
    "planned"
  ]
