{
  "brief": "The opening of the Perfect Day page \u2014 the day named and promised in one full-bleed glance, headline set over the image.",
  "type": "Box",
  "style": {
    "position": "relative",
    "flex": "0 0 auto",
    "height": "120",
    "width": "full",
    "overflow": "hidden"
  },
  "children": [
    {
      "type": "Image",
      "skeleton": true,
      "brief": {
        "description": "The single most striking image among the chosen content \u2014 the one that sells the whole day at a glance. Always from a real content item; never a stock or invented URL. Must be a DIRECT IMAGE FILE URL \u2014 a photo ending .jpg/.jpeg/.png/.webp (often on static.myconnect.ae) taken verbatim from a search result \u2014 NEVER a webpage URL (yasisland.com/en/... pages are not images and render broken)."
      },
      "bind": {
        "src": "heroImage",
        "alt": "headline"
      },
      "style": {
        "position": "absolute",
        "inset": "0",
        "width": "full",
        "height": "full",
        "fit": "cover"
      }
    },
    {
      "type": "Box",
      "style": {
        "position": "absolute",
        "inset": "0",
        "direction": "column",
        "align": "start",
        "justify": "end",
        "gap": "sm",
        "padding": "xl",
        "background": "overlay.scrim",
        "textAlign": "start"
      },
      "children": [
        {
          "type": "Box",
          "visibleWhen": "heroPlace",
          "style": {
            "direction": "row",
            "align": "center",
            "gap": "xs",
            "padding": [
              "xs",
              "3"
            ],
            "radius": "full",
            "background": "brand.yasisland.glass"
          },
          "children": [
            {
              "type": "Icon",
              "icon": "location",
              "style": {
                "width": "4",
                "height": "4",
                "color": "white"
              }
            },
            {
              "type": "Text",
              "brief": {
                "description": "The real place name anchoring the day, verbatim from the content \u2014 never paraphrased.",
                "maxLength": 40
              },
              "bind": {
                "value": "heroPlace"
              },
              "style": {
                "font": "caption",
                "color": "white",
                "lineHeight": "tight"
              }
            }
          ]
        },
        {
          "type": "Text",
          "brief": {
            "description": "Name the day in the guest's OWN emotional language \u2014 'Your evening for two under the fireworks', never a generic label like 'Romantic package'. Plain text only \u2014 never markdown.",
            "maxLength": 60
          },
          "skeleton": true,
          "bind": {
            "value": "headline"
          },
          "style": {
            "font": "display",
            "color": "white",
            "lineHeight": "tight",
            "align": "start",
            "maxWidth": "160"
          }
        },
        {
          "type": "Text",
          "brief": {
            "description": "ONE warm sentence that strings the chosen experiences into a single lived arc, early to late \u2014 a promise, not a summary. Plain text only \u2014 never markdown.",
            "maxLength": 180
          },
          "skeleton": true,
          "bind": {
            "value": "intro"
          },
          "style": {
            "font": "body.lg",
            "color": "brand.yasisland.white-dim",
            "align": "start",
            "maxWidth": "140"
          }
        }
      ]
    }
  ]
}
