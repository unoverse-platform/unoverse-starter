{
  "brief": "One experience of a chapter \u2014 exactly ONE real need/experience from the search results, never invented.",
  "type": "Box",
  "style": {
    "direction": "column",
    "align": "start",
    "gap": "3",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "position": "relative",
        "height": "50",
        "width": "full",
        "overflow": "hidden",
        "radius": "2xl"
      },
      "children": [
        {
          "type": "Image",
          "brief": {
            "description": "The image belonging to THIS content item \u2014 never borrowed from another item, never stock, never invented. Must be a DIRECT IMAGE FILE URL \u2014 a photo ending .jpg/.jpeg/.png/.webp (often on static.myconnect.ae) taken verbatim from a search result \u2014 NEVER a webpage URL (yasisland.com/en/... pages are not images and render broken)."
          },
          "bind": {
            "src": "image",
            "alt": "title"
          },
          "style": {
            "position": "absolute",
            "inset": "0",
            "width": "full",
            "height": "full",
            "fit": "cover"
          }
        },
        {
          "type": "Box",
          "visibleWhen": "place",
          "style": {
            "position": "absolute",
            "inset": "auto auto 0 0",
            "zIndex": 2,
            "margin": "3",
            "direction": "row",
            "align": "center",
            "gap": "xs",
            "padding": [
              "xs",
              "3"
            ],
            "radius": "full",
            "background": "brand.yasisland.glass"
          },
          "children": [
            {
              "type": "Icon",
              "icon": "location",
              "style": {
                "width": "3",
                "height": "3",
                "color": "white"
              }
            },
            {
              "type": "Text",
              "brief": {
                "description": "The real location name from the content item, verbatim \u2014 never paraphrased.",
                "maxLength": 50
              },
              "bind": {
                "value": "place"
              },
              "style": {
                "font": "caption",
                "color": "white",
                "lineHeight": "tight"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Text",
      "brief": {
        "description": "The experience, phrased in the guest's language \u2014 what they'd feel, not the venue's marketing name. 5-8 plain English words, 35-55 characters \u2014 keep every card title in the guide roughly the SAME length (about two lines). Never markdown, never abbreviations or substituted characters to fit \u2014 write a shorter title instead.",
        "maxLength": 55
      },
      "bind": {
        "value": "title"
      },
      "style": {
        "font": "headline.sm",
        "weight": "bold",
        "color": "text.primary",
        "lineHeight": "tight"
      }
    },
    {
      "type": "Markdown",
      "brief": {
        "description": "1-2 sentences grounded ONLY in the source content \u2014 never invent facts, prices, opening times or names not present in it. May use **bold** on the real place names; no other markdown.",
        "maxLength": 240
      },
      "bind": {
        "value": "body"
      },
      "style": {
        "font": "body.md",
        "color": "text.secondary"
      }
    },
    {
      "type": "Ref",
      "ref": "cta-link",
      "visibleWhen": "link",
      "props": {
        "link": "link"
      }
    }
  ]
}
