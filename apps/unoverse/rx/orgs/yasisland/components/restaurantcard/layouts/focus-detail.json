{
  "type": "Box",
  "style": {
    "position": "relative",
    "direction": "column",
    "width": "full",
    "minHeight": "full",
    "background": "surface.base",
    "textAlign": "start"
  },
  "children": [
    {
      "type": "Button",
      "action": {
        "type": "setValue",
        "values": [
          {
            "key": "defaultState",
            "value": "list"
          },
          {
            "key": "step",
            "value": "detail"
          }
        ]
      },
      "style": {
        "flex": "0 0 auto",
        "cursor": "pointer",
        "width": "8",
        "height": "8",
        "radius": "full",
        "background": "surface.base",
        "border": "subtle",
        "shadow": "sm",
        "direction": "row",
        "align": "center",
        "justify": "center",
        "transition": "all 150ms ease",
        "hover": {
          "background": "surface.sunken"
        },
        "position": "absolute",
        "inset": "0 0 auto auto",
        "zIndex": 2,
        "margin": "4"
      },
      "children": [
        {
          "type": "Icon",
          "icon": "close",
          "style": {
            "width": "4",
            "height": "4",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "flex": "0 0 auto",
        "height": "50",
        "width": "full",
        "overflow": "hidden"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "src": "primaryImage",
            "alt": "title"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "5",
        "padding": [
          "xl",
          "8"
        ],
        "width": "full",
        "maxWidth": "160",
        "margin": [
          "0",
          "auto"
        ]
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "align": "center",
            "justify": "space-between",
            "gap": "md",
            "width": "full"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "gap": "2",
                "flex": 1,
                "minWidth": 0
              },
              "children": [
                {
                  "type": "Text",
                  "visibleWhen": "tagline",
                  "bind": {
                    "value": "tagline"
                  },
                  "style": {
                    "font": "label",
                    "weight": "semibold",
                    "color": "action.primary"
                  }
                },
                {
                  "type": "Text",
                  "bind": {
                    "value": "title"
                  },
                  "style": {
                    "font": "headline.md",
                    "weight": "bold",
                    "color": "text.primary",
                    "lineHeight": "tight"
                  }
                }
              ]
            },
            {
              "type": "Button",
              "action": {
                "type": "setValue",
                "values": [
                  {
                    "key": "step",
                    "value": "book"
                  }
                ]
              },
              "style": {
                "direction": "row",
                "align": "center",
                "gap": "xs",
                "flex": "0 0 auto",
                "background": "action.cta",
                "border": "none",
                "radius": "full",
                "padding": [
                  "2",
                  "4"
                ],
                "shadow": "sm",
                "cursor": "pointer",
                "transition": "all 150ms ease",
                "hover": {
                  "background": "action.cta-hover",
                  "shadow": "md"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "value": "Book a table",
                  "style": {
                    "font": "button",
                    "color": "action.cta-text"
                  }
                },
                {
                  "type": "Icon",
                  "icon": "arrowRight",
                  "style": {
                    "width": "3",
                    "height": "3",
                    "color": "action.cta-text"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "style": { "direction": "row", "align": "center", "gap": "3", "wrap": "wrap", "width": "full" },
          "children": [
            {
              "type": "Box",
              "visibleWhen": "openState",
              "style": { "direction": "row", "align": "center", "padding": ["1", "2"], "background": "status.success-subtle", "radius": "full" },
              "children": [
                { "type": "Text", "bind": { "value": "openState" }, "style": { "font": "body.sm", "weight": "semibold", "color": "status.success-text" } }
              ]
            },
            { "type": "Text", "visibleWhen": "hours", "bind": { "value": "hours" }, "style": { "font": "body.sm", "color": "text.secondary" } },
            {
              "type": "Box",
              "visibleWhen": "rating",
              "style": { "direction": "row", "align": "baseline", "gap": "1" },
              "children": [
                { "type": "Text", "value": "★", "style": { "font": "body.md", "color": "action.primary" } },
                { "type": "Text", "bind": { "value": "rating" }, "style": { "font": "body.md", "weight": "semibold", "color": "text.primary" } },
                { "type": "Text", "value": "·", "style": { "font": "body.sm", "color": "text.secondary" } },
                { "type": "Text", "bind": { "value": "reviews" }, "style": { "font": "body.sm", "color": "text.secondary" } },
                { "type": "Text", "value": "reviews", "style": { "font": "body.sm", "color": "text.secondary" } }
              ]
            }
          ]
        },
        {
          "type": "Each",
          "bind": { "items": "highlights" },
          "style": { "direction": "row", "wrap": "wrap", "align": "start", "gap": "2", "width": "full" },
          "template": {
            "type": "Box",
            "style": { "direction": "row", "align": "center", "flex": "0 0 auto", "padding": ["1", "3"], "background": "surface.sunken", "radius": "full" },
            "children": [
              { "type": "Text", "bind": { "value": "label" }, "style": { "font": "body.sm", "color": "text.secondary" } }
            ]
          }
        },
        {
          "type": "Text",
          "visibleWhen": "description",
          "bind": {
            "value": "description"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        },
        {
          "type": "Markdown",
          "visibleWhen": "bodyCopy",
          "bind": {
            "value": "bodyCopy"
          },
          "style": {
            "font": "body.md"
          }
        },
        {
          "type": "Each",
          "bind": { "items": "images" },
          "style": { "direction": "row", "gap": "2", "width": "full", "overflow": "hidden" },
          "template": {
            "type": "Image",
            "bind": { "src": "url" },
            "style": { "width": "28", "height": "20", "fit": "cover", "radius": "md", "flex": "0 0 auto" }
          }
        },
        {
          "type": "Box",
          "style": { "direction": "column", "gap": "1", "width": "full" },
          "children": [
            { "type": "Text", "visibleWhen": "address", "bind": { "value": "address" }, "style": { "font": "body.sm", "color": "text.secondary" } },
            { "type": "Text", "visibleWhen": "contactPhone", "bind": { "value": "contactPhone" }, "style": { "font": "body.sm", "color": "text.secondary" } }
          ]
        }
      ]
    }
  ]
}
