{
  "unoverse": "1.0",
  "kind": "component",
  "name": "NeedCard",
  "category": "Travel",
  "nodeSize": {
    "width": 360,
    "height": 240
  },
  "props": {
    "title": {
      "type": "string",
      "default": "Dining with spectacular fountain views",
      "input": true
    },
    "description": {
      "type": "string",
      "default": "A waterside table timed to the fountain shows — the island's easiest wow moment.",
      "input": true
    },
    "place": {
      "type": "string",
      "default": "The Fountains, Yas Bay",
      "input": true
    },
    "section": {
      "type": "string",
      "default": "things-to-do",
      "input": true
    },
    "reason": {
      "type": "string",
      "default": "Romantic, and the evening stays easy with kids nearby",
      "input": true
    },
    "image": {
      "type": "string",
      "default": "https://picsum.photos/seed/yas-fountains/640/420",
      "input": true
    },
    "handled": {
      "type": "array",
      "default": [
        {
          "text": "Show times checked — 7:30 and 9:00 tonight"
        },
        {
          "text": "Parking: easiest at S5, free shuttle till late"
        },
        {
          "text": "Opening hours confirmed for this evening"
        }
      ],
      "input": true
    }
  },
  "root": {
    "type": "Box",
    "style": {
      "width": "full",
      "container": "inline-size"
    },
    "children": [
      {
        "type": "Switch",
        "on": "defaultState",
        "cases": {
          "inline": {
            "$include": "layouts/inline"
          },
          "horizon": {
            "$include": "layouts/horizon"
          },
          "focus": {
            "$include": "layouts/focus"
          },
          "planned": {
            "$include": "layouts/planned"
          },
          "default": {
            "$include": "layouts/inline"
          }
        }
      }
    ]
  }
}