{
  "type": "Box",
  "style": {
    "direction": "column",
    "width": "full",
    "background": "surface.base",
    "border": "subtle",
    "radius": "xl",
    "shadow": "sm",
    "overflow": "hidden",
    "textAlign": "start",
    "transition": "all 150ms ease",
    "hover": {
      "shadow": "md"
    }
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "flex": "0 0 auto",
        "height": "28",
        "width": "full",
        "overflow": "hidden"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "src": "image",
            "alt": "title"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "padding": "3"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "title"
          },
          "style": {
            "font": "title",
            "weight": "semibold",
            "color": "text.primary",
            "lineHeight": "tight"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "reason",
          "bind": {
            "value": "reason"
          },
          "style": {
            "font": "body.sm",
            "color": "text.secondary",
            "lineHeight": "snug"
          }
        },
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "align": "center",
            "gap": "xs",
            "margin": [
              "1",
              "0",
              "0",
              "0"
            ]
          },
          "children": [
            {
              "type": "Icon",
              "icon": "location",
              "style": {
                "width": "3",
                "height": "3",
                "color": "text.tertiary"
              }
            },
            {
              "type": "Text",
              "bind": {
                "value": "place"
              },
              "style": {
                "font": "caption",
                "color": "text.tertiary",
                "lineHeight": "tight"
              }
            }
          ]
        }
      ]
    }
  ]
}
