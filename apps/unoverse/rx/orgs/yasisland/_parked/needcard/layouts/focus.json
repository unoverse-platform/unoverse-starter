{
  "type": "Box",
  "style": {
    "position": "relative",
    "direction": "column",
    "width": "full",
    "background": "surface.base",
    "textAlign": "start"
  },
  "children": [
    {
      "type": "Button",
      "action": {
        "type": "setValue",
        "values": [
          {
            "key": "defaultState",
            "value": "horizon"
          }
        ]
      },
      "style": {
        "flex": "0 0 auto",
        "cursor": "pointer",
        "width": "8",
        "height": "8",
        "radius": "full",
        "background": "surface.base",
        "border": "subtle",
        "shadow": "sm",
        "direction": "row",
        "align": "center",
        "justify": "center",
        "transition": "all 150ms ease",
        "hover": {
          "background": "surface.sunken"
        },
        "position": "absolute",
        "inset": "0 0 auto auto",
        "zIndex": 2,
        "margin": "4"
      },
      "children": [
        {
          "type": "Icon",
          "icon": "close",
          "style": {
            "width": "4",
            "height": "4",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "flex": "0 0 auto",
        "height": "50",
        "width": "full",
        "overflow": "hidden"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "src": "image",
            "alt": "title"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "4",
        "padding": [
          "xl",
          "6"
        ]
      },
      "children": [
        {
          "type": "Text",
          "visibleWhen": "reason",
          "bind": {
            "value": "reason"
          },
          "style": {
            "font": "label",
            "weight": "semibold",
            "color": "action.primary"
          }
        },
        {
          "type": "Text",
          "bind": {
            "value": "title"
          },
          "style": {
            "font": "headline.md",
            "weight": "bold",
            "color": "text.primary",
            "lineHeight": "tight"
          }
        },
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "align": "center",
            "gap": "xs"
          },
          "children": [
            {
              "type": "Icon",
              "icon": "location",
              "style": {
                "width": "4",
                "height": "4",
                "color": "text.tertiary"
              }
            },
            {
              "type": "Text",
              "bind": {
                "value": "place"
              },
              "style": {
                "font": "body.sm",
                "color": "text.tertiary"
              }
            }
          ]
        },
        {
          "type": "Text",
          "visibleWhen": "description",
          "bind": {
            "value": "description"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        },
        {
          "type": "Box",
          "visibleWhen": "handled",
          "style": {
            "direction": "column",
            "gap": "2",
            "padding": "4",
            "background": "surface.sunken",
            "radius": "xl"
          },
          "children": [
            {
              "type": "Text",
              "value": "Handled for you",
              "style": {
                "font": "label",
                "weight": "semibold",
                "color": "text.tertiary"
              }
            },
            {
              "type": "Each",
              "bind": {
                "items": "handled"
              },
              "style": {
                "direction": "column",
                "gap": "2"
              },
              "template": {
                "type": "Box",
                "style": {
                  "direction": "row",
                  "align": "center",
                  "gap": "2"
                },
                "children": [
                  {
                    "type": "Icon",
                    "icon": "check",
                    "style": {
                      "width": "4",
                      "height": "4",
                      "color": "status.success"
                    }
                  },
                  {
                    "type": "Text",
                    "bind": {
                      "value": "text"
                    },
                    "style": {
                      "font": "body.sm",
                      "color": "text.secondary",
                      "lineHeight": "snug"
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "justify": "start",
            "margin": [
              "1",
              "0",
              "0",
              "0"
            ]
          },
          "children": [
            {
              "type": "Button",
              "action": {
                "type": "setValue",
                "values": [
                  {
                    "key": "defaultState",
                    "value": "planned"
                  }
                ]
              },
              "style": {
                "direction": "row",
                "align": "center",
                "gap": "xs",
                "background": "action.primary",
                "border": "none",
                "radius": "full",
                "padding": [
                  "2",
                  "4"
                ],
                "shadow": "sm",
                "cursor": "pointer",
                "transition": "all 150ms ease",
                "hover": {
                  "background": "action.primary-hover",
                  "shadow": "md"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "value": "Add to plan",
                  "style": {
                    "font": "body.sm",
                    "weight": "medium",
                    "color": "action.primary-text"
                  }
                },
                {
                  "type": "Icon",
                  "icon": "check",
                  "style": {
                    "width": "3",
                    "height": "3",
                    "color": "action.primary-text"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
