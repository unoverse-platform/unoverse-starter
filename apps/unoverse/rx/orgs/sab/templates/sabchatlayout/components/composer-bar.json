{
  "type": "Box",
  "style": { "direction": "row", "gap": "sm", "padding": ["4", "8", "6", "8"], "background": "surface.base" },
  "children": [
    {
      "type": "Box",
      "style": { "flex": 1, "direction": "row", "align": "center", "gap": "sm", "background": "surface.sunken", "border": "subtle", "radius": "full", "shadow": "sm", "padding": ["3", "4"] },
      "children": [
        { "type": "Icon", "icon": "chat", "style": { "width": "5", "height": "5", "color": "action.primary" } },
        {
          "type": "Input",
          "placeholder": "Ask me anything…",
          "action": "sendMessage",
          "bind": { "value": "draft" },
          "style": { "flex": 1, "font": "body.md", "color": "text.primary", "background": "transparent", "border": "none", "outline": "none" }
        },
        { "type": "Icon", "icon": "mic", "style": { "width": "5", "height": "5", "color": "text.tertiary" } },
        {
          "type": "Button",
          "action": "sendMessage",
          "style": { "background": "transparent", "border": "none", "cursor": "pointer", "align": "center", "padding": "0" },
          "children": [
            { "type": "Icon", "icon": "send", "style": { "width": "5", "height": "5", "color": "action.primary" } }
          ]
        }
      ]
    }
  ]
}
