{
  "type": "Box",
  "visibleWhen": "isEmpty",
  "style": {
    "direction": "column",
    "flex": 1,
    "minHeight": "0",
    "overflow": "auto",
    "align": "center",
    "justify": "center",
    "gap": "xl",
    "padding": "xl"
  },
  "children": [
    {
      "type": "Image",
      "style": {
        "height": "10",
        "fit": "contain"
      },
      "src": "https://res.cloudinary.com/sonik/image/upload/v1764865338/SAB/sablogo.jpg",
      "alt": "SAB Smart Assistant"
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "align": "center",
        "gap": "xs"
      },
      "children": [
        {
          "type": "Text",
          "style": {
            "font": "headline.lg",
            "color": "text.primary",
            "align": "center"
          },
          "value": "SAB Smart Assistant"
        },
        {
          "type": "Text",
          "style": {
            "font": "body.md",
            "color": "text.secondary",
            "align": "center"
          },
          "value": "How can I help you today?"
        }
      ]
    },
    {
      "type": "Each",
      "style": {
        "columns": 2,
        "gap": "md",
        "width": "full",
        "maxWidth": 560
      },
      "template": {
        "type": "Button",
        "action": "sendMessage",
        "style": {
          "direction": "column",
          "align": "start",
          "gap": "sm",
          "width": "full",
          "minHeight": "28",
          "padding": "md",
          "border": "subtle",
          "radius": "lg",
          "background": "surface.base",
          "color": "text.primary",
          "cursor": "pointer",
          "transition": "all 150ms ease",
          "hover": {
            "background": "action.subtle",
            "borderRight": "thick action.primary"
          }
        },
        "children": [
          {
            "type": "Box",
            "style": {
              "width": "10",
              "height": "10",
              "direction": "row",
              "align": "center",
              "justify": "center",
              "radius": "xl",
              "background": "action.subtle"
            },
            "children": [
              {
                "type": "Icon",
                "bind": {
                  "name": "icon"
                },
                "style": {
                  "width": "5",
                  "height": "5",
                  "color": "action.primary"
                }
              }
            ]
          },
          {
            "type": "Box",
            "style": {
              "direction": "column",
              "align": "start",
              "gap": "xs"
            },
            "children": [
              {
                "type": "Text",
                "bind": {
                  "value": "title"
                },
                "style": {
                  "font": "title",
                  "color": "text.primary",
                  "lineHeight": "tight"
                }
              },
              {
                "type": "Text",
                "bind": {
                  "value": "subtitle"
                },
                "style": {
                  "font": "body.md",
                  "color": "text.secondary",
                  "lineHeight": "tight"
                }
              }
            ]
          }
        ]
      },
      "items": [
        {
          "icon": "creditCard",
          "title": "Travel Cards",
          "subtitle": "What card is best for travel?",
          "text": "What card is best for travel?"
        },
        {
          "icon": "transfer",
          "title": "Make Transfer",
          "subtitle": "Transfer money to Kieran",
          "text": "Transfer money to Kieran"
        },
        {
          "icon": "newCard",
          "title": "New Card",
          "subtitle": "Which card should I apply for?",
          "text": "Which card should I apply for?"
        },
        {
          "icon": "support",
          "title": "Live Support",
          "subtitle": "I want to speak to a real person",
          "text": "I want to speak to a real person"
        }
      ]
    }
  ]
}
