{
  "type": "Box",
  "visibleWhen": "active",
  "style": { "direction": "row", "gap": "sm", "align": "start" },
  "children": [
    {
      "type": "Image",
      "bind": { "src": "avatarUrl", "alt": "assistantName" },
      "style": { "width": "8", "height": "8", "radius": "full", "shadow": "md", "fit": "cover" }
    },
    {
      "type": "Box",
      "style": { "direction": "column", "flex": 1, "gap": "sm", "minWidth": 0, "maxWidth": "70%" },
      "children": [
        {
          "type": "Box",
          "visibleWhen": { "field": "empty", "eq": false },
          "style": { "background": "surface.sunken", "radius": "2xl", "radiusTopLeft": "0", "padding": ["sm", "md"] },
          "children": [{ "type": "ComponentSlot", "select": {} }]
        },
        {
          "type": "Box",
          "visibleWhen": "streaming",
          "children": [
            {
              "type": "Box",
              "visibleWhen": "empty",
              "style": { "direction": "row", "gap": "sm", "align": "center" },
              "children": [
                { "$include": "blocks/thinking-dots" },
                { "type": "Text", "bind": { "value": "thinkingText" }, "style": { "font": "body.sm", "color": "text.tertiary" } }
              ]
            }
          ]
        },
        { "type": "Text", "visibleWhen": "time", "bind": { "value": "time" }, "style": { "font": "body.sm", "color": "text.tertiary" } }
      ]
    }
  ]
}
