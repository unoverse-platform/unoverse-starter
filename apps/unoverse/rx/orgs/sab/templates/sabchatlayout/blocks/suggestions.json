{
  "type": "Box",
  "visibleWhen": "faqs",
  "style": { "width": "full", "position": "relative", "direction": "column", "background": "surface.base" },
  "children": [
    {
      "type": "Box",
      "visibleWhen": { "field": "openPanel", "eq": "faq" },
      "style": { "width": "full", "direction": "column", "gap": "sm", "background": "surface.sunken", "radius": "lg", "padding": "4", "shadow": "lg", "margin": ["0", "0", "sm", "0"], "animation": { "name": "slideUp", "duration": "0.3s", "easing": "ease-out", "iteration": "1" } },
      "children": [
        {
          "type": "Box",
          "style": { "direction": "row", "justify": "end" },
          "children": [
            { "type": "Ref", "ref": "close-button", "action": { "type": "setTemplateValue", "values": [{ "key": "openPanel", "value": null }] } }
          ]
        },
        {
          "type": "Each",
          "bind": { "items": "faqs" },
          "style": { "direction": "row", "wrap": "wrap", "align": "start", "gap": "sm", "width": "full" },
          "template": {
            "type": "Button",
            "action": { "type": "sendMessage", "then": { "type": "setTemplateValue", "values": [{ "key": "openPanel", "value": null }] } },
            "style": {
              "direction": "row", "align": "center", "flex": "0 0 auto", "maxWidth": "full", "padding": ["sm", "4"],
              "background": "surface.base", "border": "subtle", "outline": "none", "radius": "full", "shadow": "sm",
              "cursor": "pointer", "transition": "all 150ms ease",
              "hover": { "background": "gray.100" }
            },
            "children": [
              { "type": "Text", "bind": { "value": "text" }, "style": { "font": "body.sm", "color": "text.secondary", "lineHeight": "tight" } }
            ]
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": { "width": "full", "direction": "row", "justify": "center", "padding": ["xs", "0"] },
      "children": [
        {
          "type": "Button",
          "action": { "type": "setTemplateValue", "values": [{ "key": "openPanel", "value": "faq" }] },
          "style": {
            "direction": "row", "align": "center", "gap": "xs", "padding": ["xs", "3"],
            "background": "surface.sunken", "border": "subtle", "outline": "none", "radius": "full", "cursor": "pointer",
            "transition": "all 150ms ease", "hover": { "background": "gray.100" }
          },
          "children": [
            { "type": "Icon", "icon": "chat", "style": { "width": "4", "height": "4", "color": "text.tertiary" } },
            { "type": "Text", "bind": { "value": "faqLabel" }, "style": { "font": "body.sm", "color": "text.tertiary", "weight": "medium" } }
          ]
        }
      ]
    }
  ]
}
