{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "align": "center",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "amountTitle"
          },
          "style": {
            "font": "headline.md",
            "weight": "semibold",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "amountSubtitle",
          "bind": {
            "value": "amountSubtitle"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "style": {
            "font": "label",
            "weight": "semibold",
            "color": "text.secondary"
          },
          "value": "Amount"
        },
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "align": "center",
            "gap": "2",
            "width": "full",
            "padding": [
              "3",
              "4"
            ],
            "background": "surface.base",
            "border": "subtle",
            "radius": "lg"
          },
          "children": [
            {
              "type": "Text",
              "style": {
                "font": "headline.sm",
                "weight": "bold",
                "color": "text.tertiary"
              },
              "value": "SAR"
            },
            {
              "type": "Input",
              "placeholder": "0.00",
              "style": {
                "flex": "1",
                "minWidth": "0",
                "font": "headline.sm",
                "weight": "bold",
                "color": "text.primary",
                "background": "transparent",
                "border": "none",
                "outline": "none"
              },
              "value": "1,500.00"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "style": {
            "font": "label",
            "weight": "semibold",
            "color": "text.secondary"
          },
          "value": "Memo (optional)"
        },
        {
          "type": "Input",
          "bind": {
            "value": "memo"
          },
          "placeholder": "What's this for?",
          "style": {
            "width": "full",
            "padding": [
              "3",
              "4"
            ],
            "font": "body.md",
            "color": "text.primary",
            "background": "surface.base",
            "border": "subtle",
            "radius": "lg",
            "outline": "none"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "row",
        "align": "center",
        "gap": "3",
        "width": "full"
      },
      "children": [
        {
          "type": "Button",
          "action": {
            "type": "setValue",
            "values": [
              {
                "key": "step",
                "value": "recipient"
              },
              {
                "key": "progressPct",
                "value": "50%"
              },
              {
                "key": "stepLabel",
                "value": "Step 2 of 4"
              },
              {
                "key": "inlinePrimary",
                "value": "Pick a recipient"
              }
            ]
          },
          "style": {
            "flex": "0 0 auto",
            "cursor": "pointer",
            "font": "button",
            "background": "transparent",
            "color": "text.primary",
            "border": "subtle",
            "padding": [
              "4",
              "6"
            ],
            "radius": "lg"
          },
          "label": "Back"
        },
        {
          "type": "Button",
          "action": {
            "type": "setValue",
            "values": [
              {
                "key": "step",
                "value": "review"
              },
              {
                "key": "progressPct",
                "value": "100%"
              },
              {
                "key": "stepLabel",
                "value": "Step 4 of 4"
              },
              {
                "key": "inlinePrimary",
                "value": "Review & confirm"
              }
            ]
          },
          "style": {
            "flex": "1",
            "cursor": "pointer",
            "font": "button",
            "background": "action.primary",
            "color": "action.primary-text",
            "border": "none",
            "padding": [
              "4",
              "6"
            ],
            "radius": "lg",
            "direction": "row",
            "align": "center",
            "justify": "center",
            "transition": "all 150ms ease",
            "hover": {
              "background": "action.primary-hover"
            }
          },
          "label": "Continue to review"
        }
      ]
    }
  ]
}
