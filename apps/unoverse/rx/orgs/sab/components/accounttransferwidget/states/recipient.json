{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "align": "center",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "recipientTitle"
          },
          "style": {
            "font": "headline.md",
            "weight": "semibold",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "recipientSubtitle",
          "bind": {
            "value": "recipientSubtitle"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Each",
      "bind": {
        "items": "beneficiaries"
      },
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Button",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "recipientLabel",
              "value": "{{name}}"
            },
            {
              "key": "recipientBank",
              "value": "{{bankName}}"
            },
            {
              "key": "step",
              "value": "amount"
            },
            {
              "key": "progressPct",
              "value": "75%"
            },
            {
              "key": "stepLabel",
              "value": "Step 3 of 4"
            },
            {
              "key": "inlinePrimary",
              "value": "Enter the amount"
            }
          ]
        },
        "style": {
          "width": "full",
          "direction": "column",
          "gap": "1",
          "align": "start",
          "padding": "3",
          "background": "surface.base",
          "border": "subtle",
          "radius": "lg",
          "cursor": "pointer",
          "transition": "all 150ms ease",
          "hover": {
            "background": "surface.sunken"
          }
        },
        "children": [
          {
            "type": "Box",
            "style": {
              "direction": "row",
              "align": "start",
              "justify": "space-between",
              "gap": "3",
              "width": "full"
            },
            "children": [
              {
                "type": "Box",
                "style": {
                  "direction": "column",
                  "align": "start",
                  "gap": "0",
                  "flex": "1",
                  "minWidth": "0"
                },
                "children": [
                  {
                    "type": "Text",
                    "bind": {
                      "value": "name"
                    },
                    "style": {
                      "font": "body.md",
                      "weight": "semibold",
                      "color": "text.primary"
                    }
                  },
                  {
                    "type": "Text",
                    "visibleWhen": "accountNumber",
                    "bind": {
                      "value": "accountNumber"
                    },
                    "style": {
                      "font": "caption",
                      "color": "text.tertiary"
                    }
                  }
                ]
              },
              {
                "type": "Text",
                "visibleWhen": "balance",
                "bind": {
                  "value": "balance"
                },
                "style": {
                  "flex": "0 0 auto",
                  "font": "body.md",
                  "weight": "bold",
                  "color": "text.primary"
                }
              }
            ]
          },
          {
            "type": "Text",
            "visibleWhen": "bankName",
            "bind": {
              "value": "bankName"
            },
            "style": {
              "font": "body.sm",
              "color": "text.secondary"
            }
          }
        ]
      }
    }
  ]
}
