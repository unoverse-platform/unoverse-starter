{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "align": "center",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "feeTitle"
          },
          "style": {
            "font": "headline.md",
            "weight": "semibold",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "feeSubtitle",
          "bind": {
            "value": "feeSubtitle"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Button",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "feeTolerance",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "result"
            },
            {
              "key": "phase",
              "value": "result"
            },
            {
              "key": "progressPct",
              "value": "100%"
            },
            {
              "key": "headerTitle",
              "value": "Your Best Match"
            },
            {
              "key": "inlinePrimary",
              "value": "View your recommendation"
            }
          ]
        },
        "style": {
          "width": "full",
          "direction": "row",
          "align": "center",
          "gap": "3",
          "padding": "3",
          "textAlign": "start",
          "background": "surface.base",
          "border": "subtle",
          "radius": "lg",
          "cursor": "pointer",
          "transition": "all 150ms ease",
          "hover": {
            "background": "surface.sunken"
          }
        },
        "children": [
          {
            "type": "Icon",
            "visibleWhen": "icon",
            "bind": {
              "name": "icon"
            },
            "style": {
              "width": "6",
              "height": "6",
              "color": "text.secondary"
            }
          },
          {
            "type": "Box",
            "style": {
              "direction": "column",
              "flex": "1",
              "minWidth": "0",
              "gap": "1",
              "align": "start"
            },
            "children": [
              {
                "type": "Text",
                "bind": {
                  "value": "label"
                },
                "style": {
                  "font": "body.md",
                  "weight": "semibold",
                  "color": "text.primary"
                }
              },
              {
                "type": "Text",
                "visibleWhen": "description",
                "bind": {
                  "value": "description"
                },
                "style": {
                  "font": "body.sm",
                  "color": "text.secondary"
                }
              }
            ]
          }
        ]
      },
      "items": [
        {
          "value": "low",
          "label": "Prefer free / low fee",
          "description": "Keep costs minimal"
        },
        {
          "value": "medium",
          "label": "Will pay if value is clear",
          "description": "Balance cost and benefits"
        },
        {
          "value": "high",
          "label": "Happy to pay for premium",
          "description": "Best perks matter most"
        }
      ]
    }
  ]
}
