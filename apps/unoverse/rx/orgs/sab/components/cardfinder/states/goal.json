{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "align": "center",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "goalTitle"
          },
          "style": {
            "font": "headline.md",
            "weight": "semibold",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "goalSubtitle",
          "bind": {
            "value": "goalSubtitle"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        }
      ]
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Button",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "goal",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "airline"
            },
            {
              "key": "phase",
              "value": "bestfit"
            },
            {
              "key": "progressPct",
              "value": "66%"
            },
            {
              "key": "questionLabel",
              "value": "Question 5 of 7"
            }
          ]
        },
        "style": {
          "width": "full",
          "direction": "row",
          "align": "center",
          "gap": "3",
          "padding": "3",
          "textAlign": "start",
          "background": "surface.base",
          "border": "subtle",
          "radius": "lg",
          "cursor": "pointer",
          "transition": "all 150ms ease",
          "hover": {
            "background": "surface.sunken"
          }
        },
        "children": [
          {
            "type": "Icon",
            "visibleWhen": "icon",
            "bind": {
              "name": "icon"
            },
            "style": {
              "width": "6",
              "height": "6",
              "color": "text.secondary"
            }
          },
          {
            "type": "Box",
            "style": {
              "direction": "column",
              "flex": "1",
              "minWidth": "0",
              "gap": "1",
              "align": "start"
            },
            "children": [
              {
                "type": "Text",
                "bind": {
                  "value": "label"
                },
                "style": {
                  "font": "body.md",
                  "weight": "semibold",
                  "color": "text.primary"
                }
              },
              {
                "type": "Text",
                "visibleWhen": "description",
                "bind": {
                  "value": "description"
                },
                "style": {
                  "font": "body.sm",
                  "color": "text.secondary"
                }
              }
            ]
          }
        ]
      },
      "items": [
        {
          "value": "cashback",
          "label": "Cashback",
          "description": "Earn money back on everyday purchases",
          "icon": "coins"
        },
        {
          "value": "travel",
          "label": "Travel perks",
          "description": "Lounges, insurance, and travel benefits",
          "icon": "plane"
        },
        {
          "value": "miles",
          "label": "Airline miles",
          "description": "Earn miles with your preferred airline",
          "icon": "ticket"
        },
        {
          "value": "premium",
          "label": "Premium lifestyle",
          "description": "Concierge, exclusive access, and luxury perks",
          "icon": "crown"
        }
      ]
    }
  ]
}
