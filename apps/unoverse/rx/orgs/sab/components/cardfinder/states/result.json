{
  "type": "Box",
  "style": {
    "direction": "row",
    "width": "full",
    "gap": "8",
    "padding": "0",
    "minHeight": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "flex": "1",
        "direction": "column",
        "align": "center",
        "justify": "center",
        "gap": "3",
        "minWidth": "0",
        "background": "surface.sunken",
        "padding": [
          "5",
          "2"
        ]
      },
      "children": [
        {
          "type": "Image",
          "style": {
            "width": "full",
            "maxWidth": "120",
            "radius": "xl",
            "shadow": "lg"
          },
          "src": "https://res.cloudinary.com/sonik/image/upload/v1767547655/SAB/ek-visa-472X296.png",
          "alt": "SAB Emirates Infinite"
        },
        {
          "type": "Box",
          "style": {
            "width": "full",
            "maxWidth": "120",
            "direction": "row",
            "align": "center",
            "justify": "center",
            "gap": "6",
            "padding": [
              "3",
              "4"
            ],
            "background": "surface.base",
            "border": "subtle",
            "radius": "xl",
            "shadow": "sm"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "align": "center",
                "gap": "0"
              },
              "children": [
                {
                  "type": "Text",
                  "style": {
                    "font": "headline.sm",
                    "weight": "bold",
                    "color": "text.primary"
                  },
                  "value": "750"
                },
                {
                  "type": "Text",
                  "style": {
                    "font": "caption",
                    "color": "text.tertiary"
                  },
                  "value": "SAR / year"
                }
              ]
            },
            {
              "type": "Box",
              "style": {
                "flex": "0 0 auto",
                "width": "1",
                "height": "10",
                "background": "border.subtle",
                "radius": "full"
              }
            },
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "align": "center",
                "gap": "0"
              },
              "children": [
                {
                  "type": "Text",
                  "style": {
                    "font": "headline.sm",
                    "weight": "bold",
                    "color": "text.primary"
                  },
                  "value": "Infinite"
                },
                {
                  "type": "Text",
                  "style": {
                    "font": "caption",
                    "color": "text.tertiary"
                  },
                  "value": "Card Tier"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "flex": "1.4",
        "direction": "column",
        "justify": "center",
        "gap": "4",
        "minWidth": "0",
        "padding": [
          "6",
          "8",
          "6",
          "0"
        ]
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "direction": "column",
            "align": "start",
            "gap": "1",
            "width": "full",
            "textAlign": "start"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "align": "start",
                "gap": "1",
                "flex": "0 0 auto"
              },
              "children": [
                {
                  "type": "Box",
                  "style": {
                    "width": "16",
                    "height": "16",
                    "radius": "full",
                    "radial": {
                      "fill": "status.success",
                      "track": "surface.sunken",
                      "at": "{{matchScore}}"
                    },
                    "direction": "row",
                    "align": "center",
                    "justify": "center"
                  },
                  "children": [
                    {
                      "type": "Box",
                      "style": {
                        "width": "12",
                        "height": "12",
                        "radius": "full",
                        "background": "surface.base",
                        "direction": "row",
                        "align": "center",
                        "justify": "center"
                      },
                      "children": [
                        {
                          "type": "Text",
                          "bind": {
                            "value": "matchScore"
                          },
                          "style": {
                            "font": "body.md",
                            "weight": "bold",
                            "color": "status.success-text"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Text",
                  "bind": {
                    "value": "matchLabel"
                  },
                  "style": {
                    "font": "caption",
                    "weight": "semibold",
                    "color": "text.tertiary"
                  }
                }
              ]
            },
            {
              "type": "Text",
              "style": {
                "font": "headline.md",
                "weight": "bold",
                "lineHeight": "tight",
                "color": "text.primary"
              },
              "value": "SAB Emirates Infinite"
            },
            {
              "type": "Text",
              "style": {
                "font": "body.md",
                "color": "text.secondary"
              },
              "value": "Premium travel card with Emirates Skywards miles and unlimited lounge access."
            }
          ]
        },
        {
          "type": "Box",
          "style": {
            "direction": "column",
            "gap": "2",
            "width": "full"
          },
          "children": [
            {
              "type": "Text",
              "style": {
                "font": "label",
                "weight": "semibold",
                "color": "text.tertiary"
              },
              "value": "Key Benefits"
            },
            {
              "type": "Each",
              "style": {
                "direction": "column",
                "gap": "1.5",
                "width": "full"
              },
              "template": {
                "type": "Box",
                "style": {
                  "direction": "row",
                  "align": "center",
                  "gap": "3",
                  "width": "full",
                  "padding": [
                    "1.5",
                    "0"
                  ]
                },
                "children": [
                  {
                    "type": "Box",
                    "style": {
                      "flex": "0 0 auto",
                      "width": "5",
                      "height": "5",
                      "radius": "full",
                      "background": "status.success-subtle",
                      "direction": "row",
                      "align": "center",
                      "justify": "center"
                    },
                    "children": [
                      {
                        "type": "Icon",
                        "icon": "check",
                        "style": {
                          "width": "4",
                          "height": "4",
                          "color": "status.success"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "bind": {
                      "value": "label"
                    },
                    "style": {
                      "font": "body.md",
                      "color": "text.primary"
                    }
                  }
                ]
              },
              "items": [
                {
                  "label": "Earn Emirates Skywards miles on every spend"
                },
                {
                  "label": "Unlimited airport lounge access worldwide"
                },
                {
                  "label": "Comprehensive travel insurance included"
                },
                {
                  "label": "Dedicated premium concierge service"
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "style": {
            "direction": "column",
            "gap": "2",
            "width": "full",
            "align": "start"
          },
          "children": [
            {
              "type": "Button",
              "action": "apply",
              "style": {
                "direction": "row",
                "align": "center",
                "justify": "center",
                "gap": "2",
                "cursor": "pointer",
                "background": "action.primary",
                "border": "none",
                "padding": [
                  "2",
                  "5"
                ],
                "radius": "lg",
                "transition": "all 150ms ease",
                "hover": {
                  "background": "action.primary-hover"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "style": {
                    "font": "button",
                    "color": "action.primary-text"
                  },
                  "value": "Apply for this card"
                },
                {
                  "type": "Icon",
                  "icon": "arrowRight",
                  "style": {
                    "width": "5",
                    "height": "5",
                    "color": "action.primary-text"
                  }
                }
              ]
            },
            {
              "type": "Text",
              "style": {
                "font": "caption",
                "color": "text.tertiary",
                "width": "full"
              },
              "value": "Annual fee SAR 750 (without VAT) · Instant decision"
            }
          ]
        }
      ]
    }
  ]
}
