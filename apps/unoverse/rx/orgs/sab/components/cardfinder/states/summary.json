{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full",
    "align": "center"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "width": "16",
        "height": "16",
        "radius": "full",
        "background": "status.success",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "children": [
        {
          "type": "Icon",
          "icon": "success",
          "style": {
            "width": "8",
            "height": "8",
            "color": "text.inverse"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "1",
        "align": "center",
        "width": "full"
      },
      "children": [
        {
          "type": "Text",
          "style": {
            "font": "headline.sm",
            "weight": "semibold",
            "color": "text.primary"
          },
          "value": "You're Eligible!"
        },
        {
          "type": "Text",
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          },
          "value": "Let's find your perfect card"
        }
      ]
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Box",
        "style": {
          "width": "full",
          "direction": "row",
          "align": "center",
          "gap": "3",
          "padding": "4",
          "background": "surface.sunken",
          "radius": "lg"
        },
        "children": [
          {
            "type": "Icon",
            "icon": "success",
            "style": {
              "width": "5",
              "height": "5",
              "color": "status.success"
            }
          },
          {
            "type": "Text",
            "bind": {
              "value": "label"
            },
            "style": {
              "font": "body.md",
              "weight": "medium",
              "color": "text.primary"
            }
          }
        ]
      },
      "items": [
        {
          "label": "Premium Travel Cards"
        },
        {
          "label": "Travel Essentials"
        },
        {
          "label": "Cashback Cards"
        }
      ]
    },
    {
      "type": "Button",
      "action": {
        "type": "setValue",
        "values": [
          {
            "key": "step",
            "value": "goal"
          },
          {
            "key": "phase",
            "value": "bestfit"
          },
          {
            "key": "progressPct",
            "value": "55%"
          },
          {
            "key": "questionLabel",
            "value": "Question 4 of 7"
          },
          {
            "key": "headerTitle",
            "value": "Personalise Your Match"
          },
          {
            "key": "inlinePrimary",
            "value": "Tell us your preferences"
          }
        ]
      },
      "style": {
        "width": "full",
        "cursor": "pointer",
        "direction": "row",
        "align": "center",
        "justify": "center",
        "background": "action.primary",
        "border": "none",
        "padding": [
          "3",
          "6"
        ],
        "radius": "sm",
        "hover": {
          "background": "action.primary-hover"
        }
      },
      "children": [
        {
          "type": "Text",
          "value": "Find My Card",
          "style": {
            "font": "button",
            "color": "action.primary-text"
          }
        }
      ]
    }
  ]
}
