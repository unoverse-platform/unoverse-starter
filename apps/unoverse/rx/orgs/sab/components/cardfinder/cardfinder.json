{
  "unoverse": "1.0",
  "kind": "component",
  "name": "CardFinder",
  "category": "Input",
  "nodeSize": {
    "width": 1040,
    "height": 760
  },
  "state": {
    "inlinePrimary": "Find your perfect card",
    "step": "income",
    "phase": "eligibility",
    "progressPct": "14%",
    "questionLabel": "Question 1 of 7",
    "headerTitle": "Quick Eligibility Check"
  },
  "stateOrder": [
    "income",
    "salary",
    "residency",
    "summary",
    "goal",
    "airline",
    "travelfreq",
    "feetolerance",
    "result"
  ],
  "root": {
    "type": "Box",
    "style": {
      "width": "full",
      "height": "full",
      "container": "inline-size"
    },
    "children": [
      {
        "type": "Switch",
        "on": "defaultState",
        "cases": {
          "focused": {
            "$include": "layouts/focused"
          },
          "inline": {
            "$include": "layouts/inline"
          },
          "default": {
            "$include": "layouts/inline"
          }
        }
      }
    ]
  }
}
