{
  "type": "Box",
  "style": {
    "position": "relative",
    "width": "full",
    "height": "full",
    "minHeight": "160",
    "container": "inline-size",
    "direction": "row",
    "background": "surface.base",
    "overflow": "hidden"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "flex": "1.5",
        "minWidth": "0",
        "minHeight": "0",
        "direction": "column"
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "width": "full",
            "direction": "row",
            "align": "center",
            "gap": "4",
            "padding": [
              "4",
              "6"
            ],
            "background": "surface.inverse"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "width": "12",
                "height": "12",
                "radius": "xl",
                "border": "subtle",
                "direction": "row",
                "align": "center",
                "justify": "center"
              },
              "children": [
                {
                  "type": "Icon",
                  "icon": "creditCard",
                  "style": {
                    "width": "7",
                    "height": "7",
                    "color": "text.inverse"
                  }
                }
              ]
            },
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "gap": "0"
              },
              "children": [
                {
                  "type": "Text",
                  "bind": {
                    "value": "headerTitle"
                  },
                  "style": {
                    "font": "headline.lg",
                    "weight": "semibold",
                    "color": "text.inverse"
                  }
                },
                {
                  "type": "Text",
                  "style": {
                    "font": "body.sm",
                    "color": "text.inverse"
                  },
                  "value": "3 quick questions"
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "visibleWhen": {
            "field": "phase",
            "ne": "result"
          },
          "style": {
            "direction": "column",
            "gap": "3",
            "padding": [
              "4",
              "8"
            ],
            "width": "full",
            "borderBottom": "subtle"
          },
          "children": [
            {
              "$include": "components/phase-stepper"
            }
          ]
        },
        {
          "type": "Box",
          "style": {
            "flex": "1",
            "minHeight": "0",
            "overflow": "auto",
            "direction": "column",
            "gap": "5",
            "padding": [
              "6",
              "8"
            ],
            "width": "full",
            "when": [
              {
                "field": "step",
                "eq": "result",
                "apply": {
                  "padding": "0"
                }
              }
            ]
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "width": "full",
                "direction": "column",
                "margin": [
                  "auto",
                  "0"
                ],
                "when": [
                  {
                    "field": "step",
                    "eq": "result",
                    "apply": {
                      "minHeight": "full"
                    }
                  }
                ]
              },
              "children": [
                {
                  "type": "Switch",
                  "on": "step",
                  "cases": {
                    "income": {
                      "$include": "states/income"
                    },
                    "salary": {
                      "$include": "states/salary"
                    },
                    "residency": {
                      "$include": "states/residency"
                    },
                    "summary": {
                      "$include": "states/summary"
                    },
                    "goal": {
                      "$include": "states/goal"
                    },
                    "airline": {
                      "$include": "states/airline"
                    },
                    "travelfreq": {
                      "$include": "states/travelfreq"
                    },
                    "feetolerance": {
                      "$include": "states/feetolerance"
                    },
                    "result": {
                      "$include": "states/result"
                    },
                    "default": {
                      "$include": "states/income"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "visibleWhen": {
        "field": "step",
        "ne": "result"
      },
      "style": {
        "flex": "0.75",
        "minWidth": "0",
        "direction": "column",
        "background": "surface.sunken",
        "overflow": "hidden",
        "hideBelow": "160"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "alt": "headerTitle"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          },
          "src": "https://res.cloudinary.com/sonik/image/upload/v1767543207/SAB/travel.jpg"
        }
      ]
    },
    {
      "type": "Button",
      "action": {
        "type": "setValue",
        "values": [
          {
            "key": "defaultState",
            "value": "inline"
          }
        ]
      },
      "style": {
        "flex": "0 0 auto",
        "cursor": "pointer",
        "width": "8",
        "height": "8",
        "radius": "full",
        "background": "surface.base",
        "border": "subtle",
        "shadow": "sm",
        "direction": "row",
        "align": "center",
        "justify": "center",
        "transition": "all 150ms ease",
        "hover": {
          "background": "surface.sunken"
        },
        "position": "absolute",
        "inset": "0 0 auto auto",
        "margin": "4"
      },
      "children": [
        {
          "type": "Icon",
          "icon": "close",
          "style": {
            "width": "4",
            "height": "4",
            "color": "text.secondary"
          }
        }
      ]
    }
  ]
}
