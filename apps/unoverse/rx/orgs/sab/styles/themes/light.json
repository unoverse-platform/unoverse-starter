{
  "$description": "SAB light theme — this org's default semantic color layer; action colors point at the SAB brand ramp (base/color.json). Served at unoverse://theme/sab/light.",
  "color": {
    "$type": "color",
    "text": {
      "primary": {
        "$value": "{color.gray.900}"
      },
      "secondary": {
        "$value": "{color.gray.600}"
      },
      "tertiary": {
        "$value": "{color.gray.500}"
      },
      "inverse": {
        "$value": "{color.white}"
      }
    },
    "surface": {
      "base": {
        "$value": "{color.white}"
      },
      "raised": {
        "$value": "{color.white}"
      },
      "sunken": {
        "$value": "{color.gray.50}"
      },
      "inverse": {
        "$value": "{color.gray.800}"
      }
    },
    "border": {
      "subtle": {
        "$value": "{color.gray.200}"
      },
      "strong": {
        "$value": "{color.gray.300}"
      }
    },
    "action": {
      "primary": {
        "$value": "{color.brand.sab.red}"
      },
      "primary-hover": {
        "$value": "{color.brand.sab.red-hover}"
      },
      "primary-active": {
        "$value": "{color.brand.sab.red-active}"
      },
      "primary-text": {
        "$value": "{color.white}"
      },
      "subtle": {
        "$value": "{color.brand.sab.red-subtle}"
      }
    },
    "status": {
      "success": {
        "$value": "{color.primary.500}"
      },
      "success-subtle": {
        "$value": "{color.primary.50}"
      },
      "success-border": {
        "$value": "{color.primary.200}"
      },
      "success-text": {
        "$value": "{color.primary.700}"
      },
      "error": {
        "$value": "{color.error.500}"
      },
      "warning": {
        "$value": "{color.warning.500}"
      },
      "info": {
        "$value": "{color.info.500}"
      }
    },
    "overlay": {
      "scrim": {
        "$value": "linear-gradient(to top, rgba(0,0,0,0.45), rgba(0,0,0,0.05), transparent)"
      }
    }
  }
}