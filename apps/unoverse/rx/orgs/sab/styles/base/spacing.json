{
  "$description": "Dimension scale (rem), Tailwind-style: step N = N × 0.25rem. Used for BOTH spacing (gap/padding/margin) AND element sizes (width/height) — one scale, like Tailwind's w-5/p-5. Element dimensions reference a step (e.g. width: \"8\" = 2rem) instead of a raw rem.",
  "space": {
    "$type": "dimension",
    "0":   { "$value": "0" },
    "1":   { "$value": "0.25rem" },
    "1.5": { "$value": "0.375rem" },
    "2":   { "$value": "0.5rem" },
    "3":   { "$value": "0.75rem" },
    "4":   { "$value": "1rem" },
    "5":   { "$value": "1.25rem" },
    "6":   { "$value": "1.5rem" },
    "7":   { "$value": "1.75rem" },
    "8":   { "$value": "2rem" },
    "10":  { "$value": "2.5rem" },
    "12":  { "$value": "3rem" },
    "16":  { "$value": "4rem" },
    "20":  { "$value": "5rem" },
    "24":  { "$value": "6rem" },
    "28":  { "$value": "7rem" },
    "40":  { "$value": "10rem" },
    "50":  { "$value": "12.5rem" },
    "75":  { "$value": "18.75rem" },
    "90":  { "$value": "22.5rem" },
    "100": { "$value": "25rem" },
    "120": { "$value": "30rem" },
    "140": { "$value": "35rem" },
    "160": { "$value": "40rem" },
    "180": { "$value": "45rem" },
    "200": { "$value": "50rem" }
  }
}
