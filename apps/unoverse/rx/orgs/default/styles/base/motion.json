{
  "$description": "Transitions + easing. Seeded from tokens.css --transition-* / --ease-*.",
  "duration": {
    "$type": "duration",
    "fast":   { "$value": "150ms" },
    "base":   { "$value": "200ms" },
    "slow":   { "$value": "300ms" },
    "bounce": { "$value": "400ms" }
  },
  "ease": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.4, 0, 0.2, 1] },
    "bounce":   { "$value": [0.34, 1.56, 0.64, 1] },
    "smooth":   { "$value": [0.25, 0.1, 0.25, 1] }
  }
}
