{
  "$description": "Light theme — the semantic color layer. Components reference THESE names; aliases point at base/color.json. Seeded from colors.css semantic vars.",
  "color": {
    "$type": "color",
    "text": {
      "primary":   { "$value": "{color.gray.900}" },
      "secondary": { "$value": "{color.gray.600}" },
      "tertiary":  { "$value": "{color.gray.500}" },
      "inverse":   { "$value": "{color.white}" }
    },
    "surface": {
      "base":    { "$value": "{color.white}" },
      "raised":  { "$value": "{color.white}" },
      "sunken":  { "$value": "{color.gray.50}" },
      "inverse": { "$value": "{color.gray.800}" }
    },
    "border": {
      "subtle": { "$value": "{color.gray.200}" },
      "strong": { "$value": "{color.gray.300}" }
    },
    "action": {
      "primary":        { "$value": "{color.primary.500}" },
      "primary-hover":  { "$value": "{color.primary.600}" },
      "primary-active": { "$value": "{color.primary.700}" },
      "primary-text":   { "$value": "{color.white}" },
      "subtle":         { "$value": "{color.primary.50}" }
    },
    "status": {
      "success":        { "$value": "{color.primary.500}" },
      "success-subtle": { "$value": "{color.primary.50}" },
      "success-border": { "$value": "{color.primary.200}" },
      "success-text":   { "$value": "{color.primary.700}" },
      "error":          { "$value": "{color.error.500}" },
      "warning":        { "$value": "{color.warning.500}" },
      "info":           { "$value": "{color.info.500}" }
    },
    "overlay": {
      "scrim": { "$value": "linear-gradient(to top, rgba(0,0,0,0.45), rgba(0,0,0,0.05), transparent)" }
    }
  }
}
