{
  "$description": "Named keyframe animations as DATA. The SDK serializes these into CSS @keyframes (uno-<name>) once per render root; any definition animates by referencing one via `style.animation` — no SDK edit, no per-animation primitive. Stop keys are CSS keyframe selectors; decls use real CSS property names. `wave` is the thinking-dots bob, grounded in legacy ChatHistoryItem.module.css (waveFloat).",
  "keyframes": {
    "wave": {
      "$value": {
        "0%,100%": { "transform": "translateY(0)", "opacity": "0.4" },
        "50%":     { "transform": "translateY(-6px)", "opacity": "1" }
      }
    },
    "focusFadeIn": {
      "$value": {
        "from": { "opacity": "0", "transform": "scale(0.98)" },
        "to":   { "opacity": "1", "transform": "scale(1)" }
      }
    },
    "pulseRing": {
      "$value": {
        "0%":   { "transform": "scale(0.92)", "opacity": "0.45" },
        "70%":  { "opacity": "0.08" },
        "100%": { "transform": "scale(1.9)", "opacity": "0" }
      }
    },
    "slideUp": {
      "$value": {
        "from": { "opacity": "0", "transform": "translateY(20px)" },
        "to":   { "opacity": "1", "transform": "translateY(0)" }
      }
    },
    "breathe": {
      "$value": {
        "0%,100%": { "transform": "scale(1)" },
        "50%":     { "transform": "scale(1.08)" }
      }
    }
  }
}
