{
  "unoverse": "1.0",
  "kind": "component",
  "name": "ImageBlock",
  "category": "Media",
  "nodeSize": { "width": 600, "height": 460 },
  "description": "A single image from a URL with an optional caption beneath it.",
  "whenToUse": "Show one image from a URL — a photo, screenshot, generated visual, diagram — with an optional caption under it. The plain single-image choice: no title, no action button, no multi-image swiping, so it reads as a quiet figure rather than a promo or a gallery.",
  "props": {
    "image": {
      "type": "string",
      "default": "https://res.cloudinary.com/sonik/image/upload/v1761403583/gravity/YodaPark/starship.webp"
    },
    "alt": { "type": "string", "default": "Starship in deep space" },
    "caption": { "type": "string", "default": "A starship drifts past a distant nebula." }
  },
  "root": {
    "type": "Box",
    "style": { "width": "full", "direction": "column", "gap": "3" },
    "children": [
      {
        "type": "Box",
        "visibleWhen": "image",
        "style": { "width": "full", "radius": "lg", "overflow": "hidden" },
        "children": [
          {
            "type": "Image",
            "bind": { "src": "image", "alt": "alt" },
            "style": { "width": "full", "fit": "cover" }
          }
        ]
      },
      {
        "type": "Text",
        "visibleWhen": "caption",
        "bind": { "value": "caption" },
        "style": { "font": "body.sm", "color": "text.secondary" }
      }
    ]
  }
}
