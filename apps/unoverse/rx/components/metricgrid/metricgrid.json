{
  "unoverse": "1.0",
  "kind": "component",
  "name": "MetricGrid",
  "category": "Charts",
  "nodeSize": { "width": 560, "height": 360 },
  "description": "Grid of KPI tiles — each a labelled headline value with an optional prefix/suffix and icon, plus a colour-coded period-over-period delta (up/down/neutral). Sentiment and arrow glyph are resolved by the data producer (deltaPositive/deltaNegative/deltaNeutral + deltaArrow); the definition only composes them — no computation lives in the renderer.",
  "whenToUse": "Show several key metrics or KPIs together as a grid of tiles — each a label, a large headline number (with optional currency/percent affix and icon) and a colour-coded change indicator versus the prior period. Pick when summarising multiple numeric stats side by side at a glance, rather than a single standalone statistic or a time-series trend over many points.",
  "props": {
    "title": { "type": "string", "default": "This month at a glance" },
    "metrics": {
      "type": "array",
      "default": [
        { "label": "Revenue", "prefix": "$", "value": "48,250", "icon": "💰", "deltaArrow": "▲", "deltaValue": "12.4%", "deltaLabel": "MoM", "deltaPositive": true },
        { "label": "New Customers", "value": "312", "icon": "👥", "deltaArrow": "▲", "deltaValue": "5.1%", "deltaLabel": "MoM", "deltaPositive": true },
        { "label": "Churn", "value": "2.3", "suffix": "%", "icon": "📉", "deltaArrow": "▼", "deltaValue": "-0.4pp", "deltaLabel": "MoM", "deltaPositive": true },
        { "label": "Avg Order Value", "prefix": "$", "value": "154", "icon": "🛒", "deltaArrow": "→", "deltaValue": "0%", "deltaLabel": "flat", "deltaNeutral": true }
      ]
    }
  },
  "root": {
    "type": "Box",
    "style": { "width": "full", "direction": "column", "gap": "4" },
    "children": [
      {
        "type": "Text",
        "visibleWhen": "title",
        "bind": { "value": "title" },
        "style": { "font": "headline.sm", "weight": "semibold", "color": "text.primary" }
      },
      {
        "type": "Each",
        "bind": { "items": "metrics" },
        "style": { "columns": "2", "gap": "4" },
        "template": {
          "type": "Box",
          "style": {
            "direction": "column",
            "gap": "2",
            "padding": "4",
            "background": "surface.base",
            "border": "subtle",
            "radius": "lg",
            "shadow": "sm"
          },
          "children": [
            {
              "type": "Box",
              "style": { "direction": "row", "align": "center", "justify": "space-between", "gap": "2" },
              "children": [
                {
                  "type": "Text",
                  "bind": { "value": "label" },
                  "style": { "font": "label", "weight": "medium", "color": "text.secondary" }
                },
                {
                  "type": "Text",
                  "visibleWhen": "icon",
                  "bind": { "value": "icon" },
                  "style": { "font": "body.sm" }
                }
              ]
            },
            {
              "type": "Box",
              "style": { "direction": "row", "align": "baseline", "gap": "0" },
              "children": [
                {
                  "type": "Text",
                  "visibleWhen": "prefix",
                  "bind": { "value": "prefix" },
                  "style": { "font": "title", "weight": "medium", "color": "text.secondary" }
                },
                {
                  "type": "Text",
                  "bind": { "value": "value" },
                  "style": { "font": "headline.md", "weight": "semibold", "color": "text.primary" }
                },
                {
                  "type": "Text",
                  "visibleWhen": "suffix",
                  "bind": { "value": "suffix" },
                  "style": { "font": "title", "weight": "medium", "color": "text.secondary" }
                }
              ]
            },
            {
              "type": "Box",
              "style": { "direction": "row", "align": "center", "gap": "1" },
              "children": [
                {
                  "type": "Box",
                  "style": {
                    "direction": "row", "align": "center", "gap": "1", "color": "text.tertiary",
                    "when": [
                      { "field": "deltaPositive", "eq": true, "apply": { "color": "status.success" } },
                      { "field": "deltaNegative", "eq": true, "apply": { "color": "status.error" } }
                    ]
                  },
                  "children": [
                    { "type": "Text", "bind": { "value": "deltaArrow" }, "style": { "font": "label" } },
                    { "type": "Text", "bind": { "value": "deltaValue" }, "style": { "font": "label", "weight": "semibold" } }
                  ]
                },
                {
                  "type": "Text",
                  "visibleWhen": "deltaLabel",
                  "bind": { "value": "deltaLabel" },
                  "style": { "font": "label", "color": "text.tertiary" }
                }
              ]
            }
          ]
        }
      }
    ]
  }
}
