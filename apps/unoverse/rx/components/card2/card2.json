{
  "unoverse": "1.0",
  "kind": "component",
  "name": "Card2",
  "category": "Content",
  "nodeSize": { "width": 760, "height": 320 },
  "description": "Horizontal feature card: heading, description and a call-to-action beside a large image with a brand accent bar.",
  "whenToUse": "Present a single feature or offer as a wide horizontal banner — a heading, supporting text and a call-to-action button on one side, a large image on the other. Pick when the layout should run side by side across the full width rather than stack vertically in a narrow column.",
  "props": {
    "title": { "type": "string", "default": "Force Sensitivity Assessment" },
    "description": {
      "type": "string",
      "default": "Discover your connection to the Force with advanced midi-chlorian analysis. Receive personalized training recommendations and track your progress on the path to becoming a Jedi."
    },
    "image": {
      "type": "string",
      "default": "https://res.cloudinary.com/sonik/image/upload/v1761403583/gravity/YodaPark/force.avif"
    },
    "callToAction": { "type": "string", "default": "Start Assessment" }
  },
  "root": {
    "type": "Box",
    "style": {
      "width": "full",
      "direction": "row",
      "minHeight": "50",
      "background": "surface.base",
      "shadow": "md",
      "overflow": "hidden"
    },
    "children": [
      {
        "type": "Box",
        "style": {
          "flex": "1.2",
          "minWidth": "0",
          "direction": "column",
          "justify": "center",
          "align": "start",
          "gap": "4",
          "padding": "12"
        },
        "children": [
          {
            "type": "Text",
            "bind": { "value": "title" },
            "style": { "font": "headline.md", "weight": "semibold", "color": "text.primary" }
          },
          {
            "type": "Text",
            "visibleWhen": "description",
            "bind": { "value": "description" },
            "style": { "font": "body.md", "color": "text.secondary" }
          },
          {
            "type": "Ref",
            "ref": "Button",
            "visibleWhen": "callToAction",
            "props": { "label": "callToAction" }
          }
        ]
      },
      {
        "type": "Box",
        "visibleWhen": "image",
        "style": { "flex": "0.8", "direction": "row", "overflow": "hidden" },
        "children": [
          {
            "type": "Box",
            "style": { "position": "relative", "flex": "1", "overflow": "hidden" },
            "children": [
              {
                "type": "Image",
                "bind": { "src": "image", "alt": "title" },
                "style": { "position": "absolute", "inset": "0", "width": "full", "height": "full", "fit": "cover" }
              }
            ]
          },
          {
            "type": "Box",
            "style": { "width": "1.5", "background": "action.primary" }
          }
        ]
      }
    ]
  }
}
