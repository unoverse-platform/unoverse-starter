{
  "type": "Box",
  "style": {
    "position": "relative",
    "direction": "column",
    "width": "full",
    "minHeight": "full",
    "background": "surface.base",
    "border": "subtle",
    "shadow": "md",
    "textAlign": "start"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "close-button",
      "action": {
        "type": "setValue",
        "values": [
          {
            "key": "defaultState",
            "value": "inline"
          }
        ],
        "then": {
          "type": "setTemplateValue",
          "values": [
            {
              "key": "mode",
              "value": null
            }
          ]
        }
      },
      "style": {
        "position": "absolute",
        "inset": "0 0 auto auto",
        "zIndex": 2,
        "margin": "4"
      }
    },
    {
      "type": "Box",
      "style": {
        "flex": "0 0 auto",
        "height": "50",
        "width": "full",
        "overflow": "hidden"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "src": "primaryImage",
            "alt": "title"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "direction": "column",
        "gap": "5",
        "padding": [
          "xl",
          "8"
        ],
        "width": "full",
        "maxWidth": "160",
        "margin": [
          "0",
          "auto"
        ]
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "align": "center",
            "justify": "space-between",
            "gap": "md",
            "width": "full"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "gap": "2",
                "flex": 1,
                "minWidth": 0
              },
              "children": [
                {
                  "type": "Text",
                  "visibleWhen": "tagline",
                  "bind": {
                    "value": "tagline"
                  },
                  "style": {
                    "font": "label",
                    "weight": "semibold",
                    "color": "action.primary"
                  }
                },
                {
                  "type": "Text",
                  "bind": {
                    "value": "title"
                  },
                  "style": {
                    "font": "headline.md",
                    "weight": "bold",
                    "color": "text.primary",
                    "lineHeight": "tight"
                  }
                }
              ]
            },
            {
              "type": "Button",
              "action": {
                "type": "setValue",
                "values": [
                  {
                    "key": "defaultState",
                    "value": "apply"
                  }
                ]
              },
              "style": {
                "direction": "row",
                "align": "center",
                "gap": "xs",
                "flex": "0 0 auto",
                "background": "action.primary",
                "border": "none",
                "radius": "full",
                "padding": [
                  "2",
                  "4"
                ],
                "shadow": "sm",
                "cursor": "pointer",
                "transition": "all 150ms ease",
                "hover": {
                  "background": "action.primary-hover",
                  "shadow": "md"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "value": "Learn more",
                  "style": {
                    "font": "body.sm",
                    "weight": "medium",
                    "color": "action.primary-text"
                  }
                },
                {
                  "type": "Icon",
                  "icon": "arrowRight",
                  "style": {
                    "width": "3",
                    "height": "3",
                    "color": "action.primary-text"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Text",
          "visibleWhen": "description",
          "bind": {
            "value": "description"
          },
          "style": {
            "font": "body.md",
            "color": "text.secondary"
          }
        },
        {
          "type": "Markdown",
          "visibleWhen": "bodyCopy",
          "bind": {
            "value": "bodyCopy"
          },
          "style": {
            "font": "body.md"
          }
        },
        {
          "type": "Markdown",
          "visibleWhen": "link",
          "bind": {
            "value": "link"
          },
          "style": {
            "font": "body.md"
          }
        }
      ]
    }
  ]
}
