{
  "type": "Box",
  "style": {
    "direction": "row",
    "align": "stretch",
    "width": "full",
    "maxWidth": "140",
    "background": "surface.base",
    "border": "subtle",
    "radius": "xl",
    "shadow": "sm",
    "overflow": "hidden",
    "transition": "all 150ms ease",
    "hover": {
      "shadow": "md"
    },
    "height": "40"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "flex": "0 0 auto",
        "width": "24",
        "overflow": "hidden"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "src": "primaryImage",
            "alt": "title"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "flex": "1",
        "minWidth": "0",
        "direction": "column",
        "justify": "center",
        "gap": "1",
        "padding": [
          "2",
          "3"
        ],
        "textAlign": "start"
      },
      "children": [
        {
          "type": "Text",
          "bind": {
            "value": "title"
          },
          "style": {
            "font": "title",
            "weight": "semibold",
            "lineHeight": "tight",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "visibleWhen": "description",
          "bind": {
            "value": "description"
          },
          "style": {
            "font": "body.sm",
            "color": "text.secondary"
          }
        },
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "justify": "start",
            "margin": [
              "2",
              "0",
              "0",
              "0"
            ]
          },
          "children": [
            {
              "type": "Button",
              "action": {
                "type": "setValue",
                "values": [
                  {
                    "key": "defaultState",
                    "value": "course"
                  }
                ],
                "then": {
                  "type": "setTemplateValue",
                  "values": [
                    {
                      "key": "mode",
                      "value": "focus"
                    }
                  ]
                }
              },
              "style": {
                "direction": "row",
                "align": "center",
                "gap": "xs",
                "padding": [
                  "2",
                  "4"
                ],
                "background": "action.primary",
                "border": "none",
                "radius": "full",
                "cursor": "pointer",
                "transition": "all 150ms ease",
                "hover": {
                  "background": "action.primary-hover"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "bind": {
                    "value": "tagline"
                  },
                  "style": {
                    "font": "body.sm",
                    "weight": "medium",
                    "color": "action.primary-text",
                    "lineHeight": "tight"
                  }
                },
                {
                  "type": "Icon",
                  "icon": "arrowRight",
                  "style": {
                    "width": "3",
                    "height": "3",
                    "color": "action.primary-text"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
