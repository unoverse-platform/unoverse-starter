{
  "unoverse": "1.0",
  "kind": "component",
  "name": "RadialGauge",
  "category": "Charts",
  "nodeSize": { "width": 340, "height": 360 },
  "description": "Radial progress dial: a circular ring filled to a producer-supplied proportion ({{pct}}), with a value and label in the centre. Composed from a circular Box using the neutral `radial` style (a served fill token sweeping to the stop over a served track token) plus a centred hole — no chart primitive.",
  "whenToUse": "Show a single value as progress toward a whole — completion %, goal attainment, utilisation, a score out of 100. Pick for one proportion shown as a ring dial, rather than several metrics (a grid) or a comparison of categories (a bar chart).",
  "props": {
    "title": { "type": "string", "default": "Quarterly goal" },
    "pct": { "type": "string", "default": "72%" },
    "centerValue": { "type": "string", "default": "72%" },
    "label": { "type": "string", "default": "of target" }
  },
  "root": {
    "type": "Box",
    "style": {
      "width": "full",
      "direction": "column",
      "gap": "4",
      "padding": "6",
      "background": "surface.base",
      "border": "subtle",
      "radius": "lg",
      "shadow": "sm"
    },
    "children": [
      {
        "type": "Text",
        "visibleWhen": "title",
        "bind": { "value": "title" },
        "style": { "font": "headline.sm", "weight": "semibold", "color": "text.primary" }
      },
      {
        "type": "Box",
        "style": { "width": "full", "direction": "row", "justify": "center", "padding": ["2", "0"] },
        "children": [
          {
            "type": "Box",
            "style": {
              "width": "40",
              "height": "40",
              "radius": "full",
              "direction": "row",
              "align": "center",
              "justify": "center",
              "radial": { "fill": "action.primary", "track": "surface.sunken", "at": "{{pct}}" }
            },
            "children": [
              {
                "type": "Box",
                "style": {
                  "width": "28",
                  "height": "28",
                  "radius": "full",
                  "background": "surface.base",
                  "direction": "column",
                  "align": "center",
                  "justify": "center",
                  "gap": "0"
                },
                "children": [
                  { "type": "Text", "bind": { "value": "centerValue" }, "style": { "font": "headline.md", "weight": "semibold", "color": "text.primary" } },
                  { "type": "Text", "visibleWhen": "label", "bind": { "value": "label" }, "style": { "font": "label", "color": "text.tertiary" } }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
