{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "subjectTitle",
        "subtitle": "subjectSubtitle"
      }
    },
    {
      "type": "Each",
      "style": {
        "direction": "row",
        "wrap": "wrap",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-tile",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "subject",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "route"
            },
            {
              "key": "phase",
              "value": "direction"
            },
            {
              "key": "progressPct",
              "value": "66%"
            },
            {
              "key": "questionLabel",
              "value": "Question 4 of 6"
            }
          ]
        }
      },
      "items": [
        {
          "value": "accountancy-tax",
          "label": "Accountancy & Tax",
          "description": "ACCA, AAT, CIMA, ACA"
        },
        {
          "value": "law",
          "label": "Law",
          "description": "SQE, Bar and conversion"
        },
        {
          "value": "technology",
          "label": "Technology",
          "description": "Software, cyber and IT"
        },
        {
          "value": "hr",
          "label": "HR",
          "description": "CIPD qualifications"
        },
        {
          "value": "management",
          "label": "Management",
          "description": "Teams, projects, change"
        },
        {
          "value": "finance",
          "label": "Finance",
          "description": "CFA and investment"
        },
        {
          "value": "healthcare",
          "label": "Nursing and Healthcare",
          "description": "Degrees and leadership"
        },
        {
          "value": "ai",
          "label": "AI",
          "description": "Skills and apprenticeships"
        }
      ]
    }
  ]
}
