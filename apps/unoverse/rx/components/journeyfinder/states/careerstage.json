{
  "type": "Box",
  "style": { "direction": "column", "gap": "4", "width": "full" },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": { "title": "careerStageTitle", "subtitle": "careerStageSubtitle" }
    },
    {
      "type": "Each",
      "bind": { "items": "careerStageOptions" },
      "style": { "direction": "column", "gap": "2", "width": "full" },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            { "key": "careerStage", "value": "{{value}}" },
            { "key": "step", "value": "situation" },
            { "key": "phase", "value": "about" },
            { "key": "progressPct", "value": "33%" },
            { "key": "questionLabel", "value": "Question 2 of 6" }
          ]
        }
      }
    }
  ]
}
