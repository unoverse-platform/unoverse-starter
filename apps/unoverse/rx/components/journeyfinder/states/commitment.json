{
  "type": "Box",
  "style": { "direction": "column", "gap": "4", "width": "full" },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": { "title": "commitmentTitle", "subtitle": "commitmentSubtitle" }
    },
    {
      "type": "Each",
      "bind": { "items": "commitmentOptions" },
      "style": { "direction": "column", "gap": "2", "width": "full" },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            { "key": "commitment", "value": "{{value}}" },
            { "key": "step", "value": "searching" },
            { "key": "phase", "value": "results" },
            { "key": "progressPct", "value": "100%" },
            { "key": "questionLabel", "value": "" },
            { "key": "headerTitle", "value": "Your learning journey" },
            { "key": "inlinePrimary", "value": "Finding your courses…" },
            { "key": "displayState", "value": "inline" }
          ],
          "then": { "type": "submit" }
        }
      }
    }
  ]
}
