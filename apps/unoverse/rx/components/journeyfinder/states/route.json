{
  "type": "Box",
  "style": { "direction": "column", "gap": "4", "width": "full" },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": { "title": "routeTitle", "subtitle": "routeSubtitle" }
    },
    {
      "type": "Each",
      "bind": { "items": "routeOptions" },
      "style": { "direction": "column", "gap": "2", "width": "full" },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            { "key": "route", "value": "{{value}}" },
            { "key": "step", "value": "studymode" },
            { "key": "phase", "value": "study" },
            { "key": "progressPct", "value": "83%" },
            { "key": "questionLabel", "value": "Question 5 of 6" }
          ]
        }
      }
    }
  ]
}
