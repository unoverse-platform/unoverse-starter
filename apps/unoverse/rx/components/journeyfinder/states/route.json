{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "routeTitle",
        "subtitle": "routeSubtitle"
      }
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "route",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "studymode"
            },
            {
              "key": "phase",
              "value": "study"
            },
            {
              "key": "progressPct",
              "value": "83%"
            },
            {
              "key": "questionLabel",
              "value": "Question 5 of 6"
            }
          ]
        }
      },
      "items": [
        {
          "value": "professional-qualification",
          "label": "Professional qualification",
          "description": "An industry-recognised qualification",
          "icon": "qualifications"
        },
        {
          "value": "apprenticeship",
          "label": "Apprenticeship",
          "description": "Earn while you learn, employer funded",
          "icon": "apprenticeships"
        },
        {
          "value": "degree",
          "label": "University degree",
          "description": "Undergraduate or postgraduate study",
          "icon": "courses"
        },
        {
          "value": "short-courses",
          "label": "Short courses & CPD",
          "description": "Sharpen specific skills, fast",
          "icon": "layers"
        },
        {
          "value": "unsure",
          "label": "Not sure yet",
          "description": "Recommend the best route for me",
          "icon": "search"
        }
      ]
    }
  ]
}
