{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "situationTitle",
        "subtitle": "situationSubtitle"
      }
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "situation",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "subject"
            },
            {
              "key": "phase",
              "value": "direction"
            },
            {
              "key": "progressPct",
              "value": "50%"
            },
            {
              "key": "questionLabel",
              "value": "Question 3 of 6"
            }
          ]
        }
      },
      "items": [
        {
          "value": "school-leaver",
          "label": "School or college leaver",
          "description": "Finishing school and planning my next step",
          "icon": "school"
        },
        {
          "value": "working",
          "label": "Working",
          "description": "Employed \u2014 my employer may fund my study",
          "icon": "work"
        },
        {
          "value": "graduate",
          "label": "Graduate",
          "description": "I have a degree and want my next move",
          "icon": "courses"
        },
        {
          "value": "returning",
          "label": "Returning to study",
          "description": "Coming back after time away",
          "icon": "tutor"
        }
      ]
    }
  ]
}
