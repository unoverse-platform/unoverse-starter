{
  "type": "Box",
  "style": {
    "position": "relative",
    "width": "full",
    "height": "full",
    "minHeight": "160",
    "container": "inline-size",
    "direction": "row",
    "background": "surface.base",
    "overflow": "hidden"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "flex": "1.5",
        "minWidth": "0",
        "minHeight": "0",
        "direction": "column"
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "width": "full",
            "direction": "row",
            "align": "center",
            "gap": "4",
            "padding": [
              "4",
              "6"
            ],
            "background": "surface.inverse"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "direction": "column",
                "gap": "0"
              },
              "children": [
                {
                  "type": "Text",
                  "bind": {
                    "value": "headerTitle"
                  },
                  "style": {
                    "font": "headline.lg",
                    "weight": "semibold",
                    "color": "text.inverse"
                  }
                },
                {
                  "type": "Text",
                  "style": {
                    "font": "body.sm",
                    "color": "text.inverse"
                  },
                  "value": "Six quick questions"
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "visibleWhen": {
            "field": "phase",
            "ne": "results"
          },
          "style": {
            "direction": "column",
            "gap": "3",
            "padding": [
              "4",
              "8"
            ],
            "width": "full",
            "borderBottom": "subtle"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "direction": "row",
                "align": "center",
                "gap": "3",
                "width": "full"
              },
              "children": [
                {
                  "type": "Switch",
                  "on": "step",
                  "cases": {
                    "situation": {
                      "type": "Button",
                      "action": {
                        "type": "setValue",
                        "values": [
                          {
                            "key": "step",
                            "value": "careerstage"
                          },
                          {
                            "key": "phase",
                            "value": "about"
                          },
                          {
                            "key": "progressPct",
                            "value": "16%"
                          },
                          {
                            "key": "questionLabel",
                            "value": "Question 1 of 6"
                          }
                        ]
                      },
                      "style": {
                        "flex": "0 0 auto",
                        "width": "6",
                        "height": "6",
                        "radius": "full",
                        "background": "surface.sunken",
                        "border": "none",
                        "cursor": "pointer",
                        "direction": "row",
                        "align": "center",
                        "justify": "center",
                        "transition": "all 150ms ease",
                        "hover": {
                          "background": "border.subtle"
                        }
                      },
                      "children": [
                        {
                          "type": "Icon",
                          "icon": "arrowLeft",
                          "style": {
                            "width": "4",
                            "height": "4",
                            "color": "text.secondary"
                          }
                        }
                      ]
                    },
                    "subject": {
                      "type": "Button",
                      "action": {
                        "type": "setValue",
                        "values": [
                          {
                            "key": "step",
                            "value": "situation"
                          },
                          {
                            "key": "phase",
                            "value": "about"
                          },
                          {
                            "key": "progressPct",
                            "value": "33%"
                          },
                          {
                            "key": "questionLabel",
                            "value": "Question 2 of 6"
                          }
                        ]
                      },
                      "style": {
                        "flex": "0 0 auto",
                        "width": "6",
                        "height": "6",
                        "radius": "full",
                        "background": "surface.sunken",
                        "border": "none",
                        "cursor": "pointer",
                        "direction": "row",
                        "align": "center",
                        "justify": "center",
                        "transition": "all 150ms ease",
                        "hover": {
                          "background": "border.subtle"
                        }
                      },
                      "children": [
                        {
                          "type": "Icon",
                          "icon": "arrowLeft",
                          "style": {
                            "width": "4",
                            "height": "4",
                            "color": "text.secondary"
                          }
                        }
                      ]
                    },
                    "route": {
                      "type": "Button",
                      "action": {
                        "type": "setValue",
                        "values": [
                          {
                            "key": "step",
                            "value": "subject"
                          },
                          {
                            "key": "phase",
                            "value": "direction"
                          },
                          {
                            "key": "progressPct",
                            "value": "50%"
                          },
                          {
                            "key": "questionLabel",
                            "value": "Question 3 of 6"
                          }
                        ]
                      },
                      "style": {
                        "flex": "0 0 auto",
                        "width": "6",
                        "height": "6",
                        "radius": "full",
                        "background": "surface.sunken",
                        "border": "none",
                        "cursor": "pointer",
                        "direction": "row",
                        "align": "center",
                        "justify": "center",
                        "transition": "all 150ms ease",
                        "hover": {
                          "background": "border.subtle"
                        }
                      },
                      "children": [
                        {
                          "type": "Icon",
                          "icon": "arrowLeft",
                          "style": {
                            "width": "4",
                            "height": "4",
                            "color": "text.secondary"
                          }
                        }
                      ]
                    },
                    "studymode": {
                      "type": "Button",
                      "action": {
                        "type": "setValue",
                        "values": [
                          {
                            "key": "step",
                            "value": "route"
                          },
                          {
                            "key": "phase",
                            "value": "direction"
                          },
                          {
                            "key": "progressPct",
                            "value": "66%"
                          },
                          {
                            "key": "questionLabel",
                            "value": "Question 4 of 6"
                          }
                        ]
                      },
                      "style": {
                        "flex": "0 0 auto",
                        "width": "6",
                        "height": "6",
                        "radius": "full",
                        "background": "surface.sunken",
                        "border": "none",
                        "cursor": "pointer",
                        "direction": "row",
                        "align": "center",
                        "justify": "center",
                        "transition": "all 150ms ease",
                        "hover": {
                          "background": "border.subtle"
                        }
                      },
                      "children": [
                        {
                          "type": "Icon",
                          "icon": "arrowLeft",
                          "style": {
                            "width": "4",
                            "height": "4",
                            "color": "text.secondary"
                          }
                        }
                      ]
                    },
                    "commitment": {
                      "type": "Button",
                      "action": {
                        "type": "setValue",
                        "values": [
                          {
                            "key": "step",
                            "value": "studymode"
                          },
                          {
                            "key": "phase",
                            "value": "study"
                          },
                          {
                            "key": "progressPct",
                            "value": "83%"
                          },
                          {
                            "key": "questionLabel",
                            "value": "Question 5 of 6"
                          }
                        ]
                      },
                      "style": {
                        "flex": "0 0 auto",
                        "width": "6",
                        "height": "6",
                        "radius": "full",
                        "background": "surface.sunken",
                        "border": "none",
                        "cursor": "pointer",
                        "direction": "row",
                        "align": "center",
                        "justify": "center",
                        "transition": "all 150ms ease",
                        "hover": {
                          "background": "border.subtle"
                        }
                      },
                      "children": [
                        {
                          "type": "Icon",
                          "icon": "arrowLeft",
                          "style": {
                            "width": "4",
                            "height": "4",
                            "color": "text.secondary"
                          }
                        }
                      ]
                    }
                  }
                },
                {
                  "type": "Text",
                  "visibleWhen": "questionLabel",
                  "bind": {
                    "value": "questionLabel"
                  },
                  "style": {
                    "font": "label",
                    "color": "text.tertiary"
                  }
                },
                {
                  "type": "Box",
                  "style": {
                    "flex": "1",
                    "height": "1",
                    "background": "surface.sunken",
                    "radius": "full",
                    "overflow": "hidden"
                  },
                  "children": [
                    {
                      "type": "Box",
                      "style": {
                        "height": "full",
                        "width": "{{progressPct}}",
                        "background": "action.primary",
                        "radius": "full",
                        "transition": "all 300ms ease"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "style": {
            "flex": "1",
            "minHeight": "0",
            "overflow": "auto",
            "direction": "column",
            "gap": "5",
            "padding": [
              "6",
              "8"
            ],
            "width": "full"
          },
          "children": [
            {
              "type": "Switch",
              "on": "step",
              "cases": {
                "careerstage": {
                  "$include": "states/careerstage"
                },
                "situation": {
                  "$include": "states/situation"
                },
                "subject": {
                  "$include": "states/subject"
                },
                "route": {
                  "$include": "states/route"
                },
                "studymode": {
                  "$include": "states/studymode"
                },
                "commitment": {
                  "$include": "states/commitment"
                },
                "searching": {
                  "$include": "states/searching"
                },
                "results": {
                  "$include": "states/results"
                },
                "default": {
                  "$include": "states/careerstage"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "visibleWhen": {
        "field": "phase",
        "ne": "results"
      },
      "style": {
        "flex": "0.55",
        "minWidth": "0",
        "direction": "column",
        "background": "surface.sunken",
        "overflow": "hidden",
        "hideBelow": "180"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "alt": "headerTitle"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          },
          "src": "https://res.cloudinary.com/sonik/image/upload/w_1000,ar_2:3,c_fill,g_face,e_art:hokusai/v1782963908/BPP/images/1738752132-woman-conversation-laptop.jpg"
        }
      ]
    },
    {
      "type": "Ref",
      "ref": "close-button",
      "action": {
        "type": "setValue",
        "values": [
          {
            "key": "defaultState",
            "value": "inline"
          }
        ]
      },
      "style": {
        "position": "absolute",
        "inset": "0 0 auto auto",
        "margin": "4"
      }
    }
  ]
}
