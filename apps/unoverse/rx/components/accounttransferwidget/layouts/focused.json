{
  "type": "Box",
  "style": {
    "position": "relative",
    "width": "full",
    "height": "full",
    "minHeight": "160",
    "container": "inline-size",
    "direction": "row",
    "background": "surface.base",
    "border": "subtle",
    "radius": "lg",
    "shadow": "lg",
    "overflow": "hidden"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "flex": "1.5",
        "minWidth": "0",
        "direction": "column"
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "width": "full",
            "direction": "row",
            "align": "center",
            "gap": "4",
            "padding": [
              "4",
              "6"
            ],
            "background": "surface.inverse"
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "width": "12",
                "height": "12",
                "radius": "xl",
                "border": "subtle",
                "direction": "row",
                "align": "center",
                "justify": "center"
              },
              "children": [
                {
                  "type": "Icon",
                  "icon": "transfer",
                  "style": {
                    "width": "7",
                    "height": "7",
                    "color": "text.inverse"
                  }
                }
              ]
            },
            {
              "type": "Box",
              "style": {
                "flex": "1",
                "minWidth": "0",
                "direction": "column",
                "gap": "0"
              },
              "children": [
                {
                  "type": "Text",
                  "style": {
                    "font": "headline.lg",
                    "weight": "semibold",
                    "color": "text.inverse"
                  },
                  "value": "Bank Transfer"
                },
                {
                  "type": "Text",
                  "style": {
                    "font": "body.sm",
                    "color": "text.inverse"
                  },
                  "value": "Send money securely"
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "align": "center",
            "gap": "3",
            "padding": [
              "4",
              "8"
            ],
            "width": "full",
            "borderBottom": "subtle"
          },
          "children": [
            {
              "type": "Text",
              "visibleWhen": "stepLabel",
              "bind": {
                "value": "stepLabel"
              },
              "style": {
                "font": "label",
                "color": "text.tertiary"
              }
            },
            {
              "type": "Box",
              "style": {
                "flex": "1",
                "height": "1",
                "background": "surface.sunken",
                "radius": "full",
                "overflow": "hidden"
              },
              "children": [
                {
                  "type": "Box",
                  "style": {
                    "height": "full",
                    "width": "{{progressPct}}",
                    "background": "status.success",
                    "radius": "full",
                    "transition": "all 300ms ease"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "style": {
            "direction": "column",
            "gap": "5",
            "padding": [
              "6",
              "8"
            ],
            "width": "full"
          },
          "children": [
            {
              "type": "Switch",
              "on": "step",
              "cases": {
                "source": {
                  "$include": "states/source"
                },
                "recipient": {
                  "$include": "states/recipient"
                },
                "amount": {
                  "$include": "states/amount"
                },
                "review": {
                  "$include": "states/review"
                },
                "confirmation": {
                  "$include": "states/confirmation"
                },
                "default": {
                  "$include": "states/source"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "visibleWhen": "heroImage",
      "style": {
        "flex": "1",
        "minWidth": "0",
        "direction": "column",
        "background": "surface.sunken",
        "overflow": "hidden",
        "hideBelow": "180"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "src": "heroImage"
          },
          "style": {
            "width": "full",
            "height": "full",
            "fit": "cover"
          },
          "alt": "Bank Transfer"
        }
      ]
    },
    {
      "type": "Ref",
      "ref": "close-button",
      "action": {
        "type": "setValue",
        "values": [
          {
            "key": "defaultState",
            "value": "inline"
          }
        ]
      },
      "style": {
        "position": "absolute",
        "inset": "0 0 auto auto",
        "margin": "4"
      }
    }
  ]
}
