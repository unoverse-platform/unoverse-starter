{
  "type": "Button",
  "action": {
    "type": "setValue",
    "values": [
      {
        "key": "defaultState",
        "value": "focused"
      }
    ]
  },
  "style": {
    "position": "relative",
    "cursor": "pointer",
    "padding": "0",
    "direction": "row",
    "align": "stretch",
    "width": "full",
    "maxWidth": "140",
    "minHeight": "40",
    "background": "surface.base",
    "border": "subtle",
    "radius": "xl",
    "shadow": "sm",
    "overflow": "hidden",
    "transition": "all 150ms ease",
    "hover": {
      "shadow": "md"
    }
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "flex": "0 0 auto",
        "width": "16",
        "background": "surface.inverse",
        "radiusTopLeft": "xl",
        "radiusBottomLeft": "xl",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "children": [
        {
          "type": "Icon",
          "icon": "transfer",
          "style": {
            "width": "6",
            "height": "6",
            "color": "text.inverse"
          }
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "flex": "1",
        "minWidth": "0",
        "direction": "column",
        "gap": "1",
        "padding": "4"
      },
      "children": [
        {
          "type": "Box",
          "style": {
            "direction": "row",
            "justify": "center",
            "width": "full"
          },
          "children": [
            {
              "type": "Text",
              "style": {
                "font": "body.sm",
                "weight": "semibold",
                "color": "text.secondary"
              },
              "value": "Bank Transfer"
            }
          ]
        },
        {
          "type": "Text",
          "bind": {
            "value": "inlinePrimary"
          },
          "style": {
            "font": "title",
            "weight": "semibold",
            "lineHeight": "tight",
            "color": "text.primary"
          }
        },
        {
          "type": "Text",
          "style": {
            "font": "body.sm",
            "color": "text.secondary"
          },
          "value": "Tap to start a transfer"
        },
        {
          "type": "Box",
          "style": {
            "width": "full",
            "height": "1",
            "background": "surface.sunken",
            "radius": "full",
            "overflow": "hidden",
            "margin": [
              "2",
              "0",
              "0",
              "0"
            ]
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "height": "full",
                "width": "{{progressPct}}",
                "background": "status.success",
                "radius": "full",
                "transition": "all 300ms ease"
              }
            }
          ]
        },
        {
          "type": "Box",
          "visibleWhen": "stepLabel",
          "style": {
            "direction": "row",
            "justify": "center",
            "margin": [
              "2",
              "0",
              "0",
              "0"
            ]
          },
          "children": [
            {
              "type": "Box",
              "style": {
                "background": "surface.sunken",
                "radius": "full",
                "padding": [
                  "1",
                  "2"
                ]
              },
              "children": [
                {
                  "type": "Text",
                  "bind": {
                    "value": "stepLabel"
                  },
                  "style": {
                    "font": "caption",
                    "weight": "medium",
                    "color": "text.tertiary"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "visibleWhen": "heroImage",
      "style": {
        "flex": "0 0 auto",
        "width": "40",
        "overflow": "hidden",
        "hideBelow": "120",
        "position": "relative",
        "radiusTopRight": "xl",
        "radiusBottomRight": "xl"
      },
      "children": [
        {
          "type": "Image",
          "bind": {
            "src": "heroImage"
          },
          "style": {
            "position": "absolute",
            "inset": "0",
            "width": "full",
            "height": "full",
            "fit": "cover"
          },
          "alt": "Bank Transfer"
        }
      ]
    },
    {
      "type": "Box",
      "style": {
        "position": "absolute",
        "inset": "0 0 auto auto",
        "margin": "3",
        "width": "7",
        "height": "7",
        "radius": "full",
        "background": "surface.base",
        "border": "subtle",
        "shadow": "sm",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "children": [
        {
          "type": "Icon",
          "icon": "expand",
          "style": {
            "width": "4",
            "height": "4",
            "color": "text.secondary"
          }
        }
      ]
    }
  ]
}
