{
  "type": "Box",
  "style": { "direction": "column", "gap": "4", "width": "full" },
  "children": [
    { "type": "Ref", "ref": "section-header", "props": { "title": "amountTitle", "subtitle": "amountSubtitle" } },
    {
      "type": "Box",
      "style": { "direction": "column", "gap": "2", "width": "full" },
      "children": [
        { "type": "Text", "bind": { "value": "amountLabel" }, "style": { "font": "label", "weight": "semibold", "color": "text.secondary" } },
        {
          "type": "Box",
          "style": { "direction": "row", "align": "center", "gap": "2", "width": "full", "padding": ["3", "4"], "background": "surface.base", "border": "subtle", "radius": "lg" },
          "children": [
            { "type": "Text", "bind": { "value": "currencySymbol" }, "style": { "font": "headline.sm", "weight": "bold", "color": "text.tertiary" } },
            { "type": "Input", "bind": { "value": "amount" }, "placeholder": "0.00", "style": { "flex": "1", "minWidth": "0", "font": "headline.sm", "weight": "bold", "color": "text.primary", "background": "transparent", "border": "none", "outline": "none" } }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "style": { "direction": "column", "gap": "2", "width": "full" },
      "children": [
        { "type": "Text", "bind": { "value": "memoLabel" }, "style": { "font": "label", "weight": "semibold", "color": "text.secondary" } },
        { "type": "Input", "bind": { "value": "memo" }, "placeholder": "What's this for?", "style": { "width": "full", "padding": ["3", "4"], "font": "body.md", "color": "text.primary", "background": "surface.base", "border": "subtle", "radius": "lg", "outline": "none" } }
      ]
    },
    {
      "type": "Box",
      "style": { "direction": "row", "align": "center", "gap": "3", "width": "full" },
      "children": [
        {
          "type": "Button",
          "action": { "type": "setValue", "values": [{ "key": "step", "value": "recipient" }, { "key": "progressPct", "value": "50%" }, { "key": "stepLabel", "value": "Step 2 of 4" }, { "key": "inlinePrimary", "value": "Pick a recipient" }] },
          "bind": { "label": "backLabel" },
          "style": { "flex": "0 0 auto", "cursor": "pointer", "font": "button", "background": "transparent", "color": "text.primary", "border": "subtle", "padding": ["4", "6"], "radius": "lg" }
        },
        {
          "type": "Button",
          "action": { "type": "setValue", "values": [{ "key": "step", "value": "review" }, { "key": "progressPct", "value": "100%" }, { "key": "stepLabel", "value": "Step 4 of 4" }, { "key": "inlinePrimary", "value": "Review & confirm" }] },
          "bind": { "label": "amountCta" },
          "style": { "flex": "1", "cursor": "pointer", "font": "button", "background": "action.primary", "color": "action.primary-text", "border": "none", "padding": ["4", "6"], "radius": "lg", "direction": "row", "align": "center", "justify": "center", "transition": "all 150ms ease", "hover": { "background": "action.primary-hover" } }
        }
      ]
    }
  ]
}
