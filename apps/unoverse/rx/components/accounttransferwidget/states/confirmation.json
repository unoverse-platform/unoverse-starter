{
  "type": "Box",
  "style": { "direction": "column", "gap": "4", "align": "center", "width": "full", "padding": ["6", "0"] },
  "children": [
    {
      "type": "Box",
      "style": { "flex": "0 0 auto", "width": "16", "height": "16", "radius": "full", "background": "status.success-subtle", "direction": "row", "align": "center", "justify": "center" },
      "children": [
        { "type": "Icon", "icon": "success", "style": { "width": "8", "height": "8", "color": "status.success" } }
      ]
    },
    {
      "type": "Box",
      "style": { "direction": "column", "gap": "1", "align": "center", "width": "full" },
      "children": [
        { "type": "Text", "bind": { "value": "confirmTitle" }, "style": { "font": "headline.lg", "weight": "bold", "color": "text.primary" } },
        { "type": "Text", "bind": { "value": "confirmSubtitle" }, "style": { "font": "body.md", "color": "text.secondary" } }
      ]
    },
    {
      "type": "Box",
      "style": { "direction": "column", "align": "center", "gap": "1", "background": "surface.sunken", "radius": "lg", "padding": ["3", "5"] },
      "children": [
        { "type": "Text", "bind": { "value": "confirmNumberLabel" }, "style": { "font": "caption", "weight": "semibold", "color": "text.tertiary" } },
        { "type": "Text", "bind": { "value": "confirmationNumber" }, "style": { "font": "body.md", "weight": "bold", "color": "text.primary" } }
      ]
    },
    {
      "type": "Box",
      "style": { "direction": "column", "gap": "0", "width": "full", "background": "surface.base", "border": "subtle", "radius": "lg", "overflow": "hidden" },
      "children": [
        {
          "type": "Box",
          "style": { "direction": "row", "align": "center", "justify": "space-between", "gap": "3", "width": "full", "padding": "3", "borderBottom": "subtle" },
          "children": [
            { "type": "Text", "bind": { "value": "amountSentLabel" }, "style": { "font": "body.sm", "color": "text.tertiary" } },
            {
              "type": "Box",
              "style": { "direction": "row", "align": "center", "gap": "1" },
              "children": [
                { "type": "Text", "bind": { "value": "currencySymbol" }, "style": { "font": "body.md", "weight": "semibold", "color": "text.primary" } },
                { "type": "Text", "bind": { "value": "amount" }, "style": { "font": "body.md", "weight": "semibold", "color": "text.primary" } }
              ]
            }
          ]
        },
        { "type": "Ref", "ref": "detail-row", "props": { "label": "toLabel", "value": "recipientLabel" } },
        { "type": "Ref", "ref": "detail-row", "props": { "label": "arrivalLabel", "value": "estimatedArrival" }, "style": { "borderBottom": "none" } }
      ]
    },
    {
      "type": "Button",
      "action": { "type": "setValue", "values": [{ "key": "step", "value": "source" }, { "key": "progressPct", "value": "25%" }, { "key": "stepLabel", "value": "Step 1 of 4" }, { "key": "memo", "value": "" }, { "key": "inlinePrimary", "value": "Send money securely" }] },
      "bind": { "label": "confirmCta" },
      "style": { "width": "full", "cursor": "pointer", "font": "button", "background": "transparent", "color": "action.primary", "border": "subtle", "padding": ["4", "6"], "radius": "lg", "direction": "row", "align": "center", "justify": "center" }
    }
  ]
}
