{
  "type": "Box",
  "style": { "direction": "column", "gap": "4", "width": "full" },
  "children": [
    {
      "type": "Box",
      "style": { "direction": "column", "gap": "1", "align": "center", "width": "full", "padding": ["2", "0"] },
      "children": [
        {
          "type": "Box",
          "style": { "direction": "row", "align": "center", "gap": "2" },
          "children": [
            { "type": "Text", "bind": { "value": "currencySymbol" }, "style": { "font": "headline.sm", "weight": "semibold", "color": "text.tertiary" } },
            { "type": "Text", "bind": { "value": "amount" }, "style": { "font": "headline.lg", "weight": "bold", "lineHeight": "tight", "color": "text.primary" } }
          ]
        },
        { "type": "Text", "bind": { "value": "reviewTitle" }, "style": { "font": "body.md", "color": "text.secondary" } }
      ]
    },
    {
      "type": "Box",
      "style": { "direction": "column", "gap": "0", "width": "full", "background": "surface.base", "border": "subtle", "radius": "lg", "overflow": "hidden" },
      "children": [
        { "type": "Ref", "ref": "detail-row", "props": { "label": "fromLabel", "value": "sourceLabel", "sub": "sourceMeta" } },
        { "type": "Ref", "ref": "detail-row", "props": { "label": "toLabel", "value": "recipientLabel", "sub": "recipientBank" } },
        { "type": "Ref", "ref": "detail-row", "visibleWhen": "memo", "props": { "label": "memoReviewLabel", "value": "memo" } },
        { "type": "Ref", "ref": "detail-row", "props": { "label": "feeLabel", "value": "fee" }, "style": { "borderBottom": "none" } }
      ]
    },
    {
      "type": "Box",
      "style": { "direction": "row", "align": "center", "justify": "center", "gap": "2", "width": "full" },
      "children": [
        { "type": "Icon", "icon": "success", "style": { "width": "4", "height": "4", "color": "status.success" } },
        { "type": "Text", "bind": { "value": "secureNote" }, "style": { "font": "caption", "color": "text.tertiary" } }
      ]
    },
    {
      "type": "Box",
      "style": { "direction": "row", "align": "center", "gap": "3", "width": "full" },
      "children": [
        {
          "type": "Button",
          "action": { "type": "setValue", "values": [{ "key": "step", "value": "amount" }, { "key": "progressPct", "value": "75%" }, { "key": "stepLabel", "value": "Step 3 of 4" }, { "key": "inlinePrimary", "value": "Enter the amount" }] },
          "bind": { "label": "backLabel" },
          "style": { "flex": "0 0 auto", "cursor": "pointer", "font": "button", "background": "transparent", "color": "text.primary", "border": "subtle", "padding": ["4", "6"], "radius": "lg" }
        },
        {
          "type": "Button",
          "action": { "type": "setValue", "values": [{ "key": "step", "value": "confirmation" }, { "key": "inlinePrimary", "value": "Transfer complete" }] },
          "bind": { "label": "reviewCta" },
          "style": { "flex": "1", "cursor": "pointer", "font": "button", "background": "action.primary", "color": "action.primary-text", "border": "none", "padding": ["4", "6"], "radius": "lg", "direction": "row", "align": "center", "justify": "center", "transition": "all 150ms ease", "hover": { "background": "action.primary-hover" } }
        }
      ]
    }
  ]
}
