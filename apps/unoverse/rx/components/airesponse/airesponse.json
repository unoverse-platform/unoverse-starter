{
 "unoverse": "1.0",
 "kind": "component",
 "name": "AIResponse",
 "category": "Content",
 "nodeSize": {
  "width": 750,
  "height": 400
 },
 "description": "Streaming conversational AI answer: markdown body (tables, links, images) plus an optional thinking/progress line.",
 "whenToUse": "Default for chat-style AI replies that stream token-by-token. For a static rendered document or report use MarkdownRenderer; for a structured booking confirmation use BookingWidget.",
 "props": {
  "streaming": {
   "type": "boolean",
   "default": false
  },
  "thinking": {
   "type": "string",
   "input": true,
   "default": ""
  },
  "text": {
   "type": "string",
   "input": true,
   "default": "## How can I help?\n\nThis is an **AI response** rendered from _markdown_ — it streams in token by token and supports rich formatting:\n\n- **Lists** and `inline code`\n- [Links](https://example.com) that open in a new tab\n- Tables and images\n\n| Feature | Supported |\n| --- | --- |\n| Markdown body | ✅ |\n| Streaming | ✅ |\n"
  },
  "questions": {
   "type": "object",
   "input": true,
   "default": []
  }
 },
 "root": {
  "type": "Box",
  "style": {
   "direction": "column",
   "gap": "2",
   "width": "full"
  },
  "children": [
   {
    "type": "Box",
    "visibleWhen": "thinking",
    "style": {
     "direction": "row",
     "align": "center",
     "gap": "sm",
     "padding": [
      "2",
      "0",
      "0",
      "0"
     ]
    },
    "children": [
     {
      "type": "Box",
      "visibleWhen": "streaming",
      "style": {
       "direction": "row",
       "gap": "xs",
       "align": "center"
      },
      "children": [
       {
        "type": "Box",
        "style": {
         "width": "1.5",
         "height": "1.5",
         "background": "action.primary",
         "radius": "full",
         "animation": {
          "name": "wave",
          "duration": "1.6s",
          "easing": "ease-in-out"
         }
        }
       },
       {
        "type": "Box",
        "style": {
         "width": "1.5",
         "height": "1.5",
         "background": "action.primary",
         "radius": "full",
         "animation": {
          "name": "wave",
          "duration": "1.6s",
          "easing": "ease-in-out"
         },
         "animationDelay": "0.16s"
        }
       },
       {
        "type": "Box",
        "style": {
         "width": "1.5",
         "height": "1.5",
         "background": "action.primary",
         "radius": "full",
         "animation": {
          "name": "wave",
          "duration": "1.6s",
          "easing": "ease-in-out"
         },
         "animationDelay": "0.32s"
        }
       }
      ]
     },
     {
      "type": "Markdown",
      "bind": {
       "value": "thinking"
      },
      "style": {
       "font": "body.sm",
       "color": "text.tertiary"
      }
     }
    ]
   },
   {
    "type": "Box",
    "visibleWhen": "text",
    "style": {
     "background": "surface.sunken",
     "radius": "2xl",
     "radiusTopLeft": "0",
     "padding": [
      "sm",
      "md"
     ],
     "width": "fit-content",
     "maxWidth": "78%"
    },
    "children": [
     {
      "type": "Markdown",
      "bind": {
       "value": "text"
      },
      "style": {
       "font": "body.md",
       "color": "text.primary"
      }
     }
    ]
   },
   {
    "type": "Each",
    "visibleWhen": "questions",
    "bind": {
     "items": "questions"
    },
    "style": {
     "direction": "column",
     "gap": "1",
     "width": "full",
     "margin": [
      "2",
      "0",
      "0",
      "0"
     ]
    },
    "template": {
     "type": "Button",
     "action": "ask",
     "style": {
      "width": "full",
      "direction": "row",
      "align": "center",
      "gap": "2",
      "cursor": "pointer",
      "background": "transparent",
      "border": "none",
      "radius": "lg",
      "padding": [
       "1.5",
       "3"
      ],
      "transition": "all 150ms ease",
      "hover": {
       "background": "surface.sunken"
      }
     },
     "children": [
      {
       "type": "Icon",
       "icon": "chat",
       "style": {
        "flex": "0 0 auto",
        "width": "4",
        "height": "4",
        "color": "status.info"
       }
      },
      {
       "type": "Text",
       "bind": {
        "value": "value"
       },
       "style": {
        "font": "body.sm",
        "color": "text.secondary"
       }
      }
     ]
    }
   }
  ]
 }
}