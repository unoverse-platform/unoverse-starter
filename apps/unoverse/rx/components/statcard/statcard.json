{
  "unoverse": "1.0",
  "kind": "component",
  "name": "StatCard",
  "category": "Charts",
  "nodeSize": { "width": 360, "height": 260 },
  "description": "Single hero KPI card: a label, a large headline value, a colour-coded period-over-period delta, and a compact bar trend. Composed from Box + Each + {{pct}}-bound bars (no chart primitive); delta sentiment (deltaPositive/deltaNegative/deltaNeutral) and the trend proportions are resolved by the data producer.",
  "whenToUse": "Spotlight ONE key metric on its own — a single big number with its change versus the prior period and a small trend. Pick for a single prominent statistic, rather than several metrics together (a grid) or a full comparison of categories (a bar chart).",
  "props": {
    "label": { "type": "string", "default": "Monthly Revenue" },
    "value": { "type": "string", "default": "$48,250" },
    "deltaArrow": { "type": "string", "default": "▲" },
    "deltaValue": { "type": "string", "default": "12.4%" },
    "deltaLabel": { "type": "string", "default": "vs last month" },
    "deltaPositive": { "type": "boolean", "default": true },
    "deltaNegative": { "type": "boolean", "default": false },
    "deltaNeutral": { "type": "boolean", "default": false },
    "trend": {
      "type": "array",
      "default": [
        { "pct": "40%" }, { "pct": "55%" }, { "pct": "48%" }, { "pct": "62%" },
        { "pct": "58%" }, { "pct": "75%" }, { "pct": "70%" }, { "pct": "88%" },
        { "pct": "82%" }, { "pct": "100%" }
      ]
    }
  },
  "root": {
    "type": "Box",
    "style": {
      "width": "full",
      "direction": "column",
      "gap": "3",
      "padding": "6",
      "background": "surface.base",
      "border": "subtle",
      "radius": "lg",
      "shadow": "sm"
    },
    "children": [
      {
        "type": "Text",
        "bind": { "value": "label" },
        "style": { "font": "label", "weight": "medium", "color": "text.secondary" }
      },
      {
        "type": "Text",
        "bind": { "value": "value" },
        "style": { "font": "headline.lg", "weight": "semibold", "color": "text.primary" }
      },
      {
        "type": "Box",
        "style": { "direction": "row", "align": "center", "gap": "2" },
        "children": [
          {
            "type": "Box",
            "style": {
              "direction": "row", "align": "center", "gap": "1", "color": "text.tertiary",
              "when": [
                { "field": "deltaPositive", "eq": true, "apply": { "color": "status.success" } },
                { "field": "deltaNegative", "eq": true, "apply": { "color": "status.error" } }
              ]
            },
            "children": [
              { "type": "Text", "bind": { "value": "deltaArrow" }, "style": { "font": "body.sm" } },
              { "type": "Text", "bind": { "value": "deltaValue" }, "style": { "font": "body.sm", "weight": "semibold" } }
            ]
          },
          {
            "type": "Text",
            "visibleWhen": "deltaLabel",
            "bind": { "value": "deltaLabel" },
            "style": { "font": "body.sm", "color": "text.tertiary" }
          }
        ]
      },
      {
        "type": "Each",
        "bind": { "items": "trend" },
        "style": { "direction": "row", "align": "end", "gap": "1", "width": "full", "height": "10" },
        "template": {
          "type": "Box",
          "style": {
            "flex": "1",
            "height": "{{pct}}",
            "background": "action.subtle",
            "radiusTopLeft": "sm",
            "radiusTopRight": "sm"
          }
        }
      }
    ]
  }
}
