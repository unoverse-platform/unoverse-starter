{
  "unoverse": "1.0",
  "kind": "component",
  "name": "Card",
  "category": "Content",
  "nodeSize": { "width": 480, "height": 700 },
  "description": "Upright, stacked single-item card: image on top, then heading, supporting text and a primary action.",
  "whenToUse": "Present a single rich item as an upright stacked card — an image on top with a heading, supporting text and a primary action beneath it. Pick for one item shown on its own in a narrow column, rather than a wide side-by-side banner or a scrollable set of items.",
  "props": {
    "title": { "type": "string", "default": "Lightsaber Combat Training" },
    "description": {
      "type": "string",
      "default": "Master the seven forms of lightsaber combat with guidance from Jedi Masters."
    },
    "image": {
      "type": "string",
      "default": "https://res.cloudinary.com/sonik/image/upload/v1761403583/gravity/YodaPark/darth-vader-main_4560aff7.jpg"
    },
    "callToAction": { "type": "string", "default": "Begin Training" }
  },
  "root": {
    "type": "Box",
    "style": {
      "width": "full",
      "direction": "column",
      "background": "surface.base",
      "border": "subtle",
      "shadow": "lg",
      "overflow": "hidden"
    },
    "children": [
      {
        "type": "Box",
        "visibleWhen": "image",
        "style": { "width": "full", "height": "50", "overflow": "hidden" },
        "children": [
          {
            "type": "Image",
            "bind": { "src": "image", "alt": "title" },
            "style": { "width": "full", "height": "full", "fit": "cover" }
          }
        ]
      },
      {
        "type": "Box",
        "style": { "direction": "column", "padding": "lg", "gap": "3", "align": "start" },
        "children": [
          {
            "type": "Text",
            "bind": { "value": "title" },
            "style": { "font": "headline.sm", "weight": "semibold", "color": "text.primary" }
          },
          {
            "type": "Text",
            "visibleWhen": "description",
            "bind": { "value": "description" },
            "style": { "font": "body.md", "color": "text.secondary" }
          },
          {
            "type": "Ref",
            "ref": "Button",
            "visibleWhen": "callToAction",
            "props": { "label": "callToAction" }
          }
        ]
      }
    ]
  }
}
