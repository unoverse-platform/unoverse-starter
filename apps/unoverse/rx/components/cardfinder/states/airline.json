{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "airlineTitle",
        "subtitle": "airlineSubtitle"
      }
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "airlinePreference",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "travelfreq"
            },
            {
              "key": "phase",
              "value": "bestfit"
            },
            {
              "key": "progressPct",
              "value": "78%"
            },
            {
              "key": "questionLabel",
              "value": "Question 6 of 7"
            }
          ]
        }
      },
      "items": [
        {
          "value": "emirates",
          "label": "Emirates",
          "description": "Earn Skywards miles"
        },
        {
          "value": "saudia",
          "label": "SAUDIA",
          "description": "Earn AlFursan miles"
        },
        {
          "value": "none",
          "label": "No preference",
          "description": "Flexible rewards across airlines"
        }
      ]
    }
  ]
}
