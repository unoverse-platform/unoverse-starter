{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "incomeTitle",
        "subtitle": "incomeSubtitle"
      }
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "income",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "salary"
            },
            {
              "key": "phase",
              "value": "eligibility"
            },
            {
              "key": "progressPct",
              "value": "22%"
            },
            {
              "key": "questionLabel",
              "value": "Question 2 of 7"
            }
          ]
        }
      },
      "items": [
        {
          "value": "<7000",
          "label": "Less than 7,000 SAR"
        },
        {
          "value": "7000-12000",
          "label": "7,000 \u2013 12,000 SAR"
        },
        {
          "value": "12000-20000",
          "label": "12,000 \u2013 20,000 SAR"
        },
        {
          "value": "20000+",
          "label": "20,000+ SAR"
        }
      ]
    }
  ]
}
