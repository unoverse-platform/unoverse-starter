{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "incomeTitle",
        "subtitle": "incomeSubtitle"
      }
    },
    {
      "type": "Each",
      "bind": {
        "items": "incomeOptions"
      },
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "income",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "salary"
            },
            {
              "key": "phase",
              "value": "eligibility"
            },
            {
              "key": "progressPct",
              "value": "22%"
            },
            {
              "key": "questionLabel",
              "value": "Question 2 of 7"
            }
          ]
        }
      }
    }
  ]
}
