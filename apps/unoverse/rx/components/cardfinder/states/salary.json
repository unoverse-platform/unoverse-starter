{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "salaryTitle",
        "subtitle": "salarySubtitle"
      }
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "salaryTransfer",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "residency"
            },
            {
              "key": "phase",
              "value": "eligibility"
            },
            {
              "key": "progressPct",
              "value": "33%"
            },
            {
              "key": "questionLabel",
              "value": "Question 3 of 7"
            }
          ]
        }
      },
      "items": [
        {
          "value": "yes",
          "label": "Yes",
          "description": "My salary is transferred to SAB"
        },
        {
          "value": "no",
          "label": "No",
          "description": "My salary goes to another bank"
        },
        {
          "value": "unsure",
          "label": "Not sure",
          "description": "I need to check"
        }
      ]
    }
  ]
}
