{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "goalTitle",
        "subtitle": "goalSubtitle"
      }
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "goal",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "airline"
            },
            {
              "key": "phase",
              "value": "bestfit"
            },
            {
              "key": "progressPct",
              "value": "66%"
            },
            {
              "key": "questionLabel",
              "value": "Question 5 of 7"
            }
          ]
        }
      },
      "items": [
        {
          "value": "cashback",
          "label": "Cashback",
          "description": "Earn money back on everyday purchases",
          "icon": "coins"
        },
        {
          "value": "travel",
          "label": "Travel perks",
          "description": "Lounges, insurance, and travel benefits",
          "icon": "plane"
        },
        {
          "value": "miles",
          "label": "Airline miles",
          "description": "Earn miles with your preferred airline",
          "icon": "ticket"
        },
        {
          "value": "premium",
          "label": "Premium lifestyle",
          "description": "Concierge, exclusive access, and luxury perks",
          "icon": "crown"
        }
      ]
    }
  ]
}
