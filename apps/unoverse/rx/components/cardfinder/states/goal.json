{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "goalTitle",
        "subtitle": "goalSubtitle"
      }
    },
    {
      "type": "Each",
      "bind": {
        "items": "goalOptions"
      },
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "goal",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "airline"
            },
            {
              "key": "phase",
              "value": "bestfit"
            },
            {
              "key": "progressPct",
              "value": "66%"
            },
            {
              "key": "questionLabel",
              "value": "Question 5 of 7"
            }
          ]
        }
      }
    }
  ]
}
