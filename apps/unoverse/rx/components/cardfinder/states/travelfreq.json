{
  "type": "Box",
  "style": {
    "direction": "column",
    "gap": "4",
    "width": "full"
  },
  "children": [
    {
      "type": "Ref",
      "ref": "section-header",
      "props": {
        "title": "travelTitle",
        "subtitle": "travelSubtitle"
      }
    },
    {
      "type": "Each",
      "style": {
        "direction": "column",
        "gap": "2",
        "width": "full"
      },
      "template": {
        "type": "Ref",
        "ref": "choice-row",
        "action": {
          "type": "setValue",
          "values": [
            {
              "key": "travelFrequency",
              "value": "{{value}}"
            },
            {
              "key": "step",
              "value": "feetolerance"
            },
            {
              "key": "phase",
              "value": "bestfit"
            },
            {
              "key": "progressPct",
              "value": "90%"
            },
            {
              "key": "questionLabel",
              "value": "Last question"
            }
          ]
        }
      },
      "items": [
        {
          "value": "0-1",
          "label": "0 \u2013 1 flights per year",
          "description": "Occasional traveler"
        },
        {
          "value": "2-4",
          "label": "2 \u2013 4 flights per year",
          "description": "Regular traveler"
        },
        {
          "value": "5-10",
          "label": "5 \u2013 10 flights per year",
          "description": "Frequent traveler"
        },
        {
          "value": "10+",
          "label": "10+ flights per year",
          "description": "Very frequent traveler"
        }
      ]
    }
  ]
}
