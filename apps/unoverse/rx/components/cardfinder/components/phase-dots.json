{
  "type": "Box",
  "style": {
    "direction": "row",
    "align": "center",
    "justify": "center",
    "gap": "1",
    "margin": [
      "2",
      "0",
      "0",
      "0"
    ]
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "width": "2",
        "height": "2",
        "radius": "full",
        "background": "surface.sunken",
        "when": [
          {
            "field": "phase",
            "eq": "eligibility",
            "apply": {
              "background": "status.success"
            }
          }
        ]
      }
    },
    {
      "type": "Box",
      "style": {
        "width": "2",
        "height": "2",
        "radius": "full",
        "background": "surface.sunken",
        "when": [
          {
            "field": "phase",
            "eq": "bestfit",
            "apply": {
              "background": "status.success"
            }
          }
        ]
      }
    },
    {
      "type": "Box",
      "style": {
        "width": "2",
        "height": "2",
        "radius": "full",
        "background": "surface.sunken",
        "when": [
          {
            "field": "phase",
            "eq": "result",
            "apply": {
              "background": "status.success"
            }
          }
        ]
      }
    }
  ]
}
