{
  "unoverse": "1.0",
  "kind": "component",
  "name": "ListPicker",
  "category": "Input",
  "nodeSize": { "width": 380, "height": 360 },
  "description": "Vertical list of selectable rows — each an optional thumbnail with a title and supporting subtitle — under an optional heading. One tap selects a row.",
  "whenToUse": "Present a short set of choices as a vertical, tappable list of rows — each a title with an optional subtitle and thumbnail — so the user picks exactly one (language choice, menu options, quick actions, branching prompts). Pick when the interaction is selecting a single option from a small list, rather than displaying rich standalone content or a horizontally scrolling gallery of items.",
  "props": {
    "title": { "type": "string", "default": "Choose a language" },
    "subtitle": { "type": "string", "default": "Select your preferred language to continue" },
    "elements": {
      "type": "array",
      "default": [
        { "title": "English", "subtitle": "United States" },
        { "title": "Español", "subtitle": "Latinoamérica" },
        { "title": "Français", "subtitle": "France" },
        { "title": "日本語", "subtitle": "日本" }
      ]
    }
  },
  "root": {
    "type": "Box",
    "style": { "direction": "column", "gap": "2", "maxWidth": "75" },
    "children": [
      {
        "type": "Box",
        "visibleWhen": "title",
        "style": { "direction": "column", "padding": ["0", "1"] },
        "children": [
          {
            "type": "Text",
            "bind": { "value": "title" },
            "style": { "font": "body.sm", "weight": "semibold", "color": "text.primary" }
          },
          {
            "type": "Text",
            "visibleWhen": "subtitle",
            "bind": { "value": "subtitle" },
            "style": { "font": "body.sm", "color": "text.tertiary" }
          }
        ]
      },
      {
        "type": "Each",
        "bind": { "items": "elements" },
        "style": { "direction": "column", "gap": "1.5" },
        "template": {
          "type": "Button",
          "action": "select",
          "style": {
            "width": "full",
            "direction": "row",
            "align": "center",
            "justify": "start",
            "gap": "3",
            "padding": ["3", "4"],
            "background": "surface.base",
            "border": "subtle",
            "radius": "lg",
            "cursor": "pointer",
            "transition": "all 150ms ease",
            "hover": { "background": "surface.sunken", "border": "strong", "shadow": "sm" },
            "active": { "background": "surface.sunken" }
          },
          "children": [
            {
              "type": "Image",
              "visibleWhen": "imageUrl",
              "bind": { "src": "imageUrl", "alt": "title" },
              "style": { "width": "10", "height": "10", "radius": "md", "fit": "cover" }
            },
            {
              "type": "Box",
              "style": { "direction": "column", "gap": "1", "flex": "1", "minWidth": "0", "align": "start" },
              "children": [
                {
                  "type": "Text",
                  "bind": { "value": "title" },
                  "style": { "font": "body.sm", "weight": "medium", "color": "text.primary" }
                },
                {
                  "type": "Text",
                  "visibleWhen": "subtitle",
                  "bind": { "value": "subtitle" },
                  "style": { "font": "body.sm", "color": "text.tertiary", "overflow": "hidden" }
                }
              ]
            }
          ]
        }
      }
    ]
  }
}
