{
  "unoverse": "1.0",
  "kind": "component",
  "name": "StackedBarChart",
  "category": "Charts",
  "nodeSize": { "width": 560, "height": 400 },
  "description": "Stacked bar chart showing composition per category. Composed from a nested Box + Each (no chart primitive): each bar stacks segments whose heights bind to producer-supplied proportions ({{pct}}) and whose colours are served tokens bound per segment ({{color}}). A legend maps colours to series.",
  "whenToUse": "Show how a total breaks down into parts across categories — revenue by product per quarter, traffic by channel per week. Pick when each bar is a composition of sub-parts that should sum visually, rather than single values (plain bar chart) or a ranked list.",
  "props": {
    "title": { "type": "string", "default": "Revenue by product" },
    "series": {
      "type": "array",
      "default": [
        { "label": "Product A", "color": "action.primary" },
        { "label": "Product B", "color": "status.info" },
        { "label": "Product C", "color": "status.warning" }
      ]
    },
    "bars": {
      "type": "array",
      "default": [
        { "label": "Q1", "segments": [{ "pct": "15%", "color": "status.warning" }, { "pct": "25%", "color": "status.info" }, { "pct": "30%", "color": "action.primary" }] },
        { "label": "Q2", "segments": [{ "pct": "20%", "color": "status.warning" }, { "pct": "30%", "color": "status.info" }, { "pct": "40%", "color": "action.primary" }] },
        { "label": "Q3", "segments": [{ "pct": "20%", "color": "status.warning" }, { "pct": "25%", "color": "status.info" }, { "pct": "35%", "color": "action.primary" }] },
        { "label": "Q4", "segments": [{ "pct": "20%", "color": "status.warning" }, { "pct": "35%", "color": "status.info" }, { "pct": "45%", "color": "action.primary" }] }
      ]
    }
  },
  "root": {
    "type": "Box",
    "style": {
      "width": "full",
      "direction": "column",
      "gap": "4",
      "padding": "6",
      "background": "surface.base",
      "border": "subtle",
      "radius": "lg",
      "shadow": "sm"
    },
    "children": [
      {
        "type": "Box",
        "style": { "direction": "row", "align": "center", "justify": "space-between", "gap": "4", "width": "full" },
        "children": [
          {
            "type": "Text",
            "visibleWhen": "title",
            "bind": { "value": "title" },
            "style": { "font": "headline.sm", "weight": "semibold", "color": "text.primary" }
          },
          {
            "type": "Each",
            "bind": { "items": "series" },
            "style": { "direction": "row", "align": "center", "gap": "4" },
            "template": {
              "type": "Box",
              "style": { "direction": "row", "align": "center", "gap": "2" },
              "children": [
                { "type": "Box", "style": { "width": "3", "height": "3", "background": "{{color}}", "radius": "sm" } },
                { "type": "Text", "bind": { "value": "label" }, "style": { "font": "label", "color": "text.secondary" } }
              ]
            }
          }
        ]
      },
      {
        "type": "Each",
        "bind": { "items": "bars" },
        "style": { "direction": "row", "align": "stretch", "justify": "space-between", "gap": "4", "width": "full", "height": "40", "borderBottom": "strong" },
        "template": {
          "type": "Each",
          "bind": { "items": "segments" },
          "style": { "flex": "1", "direction": "column", "justify": "end", "height": "full", "overflow": "hidden", "radiusTopLeft": "sm", "radiusTopRight": "sm" },
          "template": {
            "type": "Box",
            "style": { "width": "full", "height": "{{pct}}", "background": "{{color}}" }
          }
        }
      },
      {
        "type": "Each",
        "bind": { "items": "bars" },
        "style": { "direction": "row", "justify": "space-between", "gap": "4", "width": "full" },
        "template": {
          "type": "Box",
          "style": { "flex": "1", "direction": "row", "justify": "center" },
          "children": [
            { "type": "Text", "bind": { "value": "label" }, "style": { "font": "label", "color": "text.tertiary" } }
          ]
        }
      }
    ]
  }
}
