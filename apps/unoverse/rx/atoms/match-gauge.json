{
  "unoverse": "1.0",
  "kind": "atom",
  "name": "MatchGauge",
  "description": "Circular score gauge: a conic radial ring filled to a percent, the value in the center, a label below. Composed from primitives (a circular Box with a `radial` fill) — not a chart leaf. Owns its full style — references tokens only.",
  "whenToUse": "Show a match/score/progress percentage as a ring (e.g. a recommendation fit score). Compose via a Ref, mapping value (a percent string like \"95%\") and label to host fields.",
  "props": {
    "value": { "type": "string", "default": "95%" },
    "label": { "type": "string", "default": "Match" }
  },
  "root": {
    "type": "Box",
    "style": { "direction": "column", "align": "center", "gap": "1" },
    "children": [
      {
        "type": "Box",
        "style": { "width": "16", "height": "16", "radius": "full", "radial": { "fill": "status.success", "track": "surface.sunken", "at": "{{value}}" }, "direction": "row", "align": "center", "justify": "center" },
        "children": [
          {
            "type": "Box",
            "style": { "width": "12", "height": "12", "radius": "full", "background": "surface.base", "direction": "row", "align": "center", "justify": "center" },
            "children": [
              { "type": "Text", "bind": { "value": "value" }, "style": { "font": "body.md", "weight": "bold", "color": "status.success-text" } }
            ]
          }
        ]
      },
      { "type": "Text", "bind": { "value": "label" }, "style": { "font": "caption", "weight": "semibold", "color": "text.tertiary" } }
    ]
  }
}
