{
  "unoverse": "1.0",
  "kind": "atom",
  "name": "Button",
  "description": "Primary action button. Owns its full style — references tokens only (the theme's action colors carry the brand).",
  "whenToUse": "The standard call-to-action. Components COMPOSE this atom via a Ref node.",
  "props": {
    "label": { "type": "string", "default": "Get Started" }
  },
  "root": {
    "type": "Button",
    "bind": { "label": "label" },
    "action": "click",
    "style": {
      "display": "inline-flex",
      "align": "center",
      "justify": "center",
      "cursor": "pointer",
      "border": "none",
      "font": "button",
      "background": "action.primary",
      "color": "action.primary-text",
      "padding": ["3", "6"],
      "minHeight": "10",
      "radius": "sm"
    }
  }
}
