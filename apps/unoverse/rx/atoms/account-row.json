{
  "unoverse": "1.0",
  "kind": "atom",
  "name": "AccountRow",
  "description": "A selectable account/beneficiary card: a title with an optional masked-number sub-line, an optional right-aligned figure (e.g. balance), and an optional bank line below. A richer sibling of choice-row for money UIs. Owns its full style — references tokens only.",
  "whenToUse": "A bank account or beneficiary in a selectable list (transfers, payees). Compose via a Ref as an Each `template`, supplying the per-step `action`; reads per-item fields (label/sub/balance/meta) from the Each scope.",
  "props": {
    "label": { "type": "string", "default": "Account name" },
    "sub": { "type": "string", "default": "" },
    "balance": { "type": "string", "default": "" },
    "meta": { "type": "string", "default": "" }
  },
  "root": {
    "type": "Button",
    "action": "select",
    "style": { "width": "full", "direction": "column", "gap": "1", "align": "start", "padding": "3", "background": "surface.base", "border": "subtle", "radius": "lg", "cursor": "pointer", "transition": "all 150ms ease", "hover": { "background": "surface.sunken" } },
    "children": [
      {
        "type": "Box",
        "style": { "direction": "row", "align": "start", "justify": "space-between", "gap": "3", "width": "full" },
        "children": [
          {
            "type": "Box",
            "style": { "direction": "column", "align": "start", "gap": "0", "flex": "1", "minWidth": "0" },
            "children": [
              { "type": "Text", "bind": { "value": "label" }, "style": { "font": "body.md", "weight": "semibold", "color": "text.primary" } },
              { "type": "Text", "visibleWhen": "sub", "bind": { "value": "sub" }, "style": { "font": "caption", "color": "text.tertiary" } }
            ]
          },
          { "type": "Text", "visibleWhen": "balance", "bind": { "value": "balance" }, "style": { "flex": "0 0 auto", "font": "body.md", "weight": "bold", "color": "text.primary" } }
        ]
      },
      { "type": "Text", "visibleWhen": "meta", "bind": { "value": "meta" }, "style": { "font": "body.sm", "color": "text.secondary" } }
    ]
  }
}
