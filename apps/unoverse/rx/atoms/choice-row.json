{
  "unoverse": "1.0",
  "kind": "atom",
  "name": "ChoiceRow",
  "description": "Selectable option row: an optional leading icon, a label and optional description, inside a bordered card button with a hover surface. Owns its full style — references tokens only.",
  "whenToUse": "The repeated option inside a wizard step's Each (or any single-select list). Compose via a Ref as the Each `template`, and supply the per-step `action`. Reads per-item fields (label/description/icon) from the Each scope.",
  "props": {
    "label": { "type": "string", "default": "Option" },
    "description": { "type": "string", "default": "" },
    "icon": { "type": "string", "default": "" }
  },
  "root": {
    "type": "Button",
    "action": "select",
    "style": { "width": "full", "direction": "row", "align": "center", "gap": "3", "padding": "3", "textAlign": "start", "background": "surface.base", "border": "subtle", "radius": "lg", "cursor": "pointer", "transition": "all 150ms ease", "hover": { "background": "surface.sunken" } },
    "children": [
      { "type": "Icon", "visibleWhen": "icon", "bind": { "name": "icon" }, "style": { "width": "6", "height": "6", "color": "text.secondary" } },
      {
        "type": "Box",
        "style": { "direction": "column", "flex": "1", "minWidth": "0", "gap": "1", "align": "start" },
        "children": [
          { "type": "Text", "bind": { "value": "label" }, "style": { "font": "body.md", "weight": "semibold", "color": "text.primary" } },
          { "type": "Text", "visibleWhen": "description", "bind": { "value": "description" }, "style": { "font": "body.sm", "color": "text.secondary" } }
        ]
      }
    ]
  }
}
