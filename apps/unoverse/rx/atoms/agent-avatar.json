{
  "unoverse": "1.0",
  "kind": "atom",
  "name": "AgentAvatar",
  "description": "Circular assistant avatar with concentric sonar rings that pulse calmly while a call is active and burst into a slower layered ripple while the assistant is speaking, plus a gentle breathe (scale) on the photo while speaking. Owns its full style — references tokens only; rings are DATA. The breathe is a transform, so it grows the photo visually without shifting layout. Reads the host's `callState` field directly (idle|active|agentSpeaking|userSpeaking).",
  "whenToUse": "The animated avatar for a voice / live-agent surface whose host carries a `callState` field (idle|active|agentSpeaking|userSpeaking). Compose via a Ref, mapping avatarUrl/assistantName; the rings/breathe key off `callState` directly.",
  "props": {
    "avatarUrl": { "type": "string", "default": "" },
    "assistantName": { "type": "string", "default": "Assistant" }
  },
  "root": {
    "type": "Box",
    "style": { "direction": "column", "position": "relative", "align": "center", "justify": "center", "width": "28", "height": "28" },
    "children": [
      { "type": "Box", "visibleWhen": { "field": "callState", "in": ["active", "agentSpeaking", "userSpeaking"] }, "style": { "position": "absolute", "inset": "0", "radius": "full", "border": "status.info", "animation": { "name": "pulseRing", "duration": "3.2s", "easing": "ease-out" } } },
      { "type": "Box", "visibleWhen": { "field": "callState", "in": ["active", "agentSpeaking", "userSpeaking"] }, "style": { "position": "absolute", "inset": "0", "radius": "full", "border": "status.info", "animation": { "name": "pulseRing", "duration": "3.2s", "easing": "ease-out" }, "animationDelay": "1.6s" } },

      { "type": "Box", "visibleWhen": { "field": "callState", "eq": "agentSpeaking" }, "style": { "position": "absolute", "inset": "0", "radius": "full", "border": "status.info", "animation": { "name": "pulseRing", "duration": "2.2s", "easing": "ease-out" } } },
      { "type": "Box", "visibleWhen": { "field": "callState", "eq": "agentSpeaking" }, "style": { "position": "absolute", "inset": "0", "radius": "full", "border": "status.info", "animation": { "name": "pulseRing", "duration": "2.2s", "easing": "ease-out" }, "animationDelay": "0.73s" } },
      { "type": "Box", "visibleWhen": { "field": "callState", "eq": "agentSpeaking" }, "style": { "position": "absolute", "inset": "0", "radius": "full", "border": "status.info", "animation": { "name": "pulseRing", "duration": "2.2s", "easing": "ease-out" }, "animationDelay": "1.46s" } },

      { "type": "Image", "visibleWhen": { "field": "callState", "ne": "agentSpeaking" }, "bind": { "src": "avatarUrl", "alt": "assistantName" }, "style": { "width": "28", "height": "28", "radius": "full", "shadow": "lg", "fit": "cover" } },
      { "type": "Image", "visibleWhen": { "field": "callState", "eq": "agentSpeaking" }, "bind": { "src": "avatarUrl", "alt": "assistantName" }, "style": { "width": "28", "height": "28", "radius": "full", "shadow": "lg", "fit": "cover", "animation": { "name": "breathe", "duration": "2.6s", "easing": "ease-in-out" } } }
    ]
  }
}
