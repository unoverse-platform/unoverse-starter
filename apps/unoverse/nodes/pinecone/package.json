{
  "name": "@unoverse-platform/pinecone",
  "version": "1.1.9",
  "description": "Pinecone vector database nodes for GravityWorkflow - knowledge management and vector operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch"
  },
  "keywords": [
    "gravity",
    "workflow",
    "pinecone",
    "vector",
    "database",
    "knowledge",
    "embeddings"
  ],
  "author": "GravityAI",
  "license": "MIT",
  "dependencies": {
    "@pinecone-database/pinecone": "^6.1.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@unoverse-platform/plugin-base": ">=1.1.6"
  },
  "gravity": {
    "displayName": "Pinecone",
    "category": "storage",
    "logoUrl": "https://res.cloudinary.com/sonik/image/upload/v1749139513/gravity/icons/pinecone.png",
    "nodes": [
      {
        "name": "Pinecone Query",
        "type": "PromiseNode",
        "description": "Vector similarity search across Pinecone indexes",
        "category": "Knowledge & Vectors",
        "mcp": false
      },
      {
        "name": "Pinecone Service",
        "type": "PromiseNode",
        "description": "MCP-exposed Pinecone operations for agent vector queries",
        "category": "Knowledge & Vectors",
        "mcp": true
      },
      {
        "name": "Pinecone Upload",
        "type": "PromiseNode",
        "description": "Upsert vectors with metadata to Pinecone indexes",
        "category": "Knowledge & Vectors",
        "mcp": false
      }
    ],
    "features": [
      "Vector similarity search",
      "Batch vector upsert",
      "Metadata filtering",
      "MCP service interface",
      "Namespace management"
    ],
    "credentials": [
      {
        "name": "Pinecone API Key",
        "type": "pineconeApiKey",
        "required": true,
        "description": "API key from app.pinecone.io"
      }
    ]
  }
}
