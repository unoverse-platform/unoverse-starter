{
  "name": "@unoverse-platform/openai-realtime",
  "version": "1.0.1",
  "description": "OpenAI Realtime API (gpt-realtime-2) integration for Gravity workflow system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pino": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "gravity": {
    "displayName": "OpenAI Realtime",
    "category": "ai",
    "logoUrl": "https://res.cloudinary.com/sonik/image/upload/v1749262616/gravity/icons/ChatGPT-Logo.svg.webp",
    "nodes": [
      {
        "name": "OpenAI Realtime Voice",
        "type": "CallbackNode",
        "description": "Real-time voice conversation with gpt-realtime-2 via WebSocket",
        "category": "Voice",
        "mcp": false
      }
    ],
    "features": [
      "Real-time voice conversation",
      "WebSocket streaming",
      "Function calling support",
      "Low-latency responses",
      "Server VAD (Voice Activity Detection)",
      "Audio input/output"
    ],
    "credentials": [
      {
        "name": "OpenAI API Key",
        "type": "openaiApiKey",
        "required": true,
        "description": "API key from platform.openai.com"
      }
    ]
  },
  "peerDependencies": {
    "@unoverse-platform/plugin-base": ">=1.0.0"
  }
}
