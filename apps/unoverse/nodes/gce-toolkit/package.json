{
  "name": "@gravity-platform/gce-toolkit",
  "version": "1.2.4",
  "description": "Google Gemini Image Generation integration for Gravity workflow system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "gravity",
    "google",
    "gemini",
    "image-generation",
    "workflow",
    "nodes"
  ],
  "author": "Gravity Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "mime": "^4.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "gravity": {
    "displayName": "Google Gemini",
    "category": "media",
    "logoUrl": "https://res.cloudinary.com/sonik/image/upload/v1768126954/gravity/icons/gemini.png",
    "nodes": [
      {
        "name": "Gemini Image Gen",
        "type": "PromiseNode",
        "description": "Generate images from text prompts using Google Gemini Imagen",
        "category": "Media & Design",
        "mcp": false
      }
    ],
    "features": [
      "Text-to-image generation",
      "Gemini Imagen models",
      "Multiple output formats",
      "Style control"
    ],
    "credentials": [
      {
        "name": "Google AI API Key",
        "type": "googleAiApiKey",
        "required": true,
        "description": "API key from ai.google.dev"
      }
    ]
  },
  "peerDependencies": {
    "@gravity-platform/plugin-base": ">=1.1.6"
  }
}
