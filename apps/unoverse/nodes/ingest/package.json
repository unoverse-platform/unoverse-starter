{
  "name": "@unoverse-platform/ingest",
  "version": "4.1.0",
  "description": "Data ingestion nodes for Unoverse platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "unoverse",
    "ingest",
    "workflow",
    "nodes",
    "documents",
    "web-scraping",
    "data-extraction"
  ],
  "author": "Unoverse Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.6.0",
    "jschardet": "^3.1.3",
    "crypto": "^1.0.1",
    "googleapis": "^169.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "gravity": {
    "displayName": "Ingest",
    "category": "ingest",
    "logoUrl": "https://res.cloudinary.com/sonik/image/upload/v1775374180/gravity/icons/apollo.jpg",
    "nodes": [
      {
        "name": "Abyssale",
        "type": "PromiseNode",
        "description": "Generate dynamic images and banners via Abyssale templates",
        "category": "Media & Design",
        "mcp": false
      },
      {
        "name": "Document",
        "type": "PromiseNode",
        "description": "Load documents from URLs or file paths for processing",
        "category": "Documents",
        "mcp": false
      },
      {
        "name": "Document Parser",
        "type": "PromiseNode",
        "description": "Extract text from PDF, DOCX, and other document formats",
        "category": "Documents",
        "mcp": false
      },
      {
        "name": "Google Sheet",
        "type": "PromiseNode",
        "description": "Read and write data to Google Sheets spreadsheets",
        "category": "Storage & Data",
        "mcp": false
      },
      {
        "name": "Plaid Transactions",
        "type": "PromiseNode",
        "description": "Fetch financial transactions via Plaid banking API",
        "category": "Storage & Data",
        "mcp": false
      },
      {
        "name": "Spatial Ingest",
        "type": "PromiseNode",
        "description": "Ingest content into the Spatial 3D search index with embeddings",
        "category": "Knowledge & Vectors",
        "mcp": false
      }
    ],
    "features": [
      "Document parsing (PDF/DOCX)",
      "Google Sheets integration",
      "Financial data (Plaid)",
      "Text-to-speech (ElevenLabs)",
      "Spatial index ingestion"
    ],
    "credentials": []
  },
  "peerDependencies": {
    "@unoverse-platform/plugin-base": ">=1.0.0"
  }
}
