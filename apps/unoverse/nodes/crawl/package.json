{
  "name": "@gravity-platform/crawl",
  "version": "1.3.1",
  "description": "Web crawling nodes — Hyperbrowser scrape/crawl/extract and Apify actor runs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "setupFiles": [
      "dotenv/config"
    ],
    "testTimeout": 60000
  },
  "keywords": [
    "gravity",
    "crawl",
    "web-scraping",
    "hyperbrowser",
    "apify",
    "scrape",
    "extract",
    "workflow",
    "nodes"
  ],
  "author": "Gravity Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "gravity": {
    "displayName": "Crawl",
    "category": "ingest",
    "logoUrl": "https://res.cloudinary.com/sonik/image/upload/v1751883548/gravity/icons/HyperBrowser.svg",
    "nodes": [
      {
        "name": "Hyperbrowser Scrape",
        "type": "PromiseNode",
        "description": "Scrape a single URL to markdown, HTML and links with a stealth headless browser",
        "category": "Web Scraping",
        "mcp": false
      },
      {
        "name": "Hyperbrowser Crawl",
        "type": "PromiseNode",
        "description": "Crawl a site from a seed URL across many pages, returning per-page markdown and links",
        "category": "Web Scraping",
        "mcp": false
      },
      {
        "name": "Hyperbrowser Extract",
        "type": "PromiseNode",
        "description": "Extract structured JSON from one or more URLs using a prompt and/or schema",
        "category": "Web Scraping",
        "mcp": false
      },
      {
        "name": "Apify Starter",
        "type": "PromiseNode",
        "description": "Launch an Apify actor/task run on a URL list and return its runId",
        "category": "Web Scraping",
        "mcp": false
      },
      {
        "name": "Apify Results",
        "type": "CallbackNode",
        "description": "Iterate the results of an Apify run item-by-item with a continue signal",
        "category": "Web Scraping",
        "mcp": false
      }
    ],
    "features": [
      "Single-page scrape to markdown / HTML / links",
      "Multi-page site crawl with page limits and URL patterns",
      "LLM structured extraction via prompt + JSON schema",
      "Stealth & ultra-stealth fingerprinting",
      "Residential proxies with country targeting",
      "Automatic CAPTCHA solving",
      "Adblock and auto cookie-consent handling",
      "Apify actor/task runs with paginated result iteration"
    ],
    "credentials": [
      {
        "name": "Hyperbrowser API Key",
        "type": "hyperbrowserCredential",
        "required": false,
        "description": "API key from app.hyperbrowser.ai"
      },
      {
        "name": "Apify API Token",
        "type": "apifyCredential",
        "required": false,
        "description": "API token from console.apify.com"
      }
    ]
  },
  "peerDependencies": {
    "@gravity-platform/plugin-base": ">=1.1.6"
  }
}
