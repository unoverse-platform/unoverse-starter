# Copy to .env (gitignored) and fill in your own dev API keys to run the
# integration tests. Tests that lack their key are skipped, not failed.
#
#   cp .env.example .env   &&   npm test

# Hyperbrowser Scrape / Crawl / Extract — app.hyperbrowser.ai
HYPERBROWSER_API_KEY=

# Apify Starter / Results — console.apify.com
APIFY_API_TOKEN=
