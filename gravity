#!/usr/bin/env bash

# =============================================================================
# Gravity Platform CLI
# =============================================================================
# Zero-dependency developer tool. Works immediately after git clone.
#
# Usage:
#   ./gravity init      Interactive setup wizard
#   ./gravity db-setup  Create database tables (safe to re-run)
#   ./gravity start     Start the platform
#   ./gravity stop      Stop the platform
#   ./gravity status    Show service health
#   ./gravity logs      Stream all logs
#   ./gravity logs <s>  Stream logs for one service
#   ./gravity update    Pull latest images and restart
#   ./gravity update nodes  Rebuild packages + restart node-service only
#   ./gravity doctor    Diagnose issues
#   ./gravity pull      Pull images only
#   ./gravity dev       Install deps, gen:nodes, start dev environment
# =============================================================================

# Resolve lib/ directory relative to this script
GRAVITY_LIB="$(cd "$(dirname "$0")" && pwd)"
# If script is at project root (not in scripts/), lib is at scripts/lib
# If script is in scripts/, lib is at scripts/lib
if [ -d "$GRAVITY_LIB/lib" ]; then
  GRAVITY_LIB="$GRAVITY_LIB/lib"
elif [ -d "$GRAVITY_LIB/scripts/lib" ]; then
  GRAVITY_LIB="$GRAVITY_LIB/scripts/lib"
else
  echo "Error: Cannot find scripts/lib/ directory" >&2
  exit 1
fi

# ── Source all modules ──────────────────────────────────────────────
source "$GRAVITY_LIB/find-root.sh"
source "$GRAVITY_LIB/common.sh"
source "$GRAVITY_LIB/init.sh"
source "$GRAVITY_LIB/start.sh"
source "$GRAVITY_LIB/stop.sh"
source "$GRAVITY_LIB/status.sh"
source "$GRAVITY_LIB/logs.sh"
source "$GRAVITY_LIB/update.sh"
source "$GRAVITY_LIB/pull.sh"
source "$GRAVITY_LIB/doctor.sh"
source "$GRAVITY_LIB/dev.sh"
source "$GRAVITY_LIB/build.sh"
source "$GRAVITY_LIB/check.sh"
source "$GRAVITY_LIB/dashboard.sh"
source "$GRAVITY_LIB/help.sh"
source "$GRAVITY_LIB/open.sh"
source "$GRAVITY_LIB/db-setup.sh"
source "$GRAVITY_LIB/db-verify.sh"

# ── Dispatch ───────────────────────────────────────────────────────
case "${1:-}" in
  init)      cmd_init ;;
  start)     cmd_start ;;
  stop)      cmd_stop ;;
  status)    cmd_status ;;
  logs)      cmd_logs "${2:-}" ;;
  update)
    if [ "${2:-}" = "nodes" ]; then
      cmd_update_nodes
    else
      cmd_update
    fi
    ;;
  pull)      cmd_pull ;;
  check)     cmd_check ;;
  doctor)    cmd_doctor ;;
  dev)       cmd_dev ;;
  db-setup)  cmd_db_setup ;;
  db-verify) cmd_db_verify ;;
  build)     cmd_build "${2:-}" ;;
  gendesign) cmd_gendesign ;;
  open)      cmd_open "${2:-}" ;;
  help|--help|-h) cmd_help ;;
  "")        cmd_dashboard ;;
  *)
    echo "Unknown command: $1"
    echo "Run ./gravity help for usage"
    exit 1
    ;;
esac

