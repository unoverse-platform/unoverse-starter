# =============================================================================
# GRAVITY PLATFORM - DEPLOYMENT CONFIGURATION
# =============================================================================
# Copy to .env and fill in your values.
#
# NOTE: This file is for PLATFORM services only.

# =============================================================================
# CONTAINER REGISTRY - for pulling Docker images
# =============================================================================
# Get your DOCR token from your Gravity admin
# Login: echo "YOUR_TOKEN" | docker login registry.digitalocean.com -u YOUR_TOKEN --password-stdin
DOCR_TOKEN=dop_v1_your_token_here

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgres://user:password@host:5432/gravity

# =============================================================================
# REDIS (Required)
# =============================================================================
# Redis is required for cross-instance messaging and state.
#
# LOCAL DEV: Run Redis locally with Docker:
#   docker run -d --name redis -p 6379:6379 redis:7-alpine
#   Then use: REDIS_HOST=localhost, REDIS_PASSWORD= (empty), REDIS_TLS=false
#
# PRODUCTION: Use managed Redis (DigitalOcean, AWS ElastiCache, Upstash, etc.)

# --- Local Development ---
# Use host.docker.internal so Docker containers can reach Redis on your host
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_NAMESPACE=gravity

# --- Production (uncomment and fill in) ---
# REDIS_HOST=your-redis-host.example.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_TLS=true
# REDIS_NAMESPACE=gravity

# =============================================================================
# OIDC AUTHENTICATION
# =============================================================================
# Works with: Auth0, Keycloak, Azure AD, Cognito, etc.

# Server + Canvas (shared auth config)
AUTH_ISSUER=https://your-tenant.auth0.com
AUTH_CLIENT_ID=your-client-id
AUTH_AUDIENCE=gravity-api

# Set to true to disable authentication (local development only)
DISABLE_AUTH=false


# =============================================================================
# CANVAS UI (API URL)
# =============================================================================
# Canvas connects to the server API. WebSocket URL is derived automatically.
API_URL=http://localhost:4100

# =============================================================================
# UMAP SERVICE (Optional - Spatial AI)
# =============================================================================
# If you're running UMAP for spatial search/visualization, set the URL here.
# Leave commented out if not using UMAP.
# UMAP_SERVICE_URL=http://umap:5001

# =============================================================================
# DOMAIN (Production only)
# =============================================================================
# Set this for production deployments. URLs are derived automatically:
#   api.${DOMAIN} → API server
#   mcp.${DOMAIN} → MCP server
# Leave empty for local development (uses localhost)
DOMAIN=
