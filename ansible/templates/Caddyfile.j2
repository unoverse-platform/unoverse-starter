# Gravity Platform - Caddy Reverse Proxy Configuration
# Auto-generated by Ansible. Domain: {{ caddy_domain }}
#
# Mode: {% if caddy_behind_lb %}Behind Load Balancer (HTTP only){% else %}Direct (TLS via Lets Encrypt){% endif %}

{% if caddy_behind_lb %}
# Behind Load Balancer - HTTP only (LB terminates TLS)
:80 {
    @mem-api {
        host {{ caddy_domain }}
        path /mem-api/*
    }
    handle @mem-api {
        uri replace /mem-api /api
        reverse_proxy localhost:4104
    }

    @canvas host {{ caddy_domain }}
    handle @canvas {
        reverse_proxy localhost:3001
    }
    
    @api host api.{{ caddy_domain }}
    handle @api {
        # One Engine: the unoverse public listener serves the full /api surface
        # (+ /ws/gravity + /components). The gateway (:4100) is retired.
        reverse_proxy localhost:4105
    }
    
    # mcp-server (mcp.<domain> → :4103) RETIRED 2026-07 — the unoverse listener serves
    # MCP natively at :4105/mcp, reachable via unoverse.{{ caddy_domain }}.

    # Unoverse node plane (MCP defs + plugin management) — JWT-gated in-app (:4105).
    # The internal :4106 node runtime is Docker-network-only and is NEVER proxied.
    @unoverse host unoverse.{{ caddy_domain }}
    handle @unoverse {
        reverse_proxy localhost:4105
    }

{% if caddy_include_umap %}
    @umap host umap.{{ caddy_domain }}
    handle @umap {
        reverse_proxy localhost:5001
    }
{% endif %}
}
{% else %}
# Direct mode - Caddy handles TLS via Let's Encrypt

# Canvas UI - root domain
{{ caddy_domain }} {
    handle /mem-api/* {
        uri replace /mem-api /api
        reverse_proxy localhost:4104
    }

    handle {
        reverse_proxy localhost:3001
    }
}

# API surface — served by unoverse (One Engine; gateway retired)
api.{{ caddy_domain }} {
    reverse_proxy localhost:4105
}

# Unoverse listener — serves MCP natively at /mcp AND the node plane (plugin mgmt),
# all on :4105 (JWT-gated in-app). The retired mcp-server's mcp.<domain> → :4103 route
# is gone; use unoverse.<domain> for external MCP clients. The internal :4106 node
# runtime is Docker-network-only and is NEVER proxied.
unoverse.{{ caddy_domain }} {
    reverse_proxy localhost:4105
}

{% if caddy_include_umap %}
# UMAP Service (3D coordinate projections — POC only)
umap.{{ caddy_domain }} {
    reverse_proxy localhost:5001
}
{% endif %}
{% endif %}

# NOTE: SAB is deployed separately to CDN (Vercel/Netlify).
# NOTE: The memory dashboard (:4104) is NEVER exposed via a subdomain (SSH tunnel
# only — runbook 05-caddy); only the /mem-api/* API rewrite on the root domain is public.
# NOTE: Caddy is a PLAIN reverse proxy — no jwt/forward_auth. Auth is enforced
# in-app (AUTH_ENABLED); Caddy is optional and never load-bearing (AUTH_REMEDIATION.md).
