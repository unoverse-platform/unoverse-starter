# Gravity Platform Production Inventory
#
# ═══════════════════════════════════════════════════════════════════════════════
# SINGLE VM: You don't need this file!
# Just set DEPLOY_HOST and DEPLOY_USER in .env.production and run: gravity deploy
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file is ONLY needed for enterprise multi-VM deployments.
# Copy to production.yml and update with your values.

# =============================================================================
# POC — Single VM (use .env.production instead — this is just for reference)
# =============================================================================
# all:
#   hosts:
#     gravity-prod:
#       ansible_host: <YOUR_VM_IP>
#       ansible_user: root   # DigitalOcean / direct root SSH

# If your VM uses a non-root user with passwordless sudo (Azure azureuser, AWS ubuntu, GCP debian):
# Do NOT add ansible_become_password or ansible_become_flags — cloud VMs have passwordless sudo by default.
# Adding ansible_become_password: "" will cause a 12s timeout error.

# =============================================================================
# ENTERPRISE — Multi-VM
# =============================================================================
# Uncomment and configure for multi-VM deployments.
# Use with: ansible-playbook -i inventory/production.yml playbooks/install.yml -l app_vms
#
# all:
#   children:
#     app_vms:
#       hosts:
#         app-vm-1:
#           ansible_host: 10.0.1.10
#           ansible_user: root
#         app-vm-2:
#           ansible_host: 10.0.1.11
#           ansible_user: root
#       vars:
#         gravity_services:
#           - server
#           - workflow
#           - unoverse
#           - mcp-server
#           - memory
#           - canvas
#
#     ml_vms:
#       hosts:
#         ml-vm-1:
#           ansible_host: 10.0.1.20
#           ansible_user: root
#       vars:
#         gravity_services:
#           - umap
