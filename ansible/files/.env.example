# =============================================================================
# GRAVITY PLATFORM - PRODUCTION CONFIGURATION
# =============================================================================
# Copy to .env and fill in your values.
# This file is synced to gravity-starter for customer deployments.

# =============================================================================
# CONTAINER REGISTRY - for pulling Docker images
# =============================================================================
# Get your DOCR token from your Gravity admin
# Login: echo "YOUR_TOKEN" | docker login registry.digitalocean.com -u YOUR_TOKEN --password-stdin
DOCR_TOKEN=dop_v1_your_token_here

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://user:password@host:5432/gravity

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true
REDIS_NAMESPACE=gravity

# =============================================================================
# OIDC AUTHENTICATION
# =============================================================================
AUTH_ISSUER=https://your-tenant.auth0.com
AUTH_CLIENT_ID=your-client-id
AUTH_AUDIENCE=gravity-api

# =============================================================================
# UMAP SERVICE (Optional - Spatial AI)
# =============================================================================
# If you're running UMAP for spatial search/visualization, set the URL here.
# Leave commented out if not using UMAP.
# UMAP_SERVICE_URL=http://umap:5001

# =============================================================================
# DOMAIN & PUBLIC URLs
# =============================================================================
# Your domain for public-facing services (served via Caddy with TLS).
DOMAIN=example.com

# Canvas needs these to connect to the API from the browser.
# Without these, Canvas defaults to localhost:4100 which fails in production.
API_URL=https://api.example.com
VITE_SERVER_WS_URL=wss://api.example.com
