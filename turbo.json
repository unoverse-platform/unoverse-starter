{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "@gravity-platform/gravity-sab#dev": {
      "dependsOn": ["@gravity-platform/gravity-client#build"],
      "cache": false,
      "persistent": true
    },
    "@gravity-platform/gravity-sab#build": {
      "dependsOn": ["@gravity-platform/gravity-client#build"],
      "outputs": ["dist/**"]
    },
    "@gravity-platform/mcp-server#dev": {
      "dependsOn": ["@gravity-platform/gravity-client#build"],
      "cache": false,
      "persistent": true
    }
  }
}
